<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>
    <application
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Save"
        android:networkSecurityConfig="@xml/network_security_config">

        <!-- Splash Activity as Launcher (shows first) -->
        <activity
            android:name="com.example.save.ui.activities.SplashActivity"
            android:exported="true"
            android:theme="@style/SplashTheme">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- Handle saveapp://otp?code=XXX deep links from verification emails -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="saveapp" android:host="otp" />
            </intent-filter>
        </activity>

        <!-- Main Activity (shows after splash) -->
        <activity
            android:name="com.example.save.ui.activities.OnboardingActivity"
            android:exported="false" />

        <activity
            android:name="com.example.save.ui.activities.LoginActivity"
            android:exported="false"
            android:theme="@style/Theme.Save.LightOnly" />

        <activity
            android:name="com.example.save.ui.activities.WelcomeBackActivity"
            android:exported="false"
            android:theme="@style/Theme.Save.LightOnly" />

        <activity
            android:name="com.example.save.ui.activities.MemberLoginActivity"
            android:exported="false"
            android:theme="@style/Theme.Save.LightOnly" />

        <activity
            android:name="com.example.save.ui.activities.MemberInvitationActivity"
            android:exported="false"
            android:theme="@style/Theme.Save.LightOnly" />

        <activity
            android:name="com.example.save.ui.activities.OtpRequestActivity"
            android:exported="false"
            android:theme="@style/Theme.Save.LightOnly" />

        <activity android:name="com.example.save.ui.activities.OtpVerificationActivity"
            android:exported="false"
            android:theme="@style/Theme.Save.LightOnly" />

        <activity android:name="com.example.save.ui.activities.SetPasswordActivity"
            android:exported="false"
            android:theme="@style/Theme.Save.LightOnly" />

        <activity
            android:name=".ui.activities.NavigationTestingActivity"
            android:exported="true"
            android:theme="@style/Theme.Save" />

        <activity
            android:name="com.example.save.ui.activities.AdminLoginActivity"
            android:exported="false"
            android:theme="@style/Theme.Save.LightOnly"
            tools:ignore="DuplicateActivity" />
        <activity
            android:name="com.example.save.ui.activities.MemberMainActivity"
            android:exported="false"
            android:theme="@style/Theme.Save.Dashboard" />
        <activity
            android:name="com.example.save.ui.activities.MemberRegistrationActivity"
            android:exported="false"
            android:theme="@style/Theme.Save.LightOnly" />
        <activity
            android:name="com.example.save.ui.activities.AdminSignupActivity"
            android:exported="false"
            android:theme="@style/Theme.Save.LightOnly" />

        <activity
            android:name="com.example.save.ui.activities.AdminMainActivity"
            android:exported="false"
            android:theme="@style/Theme.Save.Dashboard" />

        <activity
            android:name="com.example.save.ui.activities.ResetPasswordActivity"
            android:exported="false"
            android:theme="@style/Theme.Save.LightOnly" />

        <activity
            android:name="com.example.save.ui.activities.PasswordResetSuccessActivity"
            android:exported="false"
            android:theme="@style/Theme.Save.LightOnly" />





        <activity
            android:name="com.example.save.ui.activities.AdminSetupWizardActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:theme="@style/Theme.Save.LightOnly">
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="saveapp" android:host="otp" />
            </intent-filter>
        </activity>

        <activity
            android:name="com.example.save.ui.activities.HelpSupportActivity"
            android:exported="false" />

        <activity
            android:name="com.example.save.ui.activities.TermsOfServiceActivity"
            android:exported="false" />

        <activity
            android:name="com.example.save.ui.activities.PrivacyPolicyActivity"
            android:exported="false" />

        <activity
            android:name="com.example.save.ui.activities.ContactAdminActivity"
            android:exported="false" />

        <activity
            android:name="com.example.save.ui.activities.ProfileInfoActivity"
            android:exported="false" />

        <activity
            android:name="com.example.save.ui.activities.LanguageSelectionActivity"
            android:exported="false" />

        <activity
            android:name="com.example.save.ui.activities.PaymentMethodSelectionActivity"
            android:exported="false" />


        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.provider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <meta-data
            android:name="preloaded_fonts"
            android:resource="@array/preloaded_fonts" />

    </application>

</manifest>