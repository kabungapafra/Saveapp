<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Dark shadow bottom-right -->
    <item
        android:bottom="0dp"
        android:left="3dp"
        android:right="0dp"
        android:top="3dp">
        <shape android:shape="rectangle">
            <corners android:radius="12dp" />
            <solid android:color="#50A3B1C6" />
        </shape>
    </item>

    <!-- Light highlight top-left -->
    <item
        android:bottom="3dp"
        android:left="0dp"
        android:right="3dp"
        android:top="0dp">
        <shape android:shape="rectangle">
            <corners android:radius="12dp" />
            <solid android:color="#E0FFFFFF" />
        </shape>
    </item>

    <!-- Badge body — Pure White -->
    <item
        android:bottom="2dp"
        android:left="2dp"
        android:right="2dp"
        android:top="2dp">
        <shape android:shape="rectangle">
            <corners android:radius="12dp" />
            <solid android:color="#FFFFFF" />
        </shape>
    </item>
</layer-list>
