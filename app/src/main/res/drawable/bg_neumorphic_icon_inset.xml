<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Light Inner Shadow (Bottom Right) -->
    <item
        android:bottom="0dp"
        android:left="3dp"
        android:right="0dp"
        android:top="3dp">
        <shape android:shape="oval">
            <solid android:color="@color/neumorphic_shadow_light" />
        </shape>
    </item>

    <!-- Dark Inner Shadow (Top Left) -->
    <item
        android:bottom="3dp"
        android:left="0dp"
        android:right="3dp"
        android:top="0dp">
        <shape android:shape="oval">
            <solid android:color="@color/neumorphic_shadow_dark" />
        </shape>
    </item>

    <!-- Main Background Color (Center) -->
    <item
        android:bottom="2dp"
        android:left="2dp"
        android:right="2dp"
        android:top="2dp">
        <shape android:shape="oval">
            <solid android:color="#E8ECF2" />
        </shape>
    </item>
</layer-list>
