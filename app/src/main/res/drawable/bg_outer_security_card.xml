<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Dark shadow bottom-right (raised card) -->
    <item
        android:bottom="0dp"
        android:left="8dp"
        android:right="0dp"
        android:top="8dp">
        <shape android:shape="rectangle">
            <corners android:radius="44dp" />
            <solid android:color="#50A3B1C6" />
        </shape>
    </item>

    <!-- Light highlight top-left (raised card) -->
    <item
        android:bottom="8dp"
        android:left="0dp"
        android:right="8dp"
        android:top="0dp">
        <shape android:shape="rectangle">
            <corners android:radius="44dp" />
            <solid android:color="#E0FFFFFF" />
        </shape>
    </item>

    <!-- Card body — SAME as background #ECEEF2 -->
    <item
        android:bottom="5dp"
        android:left="5dp"
        android:right="5dp"
        android:top="5dp">
        <shape android:shape="rectangle">
            <corners android:radius="44dp" />
            <solid android:color="#ECEEF2" />
        </shape>
    </item>
</layer-list>
