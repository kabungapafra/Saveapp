<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.Save" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
        <item name="android:windowBackground">@drawable/bg_geometric_pattern</item>
        <item name="android:colorBackground">@android:color/transparent</item>
    </style>

    <style name="Theme.Save" parent="Base.Theme.Save" />

    <style name="Theme.Save.LightOnly" parent="Theme.Material3.Light.NoActionBar">
        <item name="android:windowBackground">@color/white</item>
        <item name="android:statusBarColor">@color/white</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:colorBackground">@color/white</item>
    </style>

    <!-- Dashboard specific theme for smooth transitions -->
    <style name="Theme.Save.Dashboard" parent="Theme.Save">
        <item name="android:windowBackground">@drawable/bg_geometric_pattern</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowDisablePreview">false</item>
    </style>
</resources>
