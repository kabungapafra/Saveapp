<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/card_surface"
    android:orientation="horizontal"
    android:paddingHorizontal="16dp"
    android:paddingVertical="14dp"
    android:gravity="center_vertical">

    <!-- Member Name -->
    <TextView
        android:id="@+id/tvInsightName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1.4"
        android:fontFamily="@font/manrope_bold"
        android:text=""
        android:textColor="@color/v_text_dark"
        android:textSize="13sp" />

    <!-- Contributed -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1.2"
        android:gravity="center"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvInsightContributed"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/manrope_bold"
            android:text=""
            android:textColor="@color/brand_blue"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- Reliability -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1.0"
        android:gravity="center"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/imgTrend"
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:layout_marginEnd="3dp"
            android:src="@drawable/ic_diagonal_arrow"
            app:tint="#10B981" />

        <TextView
            android:id="@+id/tvReliabilityScore"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/manrope_bold"
            android:text=""
            android:textColor="#10B981"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- Join Date -->
    <TextView
        android:id="@+id/tvJoinDate"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1.0"
        android:fontFamily="@font/manrope_medium"
        android:gravity="end"
        android:text=""
        android:textColor="@color/v_text_mid"
        android:textSize="11sp" />

</LinearLayout>
