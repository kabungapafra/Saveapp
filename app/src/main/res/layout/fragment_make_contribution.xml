<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/v_page_bg">

    <!-- HEADER -->
    <RelativeLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/card_surface"
        android:elevation="4dp"
        android:paddingHorizontal="16dp"
        android:paddingVertical="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <FrameLayout
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:background="@drawable/bg_input_bg_circle">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_arrow_back"
                app:tint="@color/v_text_dark" />
        </FrameLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:fontFamily="@font/poppins"
            android:text="Make Contribution"
            android:textColor="@color/v_text_dark"
            android:textSize="@dimen/text_size_normal" />
    </RelativeLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/header">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="32dp">

            <!-- AMOUNT HERO (brand gradient) -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="24dp"
                app:cardElevation="6dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_card_premium_blue"
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:alpha="0.85"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.08"
                        android:text="CONTRIBUTION AMOUNT"
                        android:textColor="@color/permanent_white"
                        android:textSize="@dimen/text_size_xs" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="12dp"
                            android:fontFamily="@font/poppins"
                            android:text="UGX"
                            android:textColor="@color/permanent_white"
                            android:textSize="22sp" />

                        <EditText
                            android:id="@+id/etAmount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@null"
                            android:fontFamily="@font/poppins"
                            android:hint="0"
                            android:imeOptions="actionDone"
                            android:inputType="number"
                            android:maxLines="1"
                            android:minWidth="100dp"
                            android:textColor="@color/permanent_white"
                            android:textColorHint="#80FFFFFF"
                            android:textCursorDrawable="@null"
                            android:textSize="44sp" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="20dp"
                        android:background="@color/divider_color" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/btnQuickAmount1"
                            android:layout_width="0dp"
                            android:layout_height="44dp"
                            android:layout_marginEnd="8dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_badge_success"
                            android:backgroundTint="#26FFFFFF"
                            android:clickable="true"
                            android:focusable="true"
                            android:fontFamily="@font/manrope_bold"
                            android:gravity="center"
                            android:text="+10,000"
                            android:textColor="@color/permanent_white"
                            android:textSize="13sp" />

                        <TextView
                            android:id="@+id/btnQuickAmount2"
                            android:layout_width="0dp"
                            android:layout_height="44dp"
                            android:layout_marginHorizontal="4dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_badge_success"
                            android:backgroundTint="#26FFFFFF"
                            android:clickable="true"
                            android:focusable="true"
                            android:fontFamily="@font/manrope_bold"
                            android:gravity="center"
                            android:text="+50,000"
                            android:textColor="@color/permanent_white"
                            android:textSize="13sp" />

                        <TextView
                            android:id="@+id/btnQuickAmount3"
                            android:layout_width="0dp"
                            android:layout_height="44dp"
                            android:layout_marginStart="8dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_badge_success"
                            android:backgroundTint="#26FFFFFF"
                            android:clickable="true"
                            android:focusable="true"
                            android:fontFamily="@font/manrope_bold"
                            android:gravity="center"
                            android:text="+100,000"
                            android:textColor="@color/permanent_white"
                            android:textSize="13sp" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- PAYMENT METHOD -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:fontFamily="@font/manrope_bold"
                android:text="Payment Method"
                android:textColor="@color/v_text_dark"
                android:textSize="16sp" />

            <!-- Airtel -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/btnAirtel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_payment_method_card"
                android:clickable="true"
                android:focusable="true"
                android:padding="14dp">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/airtelIconCard"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    app:cardBackgroundColor="#ED1B24"
                    app:cardCornerRadius="12dp"
                    app:strokeWidth="0dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="8dp"
                        android:scaleType="centerInside"
                        android:src="@drawable/ic_airtel_brand" />
                </com.google.android.material.card.MaterialCardView>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:orientation="vertical"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/airtelCheck"
                    app:layout_constraintStart_toEndOf="@id/airtelIconCard"
                    app:layout_constraintTop_toTopOf="parent">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/manrope_bold"
                        android:text="Airtel Mobile Money"
                        android:textColor="@color/v_text_dark"
                        android:textSize="16sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/manrope_medium"
                        android:text="Instant Processing"
                        android:textColor="@color/v_text_muted"
                        android:textSize="13sp" />
                </LinearLayout>

                <ImageView
                    android:id="@+id/airtelCheck"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_check_circle_blue"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <View
                    android:id="@+id/airtelEmptyCircle"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:background="@drawable/bg_circular_back_button"
                    android:backgroundTint="@color/v_page_bg"
                    android:visibility="gone"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- MTN -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/btnMTN"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_payment_method_card"
                android:clickable="true"
                android:focusable="true"
                android:padding="14dp">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/mtnIconCard"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    app:cardBackgroundColor="#FFCC00"
                    app:cardCornerRadius="12dp"
                    app:strokeWidth="0dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="8dp"
                        android:scaleType="centerInside"
                        android:src="@drawable/ic_mtn_brand" />
                </com.google.android.material.card.MaterialCardView>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:orientation="vertical"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/mtnCheck"
                    app:layout_constraintStart_toEndOf="@id/mtnIconCard"
                    app:layout_constraintTop_toTopOf="parent">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/manrope_bold"
                        android:text="MTN Mobile Money"
                        android:textColor="@color/v_text_dark"
                        android:textSize="16sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/manrope_medium"
                        android:text="Instant Processing"
                        android:textColor="@color/v_text_muted"
                        android:textSize="13sp" />
                </LinearLayout>

                <ImageView
                    android:id="@+id/mtnCheck"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_check_circle_blue"
                    android:visibility="gone"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <View
                    android:id="@+id/mtnEmptyCircle"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:background="@drawable/bg_circular_back_button"
                    android:backgroundTint="@color/v_page_bg"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- CONFIRM -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnConfirm"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:layout_marginTop="24dp"
                android:fontFamily="@font/manrope_bold"
                android:stateListAnimator="@null"
                android:text="Confirm Contribution"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="17sp"
                app:backgroundTint="@color/brand_blue"
                app:cornerRadius="16dp"
                app:icon="@drawable/ic_arrow_right"
                app:iconGravity="textEnd"
                app:iconPadding="12dp"
                app:iconTint="#FFFFFF" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="12dp"
                android:gravity="center"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:layout_marginEnd="6dp"
                    android:src="@drawable/ic_lock"
                    app:tint="@color/v_text_muted" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/manrope_bold"
                    android:letterSpacing="0.05"
                    android:text="SECURED WITH 256-BIT ENCRYPTION"
                    android:textColor="@color/v_text_muted"
                    android:textSize="10sp" />
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
