<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/h_slate_50">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/mainScrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="40dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- 1. TOP BAR -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="20dp"
                android:paddingTop="24dp"
                android:paddingBottom="4dp">
                

                <!-- Branding text removed as per user request -->

                <!-- Theme toggle button — to the left of the bell -->
                <FrameLayout
                    android:id="@+id/btnThemeToggle"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_toStartOf="@id/btnNotifications"
                    android:layout_marginEnd="4dp"
                    android:layout_centerVertical="true"
                    android:background="?attr/selectableItemBackgroundBorderless">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_theme_toggle"
                        app:tint="@color/brand_blue" />
                </FrameLayout>

                <FrameLayout
                    android:id="@+id/btnNotifications"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:background="?attr/selectableItemBackgroundBorderless">
                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_notifications"
                        app:tint="@color/brand_blue" />
                    <View
                        android:id="@+id/notificationIndicator"
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:layout_gravity="top|end"
                        android:layout_marginTop="7dp"
                        android:layout_marginEnd="7dp"
                        android:background="@drawable/shape_circle_blue"
                        android:backgroundTint="@color/h_red_500" />
                </FrameLayout>
            </RelativeLayout>


            <!-- 2. GREETING BLOCK -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="20dp"
                android:paddingTop="4dp">
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/manrope_bold"
                    android:letterSpacing="0.1"
                    android:text="DASHBOARD"
                    android:textColor="@color/h_slate_400"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/tvGreetingName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:fontFamily="@font/manrope_bold"
                    android:text="Welcome back, Pafra"
                    android:textColor="@color/h_slate_900"
                    android:textSize="22sp" />

                <TextView
                    android:id="@+id/tvMemberStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/manrope_medium"
                    android:text="Member since Jan 2024 · ID #00312"
                    android:textColor="@color/h_slate_400"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- 3. ALERT BANNER -->
            <com.google.android.material.card.MaterialCardView android:id="@+id/alertBanner" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginHorizontal="20dp" android:layout_marginTop="16dp" app:cardCornerRadius="14dp" app:cardElevation="0dp" >
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_alert_amber"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="12dp">
                    
                    <com.google.android.material.card.MaterialCardView android:layout_width="32dp" android:layout_height="32dp" app:cardBackgroundColor="#FDE68A" app:cardCornerRadius="10dp" app:cardElevation="0dp">
                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_clock_orange"
                            app:tint="@color/h_amber_text" />
                    </com.google.android.material.card.MaterialCardView>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/manrope_bold"
                            android:text="Contribution due in 3 days"
                            android:textColor="@color/h_amber_text"
                            android:textSize="12sp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/manrope_medium"
                            android:text="UGX 200,000 · Holiday Fund 2024"
                            android:textColor="@color/h_amber_subtext"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/manrope_bold"
                        android:text="Pay Now"
                        android:textColor="@color/h_blue_600"
                        android:textSize="11sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 4. BALANCE CARD -->
            <com.google.android.material.card.MaterialCardView android:id="@+id/balanceCard" android:layout_width="match_parent" android:layout_height="140dp" android:layout_marginHorizontal="20dp" android:layout_marginTop="16dp" app:cardCornerRadius="20dp" app:cardElevation="8dp" >
                
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_balance_card_premium"
                    android:padding="22dp">

                    <TextView
                        android:id="@+id/tvBalanceLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/manrope_medium"
                        android:text="Total Balance"
                        android:textColor="#B3FFFFFF"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/tvBalanceAmount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/tvBalanceLabel"
                        android:layout_marginTop="6dp"
                        android:fontFamily="@font/manrope_bold"
                        android:text="$12,450.00"
                        android:textColor="#FFFFFF"
                        android:textSize="30sp" />

                    <com.google.android.material.card.MaterialCardView android:layout_width="36dp" android:layout_height="36dp" android:layout_alignParentEnd="true" android:layout_alignTop="@id/tvBalanceAmount" app:cardBackgroundColor="#2EFFFFFF" app:cardCornerRadius="11dp" app:cardElevation="0dp">
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_wallet_mockup"
                            app:tint="#FFFFFF" />
                    </com.google.android.material.card.MaterialCardView>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_alignParentBottom="true"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">
                        
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_capsule_translucent"
                            android:backgroundTint="#3810B981"
                            android:drawablePadding="4dp"
                            android:paddingHorizontal="8dp"
                            android:paddingVertical="4dp"
                            android:text="📈 +12% this month"
                            android:textColor="#6EE7B7"
                            android:textSize="10sp"
                            android:fontFamily="@font/manrope_bold"
                            app:drawableStartCompat="@drawable/ic_stats"
                            app:drawableTint="#6EE7B7" />

                        <View
                            android:layout_width="0dp"
                            android:layout_height="1dp"
                            android:layout_weight="1" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/manrope_medium"
                            android:text="UPDATED 2M AGO"
                            android:textColor="#73FFFFFF"
                            android:textSize="10sp" />
                    </LinearLayout>
                </RelativeLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 5. METRIC GRID -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:orientation="horizontal"
                android:paddingHorizontal="20dp">

                <!-- Goal Card -->
                <com.google.android.material.card.MaterialCardView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginEnd="5dp" android:layout_weight="1" app:cardBackgroundColor="@color/card_surface" app:cardCornerRadius="18dp" app:cardElevation="0dp" app:strokeWidth="1dp" app:strokeColor="@color/divider_color">
                    
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_horizontal"
                        android:orientation="vertical"
                        android:padding="16dp">
                        
                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/manrope_bold"
                                android:text="GOAL"
                                android:textColor="@color/h_slate_400"
                                android:textSize="10sp" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentEnd="true"
                                android:fontFamily="@font/manrope_bold"
                                android:text="70%"
                                android:textColor="@color/h_blue_600"
                                android:textSize="10sp" />
                        </RelativeLayout>

                        <FrameLayout
                            android:layout_width="72dp"
                            android:layout_height="72dp"
                            android:layout_marginTop="12dp">
                            <com.google.android.material.progressindicator.CircularProgressIndicator
                                android:id="@+id/goalProgress"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:progress="70"
                                app:indicatorSize="72dp"
                                app:trackThickness="8dp"
                                app:indicatorColor="@color/h_blue_600"
                                app:trackColor="@color/h_slate_100"
                                app:trackCornerRadius="4dp" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:fontFamily="@font/manrope_bold"
                                android:text="70%"
                                android:textColor="@color/h_slate_900"
                                android:textSize="14sp" />
                        </FrameLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:fontFamily="@font/manrope_medium"
                            android:text="$2,100 of $3,000"
                            android:textColor="@color/h_slate_400"
                            android:textSize="11sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Payout Card -->
                <com.google.android.material.card.MaterialCardView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="5dp" android:layout_weight="1" app:cardBackgroundColor="@color/card_surface" app:cardCornerRadius="18dp" app:cardElevation="0dp" app:strokeWidth="1dp" app:strokeColor="@color/divider_color">
                    
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">
                        
                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/manrope_bold"
                                android:text="PAYOUT"
                                android:textColor="@color/h_slate_400"
                                android:textSize="10sp" />
                            <ImageView
                                android:layout_width="12dp"
                                android:layout_height="12dp"
                                android:layout_alignParentEnd="true"
                                android:src="@drawable/ic_calendar"
                                app:tint="@color/h_slate_400" />
                        </RelativeLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:fontFamily="@font/manrope_bold"
                            android:text="$850"
                            android:textColor="@color/h_red_500"
                            android:textSize="22sp" />
                        
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/manrope_medium"
                            android:text="Sept 14, 2024"
                            android:textColor="@color/h_slate_400"
                            android:textSize="11sp" />

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="14dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/manrope_bold"
                                android:text="PROGRESS"
                                android:textColor="@color/h_slate_400"
                                android:textSize="10sp" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentEnd="true"
                                android:fontFamily="@font/manrope_bold"
                                android:text="85%"
                                android:textColor="@color/h_red_500"
                                android:textSize="10sp" />
                        </RelativeLayout>

                        <com.google.android.material.progressindicator.LinearProgressIndicator
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:progress="85"
                            app:indicatorColor="@color/h_red_500"
                            app:trackColor="@color/h_slate_100"
                            app:trackThickness="5dp"
                            app:trackCornerRadius="10dp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- 6. MY POSITION -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="24dp"
                android:fontFamily="@font/manrope_bold"
                android:text="My position"
                android:textColor="@color/h_slate_900"
                android:textSize="17sp" />

            <com.google.android.material.card.MaterialCardView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginHorizontal="20dp" android:layout_marginTop="12dp" app:cardBackgroundColor="@color/card_surface" app:cardCornerRadius="18dp" app:cardElevation="0dp" app:strokeWidth="1dp" app:strokeColor="@color/divider_color">
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_capsule_translucent"
                            android:backgroundTint="@color/h_blue_50"
                            android:drawablePadding="4dp"
                            android:paddingHorizontal="10dp"
                            android:paddingVertical="6dp"
                            android:text="You are #3 of 8"
                            android:textColor="@color/h_blue_700"
                            android:textSize="12sp"
                            android:fontFamily="@font/manrope_bold"
                            app:drawableTint="@color/h_blue_700" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:background="@drawable/bg_capsule_translucent"
                            android:backgroundTint="@color/h_green_50"
                            android:paddingHorizontal="10dp"
                            android:paddingVertical="6dp"
                            android:text="Round 3 of 8"
                            android:textColor="@color/h_green_700"
                            android:textSize="12sp"
                            android:fontFamily="@font/manrope_bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:orientation="horizontal">
                        
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="4dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_capsule_translucent"
                            android:backgroundTint="@color/h_slate_50"
                            android:orientation="vertical"
                            android:padding="12dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/manrope_bold"
                                android:text="LAST RECIPIENT"
                                android:textColor="@color/h_slate_400"
                                android:textSize="10sp" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:fontFamily="@font/manrope_bold"
                                android:text="Amara M."
                                android:textColor="@color/h_slate_900"
                                android:textSize="13sp" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/manrope_medium"
                                android:text="Sept 1, 2024"
                                android:textColor="@color/h_slate_400"
                                android:textSize="11sp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_capsule_translucent"
                            android:backgroundTint="@color/h_blue_50"
                            android:orientation="vertical"
                            android:padding="12dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/manrope_bold"
                                android:text="NEXT RECIPIENT"
                                android:textColor="@color/brand_blue"
                                android:textSize="10sp" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:fontFamily="@font/manrope_bold"
                                android:text="Pafra (You)"
                                android:textColor="@color/h_blue_700"
                                android:textSize="13sp" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/manrope_medium"
                                android:text="Oct 1, 2024"
                                android:textColor="@color/brand_blue"
                                android:textSize="11sp" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 7. ACTIVE CIRCLE -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="24dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/manrope_bold"
                    android:text="Active circle"
                    android:textColor="@color/h_slate_900"
                    android:textSize="17sp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:fontFamily="@font/manrope_bold"
                    android:text="View All"
                    android:textColor="@color/h_blue_600"
                    android:textSize="13sp" />
            </RelativeLayout>

            <com.google.android.material.card.MaterialCardView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginHorizontal="20dp" android:layout_marginTop="12dp" app:cardBackgroundColor="@color/card_surface" app:cardCornerRadius="18dp" app:cardElevation="0dp" app:strokeWidth="1dp" app:strokeColor="@color/divider_color">
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">
                    
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <com.google.android.material.card.MaterialCardView android:id="@+id/ivCircleIcon" android:layout_width="42dp" android:layout_height="42dp" app:cardBackgroundColor="@color/h_blue_50" app:cardCornerRadius="13dp" app:cardElevation="0dp" app:strokeWidth="1dp" app:strokeColor="@color/divider_color">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:text="🏖️"
                                android:textSize="20sp" />
                        </com.google.android.material.card.MaterialCardView>
                        
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_toEndOf="@id/ivCircleIcon"
                            android:layout_toStartOf="@+id/tvActiveBadge"
                            android:orientation="vertical">
                            <TextView
                                android:id="@+id/tvCircleName"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/manrope_bold"
                                android:text="Holiday Fund 2024"
                                android:textColor="@color/h_slate_900"
                                android:textSize="15sp" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/manrope_medium"
                                android:text="8 members · Monthly · 8 rounds"
                                android:textColor="@color/h_slate_400"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvActiveBadge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:background="@drawable/bg_capsule_translucent"
                            android:backgroundTint="@color/h_green_100"
                            android:fontFamily="@font/manrope_bold"
                            android:paddingHorizontal="10dp"
                            android:paddingVertical="4dp"
                            android:text="ACTIVE"
                            android:textColor="@color/h_green_700"
                            android:textSize="11sp" />
                    </RelativeLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:layout_marginVertical="14dp"
                        android:background="@color/h_slate_100" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/manrope_bold"
                                android:text="POOLED FUNDS"
                                android:textColor="@color/h_slate_400"
                                android:textSize="10sp" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/manrope_bold"
                                android:text="$4,800.00"
                                android:textColor="@color/h_blue_600"
                                android:textSize="18sp" />
                        </LinearLayout>
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/manrope_bold"
                                android:text="REMAINING"
                                android:textColor="@color/h_slate_400"
                                android:textSize="10sp" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/manrope_bold"
                                android:text="12 Days"
                                android:textColor="@color/h_slate_900"
                                android:textSize="18sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:background="@drawable/bg_capsule_translucent"
                        android:backgroundTint="@color/h_slate_50"
                        android:orientation="vertical"
                        android:padding="12dp">
                        
                        <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Contribution per member" android:textColor="@color/h_slate_600" android:textSize="12sp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:text="UGX 200,000" android:textColor="@color/h_slate_900" android:textSize="12sp" android:fontFamily="@font/manrope_bold"/>
                        </RelativeLayout>
                        <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="6dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Total payout per round" android:textColor="@color/h_slate_600" android:textSize="12sp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:text="UGX 1,600,000" android:textColor="@color/h_slate_900" android:textSize="12sp" android:fontFamily="@font/manrope_bold"/>
                        </RelativeLayout>
                        <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="6dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Late penalty" android:textColor="@color/h_slate_600" android:textSize="12sp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:text="UGX 10,000 / day" android:textColor="@color/h_slate_900" android:textSize="12sp" android:fontFamily="@font/manrope_bold"/>
                        </RelativeLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/bg_capsule_translucent"
                        android:backgroundTint="@color/h_blue_50"
                        android:orientation="horizontal"
                        android:padding="12dp">
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="YOUR PAYOUT" android:textColor="@color/brand_blue" android:textSize="11sp" android:fontFamily="@font/manrope_bold"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Pafra Francis" android:textColor="@color/h_blue_700" android:textSize="13sp" android:fontFamily="@font/manrope_bold"/>
                        </LinearLayout>
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="end"
                            android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Oct 1, 2024" android:textColor="@color/brand_blue" android:textSize="11sp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="UGX 1,600,000" android:textColor="@color/h_blue_700" android:textSize="14sp" android:fontFamily="@font/manrope_bold"/>
                        </LinearLayout>
                    </LinearLayout>

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp">

                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/rvMonthRecipients"
                            android:layout_width="wrap_content"
                            android:layout_height="32dp"
                            tools:layout_width="100dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:background="@drawable/bg_capsule_translucent"
                            android:backgroundTint="@color/h_blue_50"
                            android:fontFamily="@font/manrope_bold"
                            android:paddingHorizontal="10dp"
                            android:paddingVertical="6dp"
                            android:text="Your turn next"
                            android:textColor="@color/h_blue_600"
                            android:textSize="12sp" />
                    </RelativeLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 8. MEMBER STATUS -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="24dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/manrope_bold"
                    android:text="Member status"
                    android:textColor="@color/h_slate_900"
                    android:textSize="17sp" />
                <TextView
                    android:id="@+id/btnViewAllMembers"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:fontFamily="@font/manrope_bold"
                    android:text="Details"
                    android:textColor="@color/h_blue_600"
                    android:textSize="13sp" />
            </RelativeLayout>

            <com.google.android.material.card.MaterialCardView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginHorizontal="20dp" android:layout_marginTop="12dp" app:cardBackgroundColor="@color/card_surface" app:cardCornerRadius="18dp" app:cardElevation="0dp" app:strokeWidth="1dp" app:strokeColor="@color/divider_color">
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvDashboardMembers"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                    tools:itemCount="3"
                    tools:listitem="@layout/item_member_status_v2" />
            </com.google.android.material.card.MaterialCardView>

            <!-- 9. MY CONTRIBUTIONS -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="24dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/manrope_bold"
                    android:text="My contributions"
                    android:textColor="@color/h_slate_900"
                    android:textSize="17sp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:fontFamily="@font/manrope_bold"
                    android:text="History"
                    android:textColor="@color/h_blue_600"
                    android:textSize="13sp" />
            </RelativeLayout>

            <com.google.android.material.card.MaterialCardView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginHorizontal="20dp" android:layout_marginTop="12dp" app:cardBackgroundColor="@color/card_surface" app:cardCornerRadius="18dp" app:cardElevation="0dp" app:strokeWidth="1dp" app:strokeColor="@color/divider_color">
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvDashboardTransactions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                    tools:itemCount="2"
                    tools:listitem="@layout/item_transaction" />
            </com.google.android.material.card.MaterialCardView>

            <!-- 10 & 11. BUTTON ACTIONS -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="30dp"
                android:orientation="vertical">
                
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnPayNowBottom"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:text="Pay Now · UGX 200,000"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:fontFamily="@font/manrope_bold"
                    app:backgroundTint="@color/h_blue_600"
                    app:cornerRadius="16dp"
                    app:icon="@drawable/ic_wallet_mockup"
                    app:iconGravity="textStart"
                    app:iconSize="20dp"
                    app:iconPadding="10dp" />

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
