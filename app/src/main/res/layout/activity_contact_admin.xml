<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/v_page_bg"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/brand_blue"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingTop="48dp"
                android:paddingBottom="20dp"
                android:paddingHorizontal="20dp">

                <ImageButton
                    android:id="@+id/backButton"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/bg_avatar_circle"
                    android:backgroundTint="#2EFFFFFF"
                    android:padding="8dp"
                    android:src="@drawable/ic_arrow_back"
                    app:tint="#FFFFFF" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:fontFamily="@font/manrope_bold"
                    android:text="Contact Admin"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp" />

            </LinearLayout>

            <!-- Admin info card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="20dp"
                app:cardBackgroundColor="@color/card_surface"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <ImageView
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:layout_marginBottom="12dp"
                        android:background="@drawable/bg_avatar_circle"
                        android:backgroundTint="#EBF0FF"
                        android:padding="16dp"
                        android:src="@drawable/ic_person"
                        app:tint="@color/brand_blue" />

                    <TextView
                        android:id="@+id/tvAdminName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/manrope_bold"
                        android:text="Group Administrator"
                        android:textColor="@color/v_text_dark"
                        android:textSize="16sp" />

                    <TextView
                        android:id="@+id/tvGroupName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:fontFamily="@font/manrope_medium"
                        android:text="Your Group"
                        android:textColor="@color/v_text_muted"
                        android:textSize="13sp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnCallAdmin"
                        android:layout_width="wrap_content"
                        android:layout_height="44dp"
                        android:layout_marginTop="16dp"
                        android:fontFamily="@font/manrope_bold"
                        android:paddingHorizontal="24dp"
                        android:text="Call Admin"
                        android:textSize="13sp"
                        app:backgroundTint="@color/brand_blue"
                        app:cornerRadius="22dp"
                        app:icon="@drawable/ic_phone"
                        app:iconGravity="start"
                        app:iconPadding="6dp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Message form card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="24dp"
                app:cardBackgroundColor="@color/card_surface"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:fontFamily="@font/manrope_bold"
                        android:text="Send a Message"
                        android:textColor="@color/v_text_dark"
                        android:textSize="15sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:fontFamily="@font/manrope_bold"
                        android:text="Subject"
                        android:textColor="@color/v_text_dark"
                        android:textSize="13sp" />

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etSubject"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginBottom="16dp"
                        android:background="@drawable/bg_wizard_input_solid"
                        android:fontFamily="@font/manrope_medium"
                        android:hint="e.g. Contribution query"
                        android:inputType="text"
                        android:paddingHorizontal="16dp"
                        android:textColor="@color/v_text_dark"
                        android:textColorHint="@color/v_text_muted"
                        android:textSize="14sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:fontFamily="@font/manrope_bold"
                        android:text="Message"
                        android:textColor="@color/v_text_dark"
                        android:textSize="13sp" />

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etMessage"
                        android:layout_width="match_parent"
                        android:layout_height="130dp"
                        android:layout_marginBottom="20dp"
                        android:background="@drawable/bg_wizard_input_solid"
                        android:fontFamily="@font/manrope_medium"
                        android:gravity="top|start"
                        android:hint="Type your message here..."
                        android:inputType="textMultiLine"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="12dp"
                        android:textColor="@color/v_text_dark"
                        android:textColorHint="@color/v_text_muted"
                        android:textSize="14sp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSendMessage"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:fontFamily="@font/manrope_bold"
                        android:text="Send via SMS"
                        android:textSize="15sp"
                        app:backgroundTint="@color/brand_blue"
                        app:cornerRadius="14dp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</layout>
