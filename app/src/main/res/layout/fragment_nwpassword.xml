<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/slate_50">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Main Card Container -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/loginCard"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginVertical="32dp"
            android:minHeight="600dp"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="24dp"
            app:cardElevation="6dp"
            app:layout_constraintBottom_toTopOf="@+id/footerLinks"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="32dp"
                android:paddingVertical="48dp"
                android:gravity="center_horizontal">

                <!-- Logo -->
                <ImageView
                    android:id="@+id/logoImage"
                    android:layout_width="100dp"
                    android:layout_height="50dp"
                    android:contentDescription="@string/logo"
                    android:src="@drawable/save_logo" />

                <!-- Heading Container -->
                <LinearLayout
                    android:id="@+id/headingContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="32dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:id="@+id/backButton"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_marginEnd="12dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="@string/back"
                        android:src="@drawable/ic_arrow_back"
                        app:tint="@color/text_slate_500" />

                    <TextView
                        android:id="@+id/emailTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-black"
                        android:text="@string/forgot_password_heading"
                        android:textColor="@color/text_slate_900"
                        android:textSize="26sp" />
                </LinearLayout>

                <!-- Subtitle -->
                <TextView
                    android:id="@+id/otpSubtitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:gravity="center"
                    android:lineSpacingExtra="4dp"
                    android:text="@string/forgot_password_subtitle"
                    android:textColor="@color/text_slate_500"
                    android:textSize="15sp" />

                <!-- Email Input Step Container -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/emailStepContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="32dp">

                    <TextView
                        android:id="@+id/emailLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:text="@string/email_address_label"
                        android:textColor="@color/text_slate_900"
                        android:textSize="14sp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/emailInputLayout"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        app:boxBackgroundColor="@color/slate_50"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxStrokeColor="@color/slate_200"
                        app:hintEnabled="false"
                        app:startIconDrawable="@drawable/ic_email"
                        app:startIconTint="@color/text_slate_400"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/emailLabel">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/emailInput"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="name@company.com"
                            android:inputType="textEmailAddress"
                            android:textColor="@color/text_slate_900"
                            android:textColorHint="@color/text_slate_400"
                            android:textSize="14sp" />
                    </com.google.android.material.textfield.TextInputLayout>

                </androidx.constraintlayout.widget.ConstraintLayout>

                <!-- OTP Input Step Container (Hidden by default) -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/otpStepContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="32dp"
                    android:visibility="gone">

                    <LinearLayout
                        android:id="@+id/otpInputContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="horizontal"
                        app:layout_constraintTop_toTopOf="parent">

                        <EditText android:id="@+id/otpDigit1" style="@style/OtpEditTextStyle" />
                        <EditText android:id="@+id/otpDigit2" style="@style/OtpEditTextStyle" />
                        <EditText android:id="@+id/otpDigit3" style="@style/OtpEditTextStyle" />
                        <EditText android:id="@+id/otpDigit4" style="@style/OtpEditTextStyle" />
                        <EditText android:id="@+id/otpDigit5" style="@style/OtpEditTextStyle" />
                        <EditText android:id="@+id/otpDigit6" style="@style/OtpEditTextStyle" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/resendContainer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="24dp"
                        android:gravity="center"
                        android:orientation="horizontal"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/otpInputContainer">

                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/didnt_receive_code_question" android:textColor="@color/text_slate_500" android:textSize="14sp" />
                        <TextView android:id="@+id/resendOtp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/resend_code_link" android:textColor="@color/brand_blue" android:textSize="14sp" android:fontFamily="sans-serif-medium" />
                        <TextView android:id="@+id/timerText" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="4dp" android:text="(0:30)" android:textColor="@color/text_slate_400" android:textSize="14sp" android:visibility="gone" />
                    </LinearLayout>

                </androidx.constraintlayout.widget.ConstraintLayout>

                <!-- Shared Error Message -->
                <TextView
                    android:id="@+id/errorMessage"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:gravity="center"
                    android:textColor="@color/status_overdue"
                    android:textSize="14sp"
                    android:visibility="gone" />

                <!-- Action Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/verifyButton"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="32dp"
                    android:text="@string/send_reset_link"
                    android:textAllCaps="false"
                    android:textSize="16sp"
                    android:fontFamily="sans-serif-medium"
                    app:backgroundTint="@color/brand_blue"
                    app:cornerRadius="12dp" />

                <!-- Footer Text in Card -->
                <LinearLayout
                    android:id="@+id/signinContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/remember_password_question"
                        android:textColor="@color/text_slate_500"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/signInLink"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/sign_in_link"
                        android:textColor="@color/brand_blue"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-medium" />
                </LinearLayout>

                <!-- Loading Indicator -->
                <ProgressBar
                    android:id="@+id/loadingIndicator"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:indeterminateTint="@color/brand_blue"
                    android:visibility="gone" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Secure Verification Footer (Wording matched from mockup) -->
        <LinearLayout
            android:id="@+id/secureFooter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="24dp"
            android:gravity="center"
            android:orientation="horizontal"
            app:layout_constraintBottom_toTopOf="@id/footerLinks"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/loginCard">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginEnd="8dp"
                android:src="@drawable/ic_lock"
                app:tint="@color/text_slate_400" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/secure_verification"
                android:textColor="@color/text_slate_400"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- Bottom Footer Links -->
        <LinearLayout
            android:id="@+id/footerLinks"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="32dp"
            android:gravity="center"
            android:orientation="horizontal"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/privacy_policy"
                android:textColor="@color/text_slate_400"
                android:textSize="12sp" />

            <View
                android:layout_width="4dp"
                android:layout_height="4dp"
                android:layout_marginHorizontal="12dp"
                android:background="@color/slate_200" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/terms_of_service"
                android:textColor="@color/text_slate_400"
                android:textSize="12sp" />

            <View
                android:layout_width="4dp"
                android:layout_height="4dp"
                android:layout_marginHorizontal="12dp"
                android:background="@color/slate_200" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/contact_support"
                android:textColor="@color/text_slate_400"
                android:textSize="12sp" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</ScrollView>