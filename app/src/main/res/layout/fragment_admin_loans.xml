<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dashboard_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- White Top Bar -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@color/card_surface">

            <ImageView
                android:id="@+id/backButton"
                android:layout_width="48dp"
                android:layout_height="match_parent"
                android:padding="16dp"
                android:src="@drawable/ic_arrow_back"
                app:tint="@color/dashboard_text_primary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:fontFamily="@font/manrope"
                android:text="Loan Management"
                android:textColor="@color/dashboard_text_primary"
                android:textSize="@dimen/text_size_normal"
                android:textStyle="bold" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_alignParentBottom="true"
                android:background="@color/divider_color" />
        </RelativeLayout>

        <androidx.core.widget.NestedScrollView
            android:id="@+id/main_scroll_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingBottom="100dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Stats Grid -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="vertical"
                    android:paddingHorizontal="20dp">

                    <!-- Total Active Loans + Rules merged card -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:cardBackgroundColor="@color/action_card_bg"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="20dp">

                            <!-- Header row: label + icon -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="vertical">

                                    <TextView
                                        android:id="@+id/tvActiveLoansLabel"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="TOTAL ACTIVE LOANS"
                                        android:textColor="@color/action_card_subtext"
                                        android:textSize="11sp"
                                        android:letterSpacing="0.06"
                                        android:textStyle="bold" />

                                    <TextView
                                        android:id="@+id/tvTotalActiveLoans"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="6dp"
                                        android:fontFamily="@font/manrope"
                                        android:text="UGX 0"
                                        android:textColor="@color/action_card_text"
                                        android:textSize="@dimen/text_size_xxxl"
                                        android:textStyle="bold" />
                                </LinearLayout>

                                <com.google.android.material.card.MaterialCardView
                                    android:layout_width="48dp"
                                    android:layout_height="48dp"
                                    app:cardBackgroundColor="#33000000"
                                    app:cardCornerRadius="12dp"
                                    app:cardElevation="0dp"
                                    app:strokeWidth="0dp">

                                    <ImageView
                                        android:layout_width="match_parent"
                                        android:layout_height="match_parent"
                                        android:padding="12dp"
                                        android:src="@drawable/ic_bank_filled"
                                        app:tint="#FFFFFF" />
                                </com.google.android.material.card.MaterialCardView>
                            </LinearLayout>

                            <!-- Divider -->
                            <View
                                android:layout_width="match_parent"
                                android:layout_height="1dp"
                                android:layout_marginTop="16dp"
                                android:layout_marginBottom="14dp"
                                android:background="#33FFFFFF" />

                            <!-- Rules row: Max Limit | Interest | Duration -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal">

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="vertical">

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Max Limit"
                                        android:textColor="@color/action_card_subtext"
                                        android:textSize="10sp" />

                                    <TextView
                                        android:id="@+id/tvMaxLoanLimit"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="3dp"
                                        android:text="—"
                                        android:textColor="@color/action_card_text"
                                        android:textSize="13sp"
                                        android:textStyle="bold" />
                                </LinearLayout>

                                <!-- Vertical divider -->
                                <View
                                    android:layout_width="1dp"
                                    android:layout_height="match_parent"
                                    android:background="#33FFFFFF"
                                    android:layout_marginHorizontal="12dp" />

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="vertical">

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Interest Rate"
                                        android:textColor="@color/action_card_subtext"
                                        android:textSize="10sp" />

                                    <TextView
                                        android:id="@+id/tvLoanInterest"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="3dp"
                                        android:text="—"
                                        android:textColor="@color/action_card_text"
                                        android:textSize="13sp"
                                        android:textStyle="bold" />
                                </LinearLayout>

                                <!-- Vertical divider -->
                                <View
                                    android:layout_width="1dp"
                                    android:layout_height="match_parent"
                                    android:background="#33FFFFFF"
                                    android:layout_marginHorizontal="12dp" />

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="vertical">

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Duration"
                                        android:textColor="@color/action_card_subtext"
                                        android:textSize="10sp" />

                                    <TextView
                                        android:id="@+id/tvLoanDuration"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="3dp"
                                        android:text="—"
                                        android:textColor="@color/action_card_text"
                                        android:textSize="13sp"
                                        android:textStyle="bold" />
                                </LinearLayout>
                            </LinearLayout>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Secondary Stats -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="horizontal">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="6dp"
                            android:layout_weight="1"
                            app:cardBackgroundColor="@color/card_surface"
                            app:cardCornerRadius="14dp"
                            app:cardElevation="1dp"
                            app:strokeWidth="0dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:padding="18dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="ACTIVE LOANS"
                                    android:textColor="@color/dashboard_text_secondary"
                                    android:textSize="@dimen/text_size_xs"
                                    android:textStyle="bold" />

                                <TextView
                                    android:id="@+id/tvPendingCount"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="6dp"
                                    android:text="0"
                                    android:textColor="@color/dashboard_text_primary"
                                    android:textSize="@dimen/text_size_large"
                                    android:textStyle="bold" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="6dp"
                            android:layout_weight="1"
                            app:cardBackgroundColor="@color/card_surface"
                            app:cardCornerRadius="14dp"
                            app:cardElevation="1dp"
                            app:strokeWidth="0dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:padding="18dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="LOANS OVERDUE"
                                    android:textColor="@color/dashboard_text_secondary"
                                    android:textSize="@dimen/text_size_xs"
                                    android:textStyle="bold" />

                                <TextView
                                    android:id="@+id/tvDisbursedAmount"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="6dp"
                                    android:text="UGX 0"
                                    android:textColor="@color/dashboard_text_primary"
                                    android:textSize="@dimen/text_size_large"
                                    android:textStyle="bold" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>
                    </LinearLayout>
                </LinearLayout>

                <!-- Active Loan Status Tracker Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardActiveLoanTracker"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="20dp"
                    android:layout_marginTop="12dp"
                    app:cardBackgroundColor="@color/card_surface"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <!-- Header: "Active Loan" + status pill -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Active Loan"
                                android:textColor="@color/dashboard_text_primary"
                                android:textSize="@dimen/text_size_small"
                                android:textStyle="bold" />

                            <com.google.android.material.card.MaterialCardView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                app:cardBackgroundColor="@color/card_surface"
                                app:cardCornerRadius="20dp"
                                app:cardElevation="0dp"
                                app:strokeColor="@color/divider_color"
                                app:strokeWidth="1dp">

                                <TextView
                                    android:id="@+id/tvTrackerStatusPill"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:paddingHorizontal="12dp"
                                    android:paddingVertical="4dp"
                                    android:text="Pending"
                                    android:textColor="@color/dashboard_text_secondary"
                                    android:textSize="11sp"
                                    android:textStyle="bold" />
                            </com.google.android.material.card.MaterialCardView>
                        </LinearLayout>

                        <!-- Loan amount -->
                        <TextView
                            android:id="@+id/tvTrackerAmount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="UGX 0"
                            android:textColor="@color/dashboard_text_primary"
                            android:textSize="@dimen/text_size_xxl"
                            android:textStyle="bold" />

                        <!-- Outstanding + next repayment date -->
                        <TextView
                            android:id="@+id/tvTrackerSubtitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Outstanding"
                            android:textColor="@color/dashboard_text_secondary"
                            android:textSize="11sp" />

                        <!-- Repayment progress bar -->
                        <com.google.android.material.progressindicator.LinearProgressIndicator
                            android:id="@+id/pbTrackerRepaid"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="14dp"
                            android:progress="0"
                            app:indicatorColor="@color/dashboard_accent_green"
                            app:trackColor="@color/v_page_bg"
                            app:trackCornerRadius="4dp"
                            app:trackThickness="7dp" />

                        <TextView
                            android:id="@+id/tvTrackerRepaidPct"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="0% repaid"
                            android:textColor="@color/dashboard_text_secondary"
                            android:textSize="11sp" />

                        <!-- 4-step status stepper -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <!-- Step 1: Pending -->
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:orientation="vertical">

                                <ImageView
                                    android:id="@+id/ivStepPending"
                                    android:layout_width="28dp"
                                    android:layout_height="28dp"
                                    android:src="@drawable/ic_check_circle"
                                    app:tint="@color/dashboard_accent_green" />

                                <TextView
                                    android:id="@+id/tvLabelPending"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="5dp"
                                    android:text="Pending"
                                    android:textColor="@color/dashboard_accent_green"
                                    android:textSize="9sp"
                                    android:textStyle="bold" />
                            </LinearLayout>

                            <View
                                android:id="@+id/lineStep1"
                                android:layout_width="0dp"
                                android:layout_height="2dp"
                                android:layout_marginBottom="18dp"
                                android:layout_weight="1"
                                android:background="@color/dashboard_accent_green" />

                            <!-- Step 2: Approved -->
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:orientation="vertical">

                                <ImageView
                                    android:id="@+id/ivStepApproved"
                                    android:layout_width="28dp"
                                    android:layout_height="28dp"
                                    android:src="@drawable/bg_circle_outline_gray" />

                                <TextView
                                    android:id="@+id/tvStepApproved"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="5dp"
                                    android:text="Approved"
                                    android:textColor="@color/dashboard_text_secondary"
                                    android:textSize="9sp" />
                            </LinearLayout>

                            <View
                                android:id="@+id/lineStep2"
                                android:layout_width="0dp"
                                android:layout_height="2dp"
                                android:layout_marginBottom="18dp"
                                android:layout_weight="1"
                                android:background="@color/divider_color" />

                            <!-- Step 3: Disbursed -->
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:orientation="vertical">

                                <ImageView
                                    android:id="@+id/ivStepDisbursed"
                                    android:layout_width="28dp"
                                    android:layout_height="28dp"
                                    android:src="@drawable/bg_circle_outline_gray" />

                                <TextView
                                    android:id="@+id/tvStepDisbursed"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="5dp"
                                    android:text="Disbursed"
                                    android:textColor="@color/dashboard_text_secondary"
                                    android:textSize="9sp" />
                            </LinearLayout>

                            <View
                                android:id="@+id/lineStep3"
                                android:layout_width="0dp"
                                android:layout_height="2dp"
                                android:layout_marginBottom="18dp"
                                android:layout_weight="1"
                                android:background="@color/divider_color" />

                            <!-- Step 4: Repaid -->
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:orientation="vertical">

                                <ImageView
                                    android:id="@+id/ivStepRepaid"
                                    android:layout_width="28dp"
                                    android:layout_height="28dp"
                                    android:src="@drawable/bg_circle_outline_gray" />

                                <TextView
                                    android:id="@+id/tvStepRepaid"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="5dp"
                                    android:text="Repaid"
                                    android:textColor="@color/dashboard_text_secondary"
                                    android:textSize="9sp" />
                            </LinearLayout>

                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Needs Your Approval Section -->
                <LinearLayout
                    android:id="@+id/llPendingApprovals"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:orientation="vertical">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/manrope_bold"
                            android:text="Needs Your Approval"
                            android:textColor="@color/dashboard_text_primary"
                            android:textSize="18sp" />

                        <TextView
                            android:id="@+id/btnViewAllApprovals"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:fontFamily="@font/manrope_bold"
                            android:text="View All"
                            android:textColor="@color/brand_blue"
                            android:textSize="13sp" />
                    </RelativeLayout>

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvPendingApprovals"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:clipToPadding="false"
                        android:orientation="horizontal"
                        android:paddingHorizontal="20dp"
                        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                        tools:listitem="@layout/item_approval_loan" />

                    <TextView
                        android:id="@+id/tvNoApprovals"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:gravity="center"
                        android:text="No loans currently awaiting your approval"
                        android:textColor="@color/dashboard_text_secondary"
                        android:textSize="12sp"
                        android:visibility="gone" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginHorizontal="20dp"
                        android:layout_marginTop="20dp"
                        android:background="@color/divider_color" />
                </LinearLayout>

                <!-- Chart Card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="20dp"
                    android:layout_marginTop="16dp"
                    app:cardBackgroundColor="@color/card_surface"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Loan Growth vs\nRepayments"
                                android:textColor="@color/dashboard_text_primary"
                                android:textSize="@dimen/text_size_small"
                                android:textStyle="bold" />

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentEnd="true"
                                android:layout_centerVertical="true"
                                android:gravity="center_vertical">

                                <TextView
                                    android:id="@+id/tvChartPeriod"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Last Quarter"
                                    android:textColor="@color/dashboard_text_secondary"
                                    android:textSize="@dimen/text_size_xs" />

                                <ImageView
                                    android:layout_width="16dp"
                                    android:layout_height="16dp"
                                    android:layout_marginStart="4dp"
                                    android:rotation="90"
                                    android:src="@drawable/ic_chevron_right"
                                    app:tint="@color/dashboard_text_secondary" />
                            </LinearLayout>
                        </RelativeLayout>

                        <com.github.mikephil.charting.charts.BarChart
                            android:id="@+id/loanGrowthChart"
                            android:layout_width="match_parent"
                            android:layout_height="180dp"
                            android:layout_marginTop="20dp" />

                        <!-- Chart Legend (SQUARES as per mockup) -->
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_horizontal"
                            android:layout_marginTop="20dp"
                            android:orientation="horizontal">

                            <View
                                android:layout_width="10dp"
                                android:layout_height="10dp"
                                android:layout_gravity="center_vertical"
                                android:background="@color/brand_blue" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="6dp"
                                android:text="Loan Growth"
                                android:textColor="@color/dashboard_text_secondary"
                                android:textSize="@dimen/text_size_xs" />

                            <View
                                android:layout_width="10dp"
                                android:layout_height="10dp"
                                android:layout_gravity="center_vertical"
                                android:layout_marginStart="24dp"
                                android:background="#FF8A00" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="6dp"
                                android:text="Repayments"
                                android:textColor="@color/dashboard_text_secondary"
                                android:textSize="@dimen/text_size_xs" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>



                <!-- Search -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="20dp"
                    android:layout_marginTop="16dp"
                    app:cardBackgroundColor="@color/v_input_bg"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="12dp">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_search"
                            app:tint="@color/dashboard_text_secondary" />

                        <EditText
                            android:id="@+id/etSearchBorrower"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:background="@null"
                            android:hint="Search borrower name..."
                            android:textColor="@color/dashboard_text_primary"
                            android:textColorHint="@color/dashboard_text_secondary"
                            android:textSize="@dimen/text_size_xs" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Filters -->
                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:clipToPadding="false"
                    android:paddingHorizontal="20dp"
                    android:scrollbars="none">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnFilterAll"
                            style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="8dp"
                            android:text="All Loans"
                            android:textAllCaps="false"
                            android:textSize="@dimen/text_size_xs"
                            app:cornerRadius="20dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnFilterActive"
                            style="@style/Widget.MaterialComponents.Button.TextButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="8dp"
                            android:backgroundTint="@color/v_input_bg"
                            android:text="Active"
                            android:textAllCaps="false"
                            android:textColor="@color/dashboard_text_secondary"
                            android:textSize="@dimen/text_size_xs"
                            app:cornerRadius="20dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnFilterPending"
                            style="@style/Widget.MaterialComponents.Button.TextButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="8dp"
                            android:backgroundTint="@color/v_input_bg"
                            android:text="Pending"
                            android:textAllCaps="false"
                            android:textColor="@color/dashboard_text_secondary"
                            android:textSize="@dimen/text_size_xs"
                            app:cornerRadius="20dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnFilterLate"
                            style="@style/Widget.MaterialComponents.Button.TextButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:backgroundTint="@color/v_input_bg"
                            android:text="Late"
                            android:textAllCaps="false"
                            android:textColor="@color/dashboard_text_secondary"
                            android:textSize="@dimen/text_size_xs"
                            app:cornerRadius="20dp" />
                    </LinearLayout>
                </HorizontalScrollView>

                <TextView
                    android:id="@+id/tvEmptyState"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="40dp"
                    android:gravity="center"
                    android:text="No loan records found"
                    android:textColor="@color/dashboard_text_secondary"
                    android:textSize="@dimen/text_size_xs"
                    android:visibility="gone" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvLoans"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:paddingBottom="24dp"
                    tools:listitem="@layout/item_loan_borrower_card" />

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
