<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/v_page_bg">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingBottom="140dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingHorizontal="28dp"
            android:paddingTop="48dp">

            <!-- Logo -->
            <ImageView
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:src="@drawable/save_logo"
                android:scaleType="fitCenter" />

            <!-- Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:fontFamily="@font/manrope_bold"
                android:gravity="center"
                android:text="Transparency &amp; Trust"
                android:textColor="@color/v_text_dark"
                android:textSize="32sp" />

            <!-- Subtitle -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:fontFamily="@font/manrope_medium"
                android:gravity="center"
                android:text="We've built a system where every dollar is accounted for. Experience financial group saving with total peace of mind."
                android:textColor="@color/v_text_mid"
                android:textSize="15sp"
                android:lineSpacingExtra="4dp" />

            <!-- Timeline Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="28dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <!-- Step 1: Payout Cycle -->
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <View
                            android:id="@+id/line1"
                            android:layout_width="1dp"
                            android:layout_height="40dp"
                            android:layout_marginTop="8dp"
                            android:background="#E2E8F0"
                            app:layout_constraintTop_toBottomOf="@id/step1Icon"
                            app:layout_constraintStart_toStartOf="@id/step1Icon"
                            app:layout_constraintEnd_toEndOf="@id/step1Icon" />
                        <FrameLayout
                            android:id="@+id/step1Icon"
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:background="@drawable/bg_icon_squircle"
                            android:backgroundTint="#E9F2FB"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent">
                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_refresh"
                                app:tint="#215DA1" />
                        </FrameLayout>
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:orientation="vertical"
                            app:layout_constraintStart_toEndOf="@id/step1Icon"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="@id/step1Icon"
                            app:layout_constraintBottom_toBottomOf="@id/step1Icon">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/manrope_bold"
                                android:text="The Payout Cycle"
                                android:textColor="@color/v_text_dark"
                                android:textSize="16sp" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/manrope_medium"
                                android:text="Automated &amp; predictable"
                                android:textColor="@color/v_text_mid"
                                android:textSize="14sp" />
                        </LinearLayout>
                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <!-- Step 2: Pool Contributions -->
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="24dp">
                        <View
                            android:id="@+id/line2"
                            android:layout_width="1dp"
                            android:layout_height="40dp"
                            android:layout_marginTop="8dp"
                            android:background="#E2E8F0"
                            app:layout_constraintTop_toBottomOf="@id/step2Icon"
                            app:layout_constraintStart_toStartOf="@id/step2Icon"
                            app:layout_constraintEnd_toEndOf="@id/step2Icon" />
                        <TextView
                            android:id="@+id/step2Icon"
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:background="@drawable/bg_circle_outline_blue"
                            android:gravity="center"
                            android:text="1"
                            android:textColor="#215DA1"
                            android:fontFamily="@font/manrope_bold"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:orientation="vertical"
                            app:layout_constraintStart_toEndOf="@id/step2Icon"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="@id/step2Icon"
                            app:layout_constraintBottom_toBottomOf="@id/step2Icon">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/manrope_bold"
                                android:text="Pool Contributions"
                                android:textColor="@color/v_text_dark"
                                android:textSize="16sp" />
                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/manrope_medium"
                                android:text="Everyone contributes a fixed amount into the secure vault at the start of the month."
                                android:textColor="@color/v_text_mid"
                                android:textSize="13sp" />
                        </LinearLayout>
                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <!-- Step 3: Smart Validation -->
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="24dp">
                        <View
                            android:id="@+id/line3"
                            android:layout_width="1dp"
                            android:layout_height="40dp"
                            android:layout_marginTop="8dp"
                            android:background="#E2E8F0"
                            app:layout_constraintTop_toBottomOf="@id/step3Icon"
                            app:layout_constraintStart_toStartOf="@id/step3Icon"
                            app:layout_constraintEnd_toEndOf="@id/step3Icon" />
                        <FrameLayout
                            android:id="@+id/step3Icon"
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:background="@drawable/bg_circle_blue"
                            android:backgroundTint="#215DA1"
                            android:elevation="4dp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent">
                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_shield_auth"
                                app:tint="#FFFFFF" />
                        </FrameLayout>
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:orientation="vertical"
                            app:layout_constraintStart_toEndOf="@id/step3Icon"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="@id/step3Icon"
                            app:layout_constraintBottom_toBottomOf="@id/step3Icon">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/manrope_bold"
                                android:text="Smart Validation"
                                android:textColor="@color/v_text_dark"
                                android:textSize="16sp" />
                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/manrope_medium"
                                android:text="Our system verifies all funds in real-time. No hidden ledger, no manual errors."
                                android:textColor="@color/v_text_mid"
                                android:textSize="13sp" />
                        </LinearLayout>
                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <!-- Step 4: Rotating Payout -->
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="24dp">
                        <TextView
                            android:id="@+id/step4Icon"
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:background="@drawable/bg_circle_outline_blue"
                            android:gravity="center"
                            android:text="3"
                            android:textColor="#215DA1"
                            android:fontFamily="@font/manrope_bold"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:orientation="vertical"
                            app:layout_constraintStart_toEndOf="@id/step4Icon"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="@id/step4Icon"
                            app:layout_constraintBottom_toBottomOf="@id/step4Icon">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/manrope_bold"
                                android:text="Rotating Payout"
                                android:textColor="@color/v_text_dark"
                                android:textSize="16sp" />
                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/manrope_medium"
                                android:text="The total pool is automatically paid out to the scheduled member of the month."
                                android:textColor="@color/v_text_mid"
                                android:textSize="13sp" />
                        </LinearLayout>
                    </androidx.constraintlayout.widget.ConstraintLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Bottom Tracking Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                app:cardBackgroundColor="#FFF1F2"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="20dp">

                    <FrameLayout
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:background="@drawable/bg_icon_squircle"
                        android:backgroundTint="#FECDD3">
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_shield"
                            app:tint="#E11D48" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/manrope_bold"
                            android:text="REAL-TIME TRACKING"
                            android:textColor="#E11D48"
                            android:textSize="10sp"
                            android:letterSpacing="0.1" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:fontFamily="@font/manrope_bold"
                            android:text="All funds are bank-grade encrypted and trackable 24/7 in your dashboard."
                            android:textColor="@color/v_text_dark"
                            android:textSize="13sp" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Step Label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:fontFamily="@font/manrope_bold"
                android:letterSpacing="0.1"
                android:text="STEP 2 OF 3: SECURE FINANCE"
                android:textColor="@color/v_text_muted"
                android:textSize="11sp" />

        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
