<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/neumorphic_bg">

    <ViewFlipper
        android:id="@+id/viewFlipper"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:inAnimation="@anim/slide_in_right"
        android:outAnimation="@anim/slide_out_left"
        app:layout_constraintBottom_toTopOf="@id/pagination_dots"
        app:layout_constraintTop_toTopOf="parent">

        <include layout="@layout/layout_onboarding_slide_circles" />
        <include layout="@layout/layout_onboarding_slide_loans" />
        <include layout="@layout/layout_onboarding_slide_security" />

    </ViewFlipper>

    <!-- PAGINATION DOTS -->
    <LinearLayout
        android:id="@+id/pagination_dots"
        android:layout_width="wrap_content"
        android:layout_height="8dp"
        android:layout_marginBottom="28dp"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintBottom_toTopOf="@id/nextButton"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <View
            android:id="@+id/dot_1"
            android:layout_width="24dp"
            android:layout_height="8dp"
            android:background="@drawable/bg_white_rounded"
            android:backgroundTint="@color/neumorphic_blue_active" />

        <View
            android:id="@+id/dot_2"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:layout_marginHorizontal="6dp"
            android:background="@drawable/circle_background"
            android:backgroundTint="@color/neumorphic_dot_inactive" />

        <View
            android:id="@+id/dot_3"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="@drawable/circle_background"
            android:backgroundTint="@color/neumorphic_dot_inactive" />
    </LinearLayout>

    <!-- BOTTOM CTA BUTTON -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/nextButton"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginHorizontal="32dp"
        android:layout_marginBottom="24dp"
        android:background="@drawable/bg_blue_pill_gradient"
        android:fontFamily="@font/manrope_bold"
        android:text="Next"
        android:textAllCaps="false"
        android:textColor="@color/white"
        android:textSize="17sp"
        app:backgroundTint="@null"
        app:cornerRadius="28dp"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
