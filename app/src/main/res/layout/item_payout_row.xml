<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="?attr/selectableItemBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:paddingVertical="12dp">

        <!-- Drag handle (only visible for unpaid members when admin) -->
        <ImageView
            android:id="@+id/ivDragHandle"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginEnd="8dp"
            android:src="@drawable/ic_drag_handle"
            android:visibility="gone"
            tools:ignore="ContentDescription" />

        <!-- Avatar: photo when available, initials otherwise -->
        <FrameLayout
            android:layout_width="40dp"
            android:layout_height="40dp">

            <TextView
                android:id="@+id/tvAvatarInitials"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:gravity="center"
                android:background="@drawable/bg_avatar_circle"
                android:textColor="@color/dashboard_text_primary"
                android:textSize="15sp"
                android:textStyle="bold"
                tools:text="K" />

            <ImageView
                android:id="@+id/ivAvatarPhoto"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:scaleType="centerCrop"
                android:visibility="gone"
                tools:ignore="ContentDescription" />

            <!-- Paid checkmark overlay -->
            <ImageView
                android:id="@+id/ivPaidBadge"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_gravity="bottom|end"
                android:src="@drawable/ic_check_circle"
                app:tint="#10B981"
                android:visibility="gone"
                tools:ignore="ContentDescription" />
        </FrameLayout>

        <!-- Name + status -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="8dp">

            <TextView
                android:id="@+id/tvRowTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/dashboard_text_primary"
                android:textSize="13sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"
                tools:text="Kampa John" />

            <TextView
                android:id="@+id/tvRowSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textColor="#9AA5B4"
                android:textSize="11sp"
                tools:text="Receiving: Jul 15, 2026" />
        </LinearLayout>

        <!-- Status / Amount -->
        <TextView
            android:id="@+id/tvRowAmount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="@color/dashboard_text_primary"
            tools:text="UGX 1,200,000" />

    </LinearLayout>

    <View
        android:id="@+id/viewRowDivider"
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:layout_marginStart="68dp"
        android:background="#F2F4F7" />

</LinearLayout>
