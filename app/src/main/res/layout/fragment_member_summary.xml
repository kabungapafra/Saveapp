<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/v_page_bg">

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="24dp">

                <!-- ===== HERO SECTION: TOTAL SAVINGS ===== -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/heroCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="16dp"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="24dp"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="12dp"
                    app:strokeWidth="0dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_hero_blue_gradient"
                        android:padding="22dp">

                        <!-- Decorative Circle in Corner -->
                        <View
                            android:layout_width="180dp"
                            android:layout_height="180dp"
                            android:layout_alignParentTop="true"
                            android:layout_alignParentEnd="true"
                            android:layout_marginTop="-40dp"
                            android:layout_marginEnd="-40dp"
                            android:background="@drawable/bg_v_hero_decorative_circle" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginBottom="8dp"
                                android:fontFamily="@font/manrope_medium"
                                android:text="Group Total Savings"
                                android:textColor="#BFFFFFFF"
                                android:textSize="13sp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/manrope_bold"
                                android:text="UGX"
                                android:textColor="#FFFFFF"
                                android:textSize="28sp" />

                            <TextView
                                android:id="@+id/tvTotalSavings"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/manrope_bold"
                                android:text="14,250,000"
                                android:textColor="#FFFFFF"
                                android:textSize="36sp"
                                android:lineHeight="40sp" />
                        </LinearLayout>

                        <!-- Score Badge (Glassmorphic Pill) -->
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:gravity="center"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginBottom="3dp"
                                android:fontFamily="@font/manrope_bold"
                                android:text="SCORE"
                                android:letterSpacing="0.15"
                                android:textColor="#B2FFFFFF"
                                android:textSize="9sp" />

                            <com.google.android.material.card.MaterialCardView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                app:cardBackgroundColor="#2EFFFFFF"
                                app:cardCornerRadius="12dp"
                                app:cardElevation="0dp"
                                app:strokeColor="#4DFFFFFF"
                                app:strokeWidth="1dp">

                                <TextView
                                    android:id="@+id/tvScore"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:paddingHorizontal="16dp"
                                    android:paddingVertical="8dp"
                                    android:fontFamily="@font/manrope_bold"
                                    android:text="92"
                                    android:textColor="#FFFFFF"
                                    android:textSize="26sp" />
                            </com.google.android.material.card.MaterialCardView>
                        </LinearLayout>

                        <!-- Reliability Pulse (Bottom Card) -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="150dp"
                            android:orientation="vertical">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginBottom="8dp"
                                android:orientation="horizontal">

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:fontFamily="@font/manrope_medium"
                                    android:text="Reliability Pulse"
                                    android:textColor="#BFFFFFFF"
                                    android:textSize="12sp" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="@font/manrope_bold"
                                    android:text="Very High"
                                    android:textColor="#FFFFFF"
                                    android:textSize="12sp" />
                            </LinearLayout>

                            <com.google.android.material.progressindicator.LinearProgressIndicator
                                android:id="@+id/pulseProgressBar"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:progress="88"
                                app:indicatorColor="@color/v_pink_progress_start"
                                app:trackColor="#33FFFFFF"
                                app:trackCornerRadius="99dp"
                                app:trackThickness="7dp" />
                        </LinearLayout>

                    </RelativeLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- ===== SECTION: PRIORITY RISK ALERTS ===== -->
                <LinearLayout
                    android:id="@+id/riskSection"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="16dp"
                    android:layout_marginBottom="12dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:layout_marginEnd="8dp"
                        android:src="@drawable/ic_warning"
                        app:tint="@color/v_amber_warning" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/manrope_bold"
                        android:text="Priority Risk Alerts"
                        android:textColor="@color/v_text_dark"
                        android:textSize="16sp" />
                </LinearLayout>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/alertCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="16dp"
                    android:layout_marginBottom="24dp"
                    app:cardBackgroundColor="@color/v_alert_bg"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/v_alert_border"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="14dp">

                            <com.google.android.material.imageview.ShapeableImageView
                                android:id="@+id/ivAlertAvatar"
                                android:layout_width="52dp"
                                android:layout_height="52dp"
                                android:scaleType="centerCrop"
                                android:src="@drawable/ic_profile_placeholder"
                                app:shapeAppearanceOverlay="@style/ShapeAppearance.MaterialComponents.MediumComponent" />

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_centerVertical="true"
                                android:layout_marginStart="12dp"
                                android:layout_toEndOf="@id/ivAlertAvatar"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="@font/manrope_bold"
                                    android:text="Arthur Museveni"
                                    android:textColor="@color/v_text_dark"
                                    android:textSize="15sp" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="3dp"
                                    android:fontFamily="@font/manrope_medium"
                                    android:text="Missed 2 of last 3 contributions"
                                    android:textColor="@color/v_text_muted"
                                    android:textSize="12sp" />
                            </LinearLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentEnd="true"
                                android:layout_centerVertical="true"
                                android:fontFamily="@font/manrope_bold"
                                android:text="64%"
                                android:textColor="@color/v_red_alert"
                                android:textSize="18sp" />
                        </RelativeLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnRemind"
                                android:layout_width="0dp"
                                android:layout_height="40dp"
                                android:layout_marginEnd="10dp"
                                android:layout_weight="1"
                                android:backgroundTint="@color/v_brown_dark_btn"
                                android:fontFamily="@font/manrope_bold"
                                android:insetTop="0dp"
                                android:insetBottom="0dp"
                                android:text="Remind Member"
                                android:textAllCaps="false"
                                android:textColor="#FFFFFF"
                                android:textSize="13sp"
                                app:cornerRadius="10dp"
                                app:elevation="4dp" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnViewHistory"
                                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                android:layout_width="0dp"
                                android:layout_height="40dp"
                                android:layout_weight="1"
                                android:fontFamily="@font/manrope_bold"
                                android:insetTop="0dp"
                                android:insetBottom="0dp"
                                android:text="View History"
                                android:textAllCaps="false"
                                android:textColor="@color/v_text_dark"
                                android:textSize="13sp"
                                app:cornerRadius="10dp"
                                app:strokeColor="@color/v_text_muted"
                                app:strokeWidth="1.5dp" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- ===== SECTION: MEMBER CONSISTENCY ===== -->
                <RelativeLayout
                    android:id="@+id/consistencySection"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="16dp"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/manrope_bold"
                        android:text="Member Consistency"
                        android:textColor="@color/v_text_dark"
                        android:textSize="20sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:fontFamily="@font/manrope_bold"
                        android:text="Last 6 Months"
                        android:textColor="@color/v_blue"
                        android:textSize="13sp" />
                </RelativeLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvConsistency"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clipToPadding="false"
                    android:nestedScrollingEnabled="false"
                    android:paddingHorizontal="16dp"
                    tools:listitem="@layout/item_member_consistency" />

                <!-- LEGEND -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="80dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <View
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:background="@drawable/bg_circle_white"
                        android:backgroundTint="@color/v_blue" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:fontFamily="@font/manrope_bold"
                        android:text="PAID"
                        android:textColor="@color/v_text_muted"
                        android:textSize="11sp" />

                    <View
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:layout_marginStart="20dp"
                        android:background="@drawable/bg_circle_white"
                        android:backgroundTint="@color/v_brown_late" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:fontFamily="@font/manrope_bold"
                        android:text="LATE"
                        android:textColor="@color/v_text_muted"
                        android:textSize="11sp" />

                    <View
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:layout_marginStart="20dp"
                        android:background="@drawable/bg_circle_white"
                        android:backgroundTint="@color/v_red_missed" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:fontFamily="@font/manrope_bold"
                        android:text="MISSED"
                        android:textColor="@color/v_text_muted"
                        android:textSize="11sp" />
                </LinearLayout>
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

    </androidx.coordinatorlayout.widget.CoordinatorLayout>
</layout>
