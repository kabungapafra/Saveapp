<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/v_page_bg">

        <!-- TOP HEADER -->
        <RelativeLayout
            android:id="@+id/headerLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/card_surface"
            android:elevation="4dp"
            android:paddingHorizontal="16dp"
            android:paddingVertical="16dp"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/backButton"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:background="@drawable/bg_input_bg_circle"
                android:padding="10dp"
                android:src="@drawable/ic_arrow_back"
                app:tint="@color/v_text_dark" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:fontFamily="@font/poppins"
                android:text="Top Contributors"
                android:textColor="@color/v_text_dark"
                android:textSize="@dimen/text_size_normal" />
        </RelativeLayout>

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:clipToPadding="false"
            android:paddingBottom="24dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toBottomOf="@id/headerLayout">

            <LinearLayout
                android:id="@+id/heroCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="32dp">

                <!-- ===== HERO: TOTAL CONTRIBUTIONS (YTD) ===== -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="16dp"
                    android:layout_marginTop="24dp"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="6dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_card_premium_blue"
                        android:orientation="vertical"
                        android:padding="24dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:alpha="0.8"
                            android:fontFamily="sans-serif-medium"
                            android:letterSpacing="0.08"
                            android:text="TOTAL CONTRIBUTIONS (YTD)"
                            android:textColor="@color/permanent_white"
                            android:textSize="@dimen/text_size_xs" />

                        <TextView
                            android:id="@+id/tvTotalContributions"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:fontFamily="@font/poppins"
                            android:text="UGX 0"
                            android:textColor="@color/permanent_white"
                            android:textSize="@dimen/text_size_xxxl"
                            tools:text="UGX 38,400,000" />

                        <TextView
                            android:id="@+id/tvMemberCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:alpha="0.75"
                            android:fontFamily="@font/montserrat"
                            android:text="Members ranked by amount contributed"
                            android:textColor="@color/permanent_white"
                            android:textSize="@dimen/text_size_xs" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- ===== RANKED CONTRIBUTOR LIST ===== -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/consistencySection"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="16dp"
                    android:layout_marginTop="14dp"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="2dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@color/card_surface"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <!-- Column Headers -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="2"
                                android:fontFamily="@font/montserrat"
                                android:letterSpacing="0.08"
                                android:text="MEMBER"
                                android:textColor="@color/v_text_muted"
                                android:textSize="@dimen/text_size_xs" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="2"
                                android:fontFamily="@font/montserrat"
                                android:gravity="center"
                                android:letterSpacing="0.06"
                                android:text="TARGET MET"
                                android:textColor="@color/v_text_muted"
                                android:textSize="@dimen/text_size_xs" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:fontFamily="@font/montserrat"
                                android:gravity="end"
                                android:text="AMT (M)"
                                android:textColor="@color/v_text_muted"
                                android:textSize="@dimen/text_size_xs" />
                        </LinearLayout>

                        <!-- Divider -->
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginVertical="10dp"
                            android:background="@color/v_input_bg" />

                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/rvConsistency"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:nestedScrollingEnabled="false"
                            tools:listitem="@layout/item_member_performance" />

                        <!-- Empty state -->
                        <TextView
                            android:id="@+id/tvEmpty"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:fontFamily="@font/montserrat"
                            android:gravity="center"
                            android:padding="16dp"
                            android:text="No contributors yet"
                            android:textColor="@color/v_text_muted"
                            android:textSize="@dimen/text_size_xs"
                            android:visibility="gone" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>
