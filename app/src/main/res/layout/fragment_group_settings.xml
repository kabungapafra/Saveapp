<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/v_page_bg">

    <!-- IMMERSIVE HEADER (NO NAVIGATION BAR) -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/headerContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="48dp"
        android:paddingBottom="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/badgeActiveCycle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:background="@drawable/bg_pill_tab_selected"
            android:backgroundTint="#E9F2FB"
            android:fontFamily="@font/manrope_bold"
            android:paddingHorizontal="12dp"
            android:paddingVertical="4dp"
            android:text="ACTIVE CYCLE"
            android:textColor="@color/brand_blue"
            android:textSize="11sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/groupTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="12dp"
            android:fontFamily="@font/manrope_bold"
            android:text="Group Settings"
            android:textColor="@color/v_text_dark"
            android:textSize="32sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/badgeActiveCycle" />

        <TextView
            android:id="@+id/groupStats"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="4dp"
            android:fontFamily="@font/manrope_medium"
            android:text="Created October 2023  |  12 Members"
            android:textColor="@color/v_text_mid"
            android:textSize="15sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/groupTitle" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingBottom="40dp"
        android:scrollbars="none"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/headerContainer">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="16dp">

            <!-- FINANCIAL RULES SECTION -->
            <TextView
                android:id="@+id/labelFinancialRules"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_marginTop="24dp"
                android:fontFamily="@font/manrope_bold"
                android:letterSpacing="0.1"
                android:text="FINANCIAL RULES"
                android:textColor="@color/brand_blue"
                android:textSize="12sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <LinearLayout
                android:id="@+id/listFinancialRules"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="vertical"
                app:layout_constraintTop_toBottomOf="@id/labelFinancialRules">

                <!-- Contribution Amount -->
                <LinearLayout android:id="@+id/rowContribution" android:layout_width="match_parent" android:layout_height="64dp" android:background="?attr/selectableItemBackground" android:clickable="true" android:focusable="true" android:gravity="center_vertical" android:orientation="horizontal">
                    <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_wallet_safe_blue" app:tint="@color/brand_blue" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="12dp" android:layout_weight="1" android:fontFamily="@font/manrope_medium" android:text="Contribution Amount" android:textColor="@color/v_text_dark" android:textSize="15sp" />
                    <TextView android:id="@+id/valContribution" android:layout_width="wrap_content" android:layout_height="wrap_content" android:fontFamily="@font/manrope_bold" android:text="UGX 500" android:textColor="@color/brand_blue" android:textSize="14sp" />
                    <ImageView android:layout_width="16dp" android:layout_height="16dp" android:layout_marginStart="8dp" android:src="@drawable/ic_chevron_right" app:tint="@color/v_text_muted" />
                </LinearLayout>

                <!-- Frequency -->
                <LinearLayout android:id="@+id/rowFrequency" android:layout_width="match_parent" android:layout_height="64dp" android:background="?attr/selectableItemBackground" android:clickable="true" android:focusable="true" android:gravity="center_vertical" android:orientation="horizontal">
                    <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_calendar_month" app:tint="@color/brand_blue" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="12dp" android:layout_weight="1" android:fontFamily="@font/manrope_medium" android:text="Frequency" android:textColor="@color/v_text_dark" android:textSize="15sp" />
                    <TextView android:id="@+id/valFrequency" android:layout_width="wrap_content" android:layout_height="wrap_content" android:fontFamily="@font/manrope_bold" android:text="Monthly" android:textColor="@color/brand_blue" android:textSize="14sp" />
                    <ImageView android:layout_width="16dp" android:layout_height="16dp" android:layout_marginStart="8dp" android:src="@drawable/ic_chevron_right" app:tint="@color/v_text_muted" />
                </LinearLayout>

                <!-- Payout Amount -->
                <LinearLayout android:id="@+id/rowPayoutAmount" android:layout_width="match_parent" android:layout_height="64dp" android:background="?attr/selectableItemBackground" android:clickable="true" android:focusable="true" android:gravity="center_vertical" android:orientation="horizontal">
                    <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_money" app:tint="@color/brand_blue" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="12dp" android:layout_weight="1" android:fontFamily="@font/manrope_medium" android:text="Payout Amount" android:textColor="@color/v_text_dark" android:textSize="15sp" />
                    <TextView android:id="@+id/valPayoutAmount" android:layout_width="wrap_content" android:layout_height="wrap_content" android:fontFamily="@font/manrope_bold" android:text="UGX 50,000" android:textColor="@color/brand_blue" android:textSize="14sp" />
                    <ImageView android:layout_width="16dp" android:layout_height="16dp" android:layout_marginStart="8dp" android:src="@drawable/ic_chevron_right" app:tint="@color/v_text_muted" />
                </LinearLayout>

                <!-- Recipients -->
                <LinearLayout android:id="@+id/rowRecipients" android:layout_width="match_parent" android:layout_height="64dp" android:background="?attr/selectableItemBackground" android:clickable="true" android:focusable="true" android:gravity="center_vertical" android:orientation="horizontal">
                    <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_people" app:tint="@color/brand_blue" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="12dp" android:layout_weight="1" android:fontFamily="@font/manrope_medium" android:text="Recipients" android:textColor="@color/v_text_dark" android:textSize="15sp" />
                    <TextView android:id="@+id/valRecipients" android:layout_width="wrap_content" android:layout_height="wrap_content" android:fontFamily="@font/manrope_bold" android:text="1 Member" android:textColor="@color/brand_blue" android:textSize="14sp" />
                    <ImageView android:layout_width="16dp" android:layout_height="16dp" android:layout_marginStart="8dp" android:src="@drawable/ic_chevron_right" app:tint="@color/v_text_muted" />
                </LinearLayout>

                <!-- Late Fee -->
                <LinearLayout android:id="@+id/rowLateFee" android:layout_width="match_parent" android:layout_height="64dp" android:background="?attr/selectableItemBackground" android:clickable="true" android:focusable="true" android:gravity="center_vertical" android:orientation="horizontal">
                    <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_clock_orange" app:tint="@color/brand_blue" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="12dp" android:layout_weight="1" android:fontFamily="@font/manrope_medium" android:text="Late Fee" android:textColor="@color/v_text_dark" android:textSize="15sp" />
                    <TextView android:id="@+id/valLateFee" android:layout_width="wrap_content" android:layout_height="wrap_content" android:fontFamily="@font/manrope_bold" android:text="UGX 25" android:textColor="@color/brand_blue" android:textSize="14sp" />
                    <ImageView android:layout_width="16dp" android:layout_height="16dp" android:layout_marginStart="8dp" android:src="@drawable/ic_chevron_right" app:tint="@color/v_text_muted" />
                </LinearLayout>

                <!-- Loan Interest -->
                <LinearLayout android:id="@+id/rowLoanInterest" android:layout_width="match_parent" android:layout_height="64dp" android:background="?attr/selectableItemBackground" android:clickable="true" android:focusable="true" android:gravity="center_vertical" android:orientation="horizontal">
                    <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_trending_up" app:tint="@color/brand_blue" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="12dp" android:layout_weight="1" android:fontFamily="@font/manrope_medium" android:text="Loan Interest" android:textColor="@color/v_text_dark" android:textSize="15sp" />
                    <TextView android:id="@+id/valLoanInterest" android:layout_width="wrap_content" android:layout_height="wrap_content" android:fontFamily="@font/manrope_bold" android:text="5%" android:textColor="@color/brand_blue" android:textSize="14sp" />
                    <ImageView android:layout_width="16dp" android:layout_height="16dp" android:layout_marginStart="8dp" android:src="@drawable/ic_chevron_right" app:tint="@color/v_text_muted" />
                </LinearLayout>

                <!-- Loan Late Fee -->
                <LinearLayout android:id="@+id/rowLoanLateFee" android:layout_width="match_parent" android:layout_height="64dp" android:background="?attr/selectableItemBackground" android:clickable="true" android:focusable="true" android:gravity="center_vertical" android:orientation="horizontal">
                    <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_warning" app:tint="@color/brand_blue" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="12dp" android:layout_weight="1" android:fontFamily="@font/manrope_medium" android:text="Loan Late Fee" android:textColor="@color/v_text_dark" android:textSize="15sp" />
                    <TextView android:id="@+id/valLoanLateFee" android:layout_width="wrap_content" android:layout_height="wrap_content" android:fontFamily="@font/manrope_bold" android:text="UGX 50" android:textColor="@color/brand_blue" android:textSize="14sp" />
                    <ImageView android:layout_width="16dp" android:layout_height="16dp" android:layout_marginStart="8dp" android:src="@drawable/ic_chevron_right" app:tint="@color/v_text_muted" />
                </LinearLayout>

                <!-- Start Date -->
                <LinearLayout android:id="@+id/rowStartDate" android:layout_width="match_parent" android:layout_height="64dp" android:background="?attr/selectableItemBackground" android:clickable="true" android:focusable="true" android:gravity="center_vertical" android:orientation="horizontal">
                    <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_calendar_month" app:tint="@color/brand_blue" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="12dp" android:layout_weight="1" android:fontFamily="@font/manrope_medium" android:text="Start Date" android:textColor="@color/v_text_dark" android:textSize="15sp" />
                    <TextView android:id="@+id/valStartDate" android:layout_width="wrap_content" android:layout_height="wrap_content" android:fontFamily="@font/manrope_bold" android:text="Oct 1, 2023" android:textColor="@color/brand_blue" android:textSize="14sp" />
                    <ImageView android:layout_width="16dp" android:layout_height="16dp" android:layout_marginStart="8dp" android:src="@drawable/ic_chevron_right" app:tint="@color/v_text_muted" />
                </LinearLayout>

                <!-- Automatic Payouts -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="64dp" android:gravity="center_vertical" android:orientation="horizontal">
                    <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_automatic_payouts" app:tint="@color/brand_blue" />
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="12dp" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:fontFamily="@font/manrope_medium" android:text="Automatic Payouts" android:textColor="@color/v_text_dark" android:textSize="15sp" />
                        <TextView android:id="@+id/tvNextAutomaticPayoutDate" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Next Payout: Oct 28, 2023" android:textColor="@color/brand_blue" android:textSize="12sp" />
                    </LinearLayout>
                    <com.google.android.material.materialswitch.MaterialSwitch android:id="@+id/switchAutomaticPayouts" android:layout_width="wrap_content" android:layout_height="wrap_content" android:checked="true" app:thumbTint="@color/white" app:trackTint="@color/brand_blue" />
                </LinearLayout>

                <!-- Scheduled Contributions -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="64dp" android:gravity="center_vertical" android:orientation="horizontal">
                    <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_calendar" app:tint="@color/brand_blue" />
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="12dp" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:fontFamily="@font/manrope_medium" android:text="Scheduled Contributions" android:textColor="@color/v_text_dark" android:textSize="15sp" />
                        <TextView android:id="@+id/tvNextContributionDate" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Next: Oct 24, 2023" android:textColor="@color/brand_blue" android:textSize="12sp" />
                    </LinearLayout>
                    <com.google.android.material.materialswitch.MaterialSwitch android:id="@+id/switchScheduledContributions" android:layout_width="wrap_content" android:layout_height="wrap_content" android:checked="true" app:thumbTint="@color/white" app:trackTint="@color/brand_blue" />
                </LinearLayout>

                <!-- Smart Round-ups -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="64dp" android:gravity="center_vertical" android:orientation="horizontal">
                    <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_stars" app:tint="@color/brand_blue" />
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="12dp" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:fontFamily="@font/manrope_medium" android:text="Smart Round-ups" android:textColor="@color/v_text_dark" android:textSize="15sp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Round up to the nearest UGX 1.00" android:textColor="@color/v_text_muted" android:textSize="12sp" />
                    </LinearLayout>
                    <com.google.android.material.materialswitch.MaterialSwitch android:id="@+id/switchSmartRoundups" android:layout_width="wrap_content" android:layout_height="wrap_content" android:checked="false" app:thumbTint="@color/white" app:trackTint="@color/brand_blue" />
                </LinearLayout>

            </LinearLayout>

            <!-- AUTOMATION & GOVERNANCE SECTION -->
            <TextView
                android:id="@+id/labelAutomationGovernance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_marginTop="32dp"
                android:fontFamily="@font/manrope_bold"
                android:letterSpacing="0.1"
                android:text="AUTOMATION &amp; GOVERNANCE"
                android:textColor="@color/v_text_muted"
                android:textSize="12sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/listFinancialRules" />

            <!-- Automation Card Container -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardAutomationGovernance"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="@color/v_page_bg"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:layout_constraintTop_toBottomOf="@id/labelAutomationGovernance"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Automated Cycle Rotation Row -->
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="64dp"
                        android:paddingHorizontal="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/manrope_medium"
                            android:text="Automated Cycle Rotation"
                            android:textColor="@color/v_text_dark"
                            android:textSize="15sp"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:drawableStartCompat="@drawable/ic_automated_cycle"
                            android:drawablePadding="12dp"
                            android:gravity="center_vertical" />

                        <com.google.android.material.materialswitch.MaterialSwitch
                            android:id="@+id/switchAutomatedCycle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:checked="true"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:thumbTint="@color/white"
                            app:trackTint="@color/brand_blue" />
                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <!-- Loan Request Permissions Row -->
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="64dp"
                        android:paddingHorizontal="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/manrope_medium"
                            android:text="Loan Request Permissions"
                            android:textColor="@color/v_text_dark"
                            android:textSize="15sp"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:drawableStartCompat="@drawable/ic_loan_requests"
                            android:drawablePadding="12dp"
                            android:gravity="center_vertical" />

                        <com.google.android.material.materialswitch.MaterialSwitch
                            android:id="@+id/switchLoanRequests"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:checked="true"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:thumbTint="@color/white"
                            app:trackTint="@color/brand_blue" />
                    </androidx.constraintlayout.widget.ConstraintLayout>

                     <!-- Invite Others Row -->
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/btnInviteOthers"
                        android:layout_width="match_parent"
                        android:layout_height="64dp"
                        android:background="@drawable/bg_pill_light_blue"
                        android:backgroundTint="#E9F2FB"
                        android:layout_margin="8dp"
                        android:paddingHorizontal="16dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/manrope_bold"
                            android:text="Invite Others to Group"
                            android:textColor="@color/brand_blue"
                            android:textSize="15sp"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:drawableStartCompat="@drawable/ic_invite_others"
                            android:drawablePadding="12dp"
                            android:gravity="center_vertical" />

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_chevron_right"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:tint="@color/brand_blue" />
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- APP PREFERENCES SECTION -->
            <TextView
                android:id="@+id/labelAppPreferences"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_marginTop="32dp"
                android:fontFamily="@font/manrope_bold"
                android:letterSpacing="0.1"
                android:text="APP PREFERENCES"
                android:textColor="@color/v_text_muted"
                android:textSize="12sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/cardAutomationGovernance" />

            <!-- Preferences Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardPreferences"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="@color/v_page_bg"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:layout_constraintTop_toBottomOf="@id/labelAppPreferences"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingVertical="8dp">


                    <!-- Push Notifications Row -->
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:paddingHorizontal="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/manrope_medium"
                            android:text="Push Notifications"
                            android:textColor="@color/v_text_dark"
                            android:textSize="15sp"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:drawableStartCompat="@drawable/ic_bell_premium"
                            android:drawablePadding="12dp"
                            android:gravity="center_vertical" />

                        <com.google.android.material.materialswitch.MaterialSwitch
                            android:id="@+id/switchNotifications"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:checked="true"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:thumbTint="@color/white"
                            app:trackTint="@color/brand_blue" />
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>


            <!-- Delete Group Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDeleteGroup"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginTop="40dp"
                android:layout_marginBottom="24dp"
                android:fontFamily="@font/manrope_bold"
                android:text="Delete Group"
                android:textAllCaps="false"
                android:textColor="#DC2626"
                android:textSize="16sp"
                app:cornerRadius="32dp"
                app:icon="@drawable/ic_delete"
                app:iconGravity="textStart"
                app:iconPadding="12dp"
                app:iconTint="#DC2626"
                app:layout_constraintTop_toBottomOf="@id/cardPreferences"
                app:strokeColor="#FEE2E2"
                app:backgroundTint="#FEF2F2"
                app:strokeWidth="1dp"
                tools:ignore="VisualLintButtonSize" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
