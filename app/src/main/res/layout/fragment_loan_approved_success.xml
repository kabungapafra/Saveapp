<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/v_page_bg">

    <ImageView
        android:id="@+id/ivLogo"
        android:layout_width="140dp"
        android:layout_height="70dp"
        android:layout_marginTop="32dp"
        android:scaleType="fitCenter"
        android:src="@drawable/save_logo"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingBottom="32dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/ivLogo">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingHorizontal="32dp">

            <!-- Success Graphic Container -->
            <FrameLayout
                android:layout_width="280dp"
                android:layout_height="280dp"
                android:layout_marginTop="40dp">

                <!-- Soft Green Glow Background -->
                <View
                    android:layout_width="260dp"
                    android:layout_height="260dp"
                    android:layout_gravity="center"
                    android:alpha="0.2"
                    android:background="@drawable/bg_circle_green" />

                <View
                    android:layout_width="200dp"
                    android:layout_height="200dp"
                    android:layout_gravity="center"
                    android:alpha="0.4"
                    android:background="@drawable/bg_circle_green" />

                <!-- Confetti Elements Container -->
                <FrameLayout
                    android:id="@+id/confettiContainer"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">
                    <View
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:layout_gravity="top|start"
                        android:layout_marginStart="60dp"
                        android:layout_marginTop="60dp"
                        android:background="@color/brand_blue"
                        android:rotation="15" />

                    <View
                        android:layout_width="6dp"
                        android:layout_height="6dp"
                        android:layout_gravity="center_vertical|start"
                        android:layout_marginStart="50dp"
                        android:background="#A7F3D0"
                        android:rotation="45" />

                    <View
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:layout_gravity="bottom|start"
                        android:layout_marginStart="90dp"
                        android:layout_marginBottom="70dp"
                        android:background="#FDE68A"
                        android:rotation="-20" />

                    <View
                        android:layout_width="6dp"
                        android:layout_height="6dp"
                        android:layout_gravity="bottom|center_horizontal"
                        android:layout_marginEnd="20dp"
                        android:layout_marginBottom="50dp"
                        android:background="#BFDBFE"
                        android:rotation="30" />

                    <View
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:layout_gravity="bottom|end"
                        android:layout_marginEnd="70dp"
                        android:layout_marginBottom="90dp"
                        android:background="#FDE68A"
                        android:rotation="45" />

                    <View
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:layout_gravity="center_vertical|end"
                        android:layout_marginEnd="60dp"
                        android:layout_marginBottom="20dp"
                        android:background="#FDE68A"
                        android:rotation="-15" />

                    <View
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:layout_gravity="top|end"
                        android:layout_marginTop="80dp"
                        android:layout_marginEnd="80dp"
                        android:background="#BFDBFE"
                        android:rotation="25" />
                </FrameLayout>

                <!-- Central White Circle -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/checkmarkCircle"
                    android:layout_width="140dp"
                    android:layout_height="140dp"
                    android:layout_gravity="center"
                    app:cardBackgroundColor="@color/card_surface"
                    app:cardCornerRadius="70dp"
                    app:cardElevation="12dp"
                    app:strokeWidth="0dp">

                    <ImageView
                        android:id="@+id/ivCheckmark"
                        android:layout_width="72dp"
                        android:layout_height="72dp"
                        android:layout_gravity="center"
                        app:srcCompat="@drawable/avd_checkmark_green" />
                </com.google.android.material.card.MaterialCardView>
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:fontFamily="sans-serif-black"
                android:gravity="center"
                android:text="Loan Approved\nSuccessfully!"
                android:textColor="@color/v_text_dark"
                android:textSize="28sp" />

            <!-- Detail Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                app:cardBackgroundColor="@color/card_surface"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/divider_color"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="24dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-bold"
                            android:text="$35,000"
                            android:textColor="@color/brand_blue"
                            android:textSize="16sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:text="has been successfully allocated"
                            android:textColor="@color/v_text_mid"
                            android:textSize="16sp" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="to"
                        android:textColor="@color/v_text_mid"
                        android:textSize="16sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:fontFamily="sans-serif-bold"
                        android:text="Marcus Wright"
                        android:textColor="@color/v_text_dark"
                        android:textSize="16sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <Space
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_weight="1" />

            <!-- Done Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDone"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginTop="24dp"
                android:fontFamily="sans-serif-black"
                android:text="Done   →"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="17sp"
                app:backgroundTint="@color/brand_blue"
                app:cornerRadius="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:fontFamily="sans-serif-bold"
                android:letterSpacing="0.05"
                android:text="TRANSACTION ID: SAVE-9921-XW"
                android:textColor="@color/v_text_muted"
                android:textSize="11sp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
