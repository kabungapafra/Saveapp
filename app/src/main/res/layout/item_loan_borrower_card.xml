<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="20dp"
    android:layout_marginBottom="16dp"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="16dp"
    app:cardElevation="1dp"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <!-- Red left stripe for late loans -->
        <View
            android:id="@+id/lateStripe"
            android:layout_width="4dp"
            android:layout_height="match_parent"
            android:background="#E11D48"
            android:visibility="gone" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Title row -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/ivAvatar"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:src="@drawable/ic_person"
                    app:shapeAppearanceOverlay="@style/ShapeAppearance.App.Circle" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_toEndOf="@id/ivAvatar"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvBorrowerName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/manrope"
                        android:text="Borrower Name"
                        android:textColor="@color/dashboard_text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvInterestRate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Interest: 5.2%"
                        android:textColor="@color/dashboard_text_secondary"
                        android:textSize="11sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvStatusBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:background="@drawable/bg_status_pills"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp"
                    android:text="ACTIVE"
                    android:textSize="10sp"
                    android:textStyle="bold" />
            </RelativeLayout>

            <!-- Amount & Right Info row -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp">

                <TextView
                    android:id="@+id/tvLoanAmount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/manrope"
                    android:text="$12,500.00"
                    android:textColor="@color/dashboard_text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvRightInfo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:text="Due: Oct 24, 2023"
                    android:textColor="@color/dashboard_text_secondary"
                    android:textSize="11sp" />
            </RelativeLayout>

            <!-- Progress -->
            <com.google.android.material.progressindicator.LinearProgressIndicator
                android:id="@+id/loanProgress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:progress="45"
                app:indicatorColor="#215DA1"
                app:trackColor="@color/v_page_bg"
                app:trackCornerRadius="4dp"
                app:trackThickness="6dp" />

            <!-- Overdue Indicator -->
            <TextView
                android:id="@+id/tvOverdueInfo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:layout_marginTop="4dp"
                android:text="Overdue: 4 days"
                android:textColor="#E11D48"
                android:textSize="11sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <!-- Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnLeft"
                    style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    android:backgroundTint="@color/v_page_bg"
                    android:fontFamily="@font/manrope"
                    android:text="View Details"
                    android:textAllCaps="false"
                    android:textColor="@color/dashboard_text_primary"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    app:cornerRadius="8dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnRight"
                    style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:fontFamily="@font/manrope"
                    android:text="Remind"
                    android:textAllCaps="false"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    app:cornerRadius="8dp" />
            </LinearLayout>

        </LinearLayout>
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
