<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/v_page_bg"
    tools:context=".ui.fragments.ApprovalsFragment">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/nestedScrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingBottom="40dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="36dp">

            <!-- Metric Cards (Horizontal Stack) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="110dp"
                android:orientation="horizontal"
                android:paddingHorizontal="20dp"
                android:paddingBottom="8dp"
                android:layout_marginTop="16dp">

                <!-- Loans Card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    app:cardBackgroundColor="@color/card_surface"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="2dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/manrope_bold"
                            android:letterSpacing="0.1"
                            android:text="PENDING LOANS"
                            android:textColor="@color/v_text_mid"
                            android:textSize="8sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentBottom="true"
                            android:fontFamily="@font/manrope_bold"
                            android:text="14"
                            android:textColor="@color/v_text_dark"
                            android:textSize="28sp" />

                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:layout_alignParentEnd="true"
                            android:layout_alignParentBottom="true"
                            android:alpha="0.1"
                            android:src="@drawable/ic_account_balance_wallet"
                            app:tint="@color/brand_blue" />
                    </RelativeLayout>
                </androidx.cardview.widget.CardView>

                <!-- Payouts Card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    app:cardBackgroundColor="@color/card_surface"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="2dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/manrope_bold"
                            android:letterSpacing="0.1"
                            android:text="PAYOUTS"
                            android:textColor="@color/v_text_mid"
                            android:textSize="8sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentBottom="true"
                            android:fontFamily="@font/manrope_bold"
                            android:text="23"
                            android:textColor="@color/v_text_dark"
                            android:textSize="28sp" />

                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:layout_alignParentEnd="true"
                            android:layout_alignParentBottom="true"
                            android:alpha="0.1"
                            android:src="@drawable/ic_shield"
                            app:tint="@color/brand_blue" />
                    </RelativeLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <!-- Loan Requests Section -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:paddingHorizontal="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:fontFamily="@font/manrope_bold"
                    android:text="Loan Requests"
                    android:textColor="@color/v_text_dark"
                    android:textSize="20sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:background="@drawable/bg_pill_orange"
                    android:backgroundTint="@color/h_amber_bg"
                    android:fontFamily="@font/manrope_bold"
                    android:letterSpacing="0.05"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp"
                    android:text="HIGH YIELD FOCUS"
                    android:textColor="@color/h_amber_text"
                    android:textSize="8sp" />
            </RelativeLayout>

            <!-- Loan Card 1: Julian -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="@color/card_surface"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp">

                    <TextView
                        android:id="@+id/lblApplicant1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/manrope_bold"
                        android:letterSpacing="0.1"
                        android:text="APPLICANT"
                        android:textColor="@color/v_text_muted"
                        android:textSize="9sp" />

                    <TextView
                        android:id="@+id/tvApplicant1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/lblApplicant1"
                        android:layout_marginTop="4dp"
                        android:fontFamily="@font/manrope_bold"
                        android:text="Julian Vane-Tempest"
                        android:textColor="@color/v_text_dark"
                        android:textSize="15sp" />

                    <TextView
                        android:id="@+id/lblRequested1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:fontFamily="@font/manrope_bold"
                        android:letterSpacing="0.1"
                        android:text="REQUESTED"
                        android:textColor="@color/v_text_muted"
                        android:textSize="9sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/lblRequested1"
                        android:layout_alignParentEnd="true"
                        android:layout_marginTop="2dp"
                        android:fontFamily="@font/manrope_bold"
                        android:text="$450,000.00"
                        android:textColor="@color/brand_blue"
                        android:textSize="17sp" />

                    <View
                        android:id="@+id/dividerLine1"
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_below="@id/tvApplicant1"
                        android:layout_marginTop="20dp"
                        android:background="@color/v_page_bg" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/dividerLine1"
                        android:layout_marginTop="20dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/manrope_bold"
                                android:letterSpacing="0.1"
                                android:text="SCORE"
                                android:textColor="@color/v_text_muted"
                                android:textSize="8sp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/manrope_bold"
                                android:text="812"
                                android:textColor="@color/v_text_dark"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/btnRejectJulian"
                            android:layout_width="80dp"
                            android:layout_height="32dp"
                            android:layout_marginEnd="8dp"
                            android:background="@drawable/bg_btn_reject"
                            android:fontFamily="@font/manrope_bold"
                            android:gravity="center"
                            android:letterSpacing="0.05"
                            android:text="REJECT"
                            android:textColor="#FFFFFF"
                            android:textSize="10sp" />

                        <TextView
                            android:id="@+id/btnAcceptJulian"
                            android:layout_width="80dp"
                            android:layout_height="32dp"
                            android:background="@drawable/bg_btn_primary"
                            android:fontFamily="@font/manrope_bold"
                            android:gravity="center"
                            android:letterSpacing="0.05"
                            android:text="ACCEPT"
                            android:textColor="#FFFFFF"
                            android:textSize="10sp" />
                    </LinearLayout>
                </RelativeLayout>
            </androidx.cardview.widget.CardView>

            <!-- Loan Card 2: Elena -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="@color/card_surface"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp">

                    <TextView
                        android:id="@+id/lblApplicant2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/manrope_bold"
                        android:letterSpacing="0.1"
                        android:text="APPLICANT"
                        android:textColor="@color/v_text_muted"
                        android:textSize="9sp" />

                    <TextView
                        android:id="@+id/tvApplicant2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/lblApplicant2"
                        android:layout_marginTop="4dp"
                        android:fontFamily="@font/manrope_bold"
                        android:text="Elena Rothschild"
                        android:textColor="@color/v_text_dark"
                        android:textSize="15sp" />

                    <TextView
                        android:id="@+id/lblRequested2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:fontFamily="@font/manrope_bold"
                        android:letterSpacing="0.1"
                        android:text="REQUESTED"
                        android:textColor="@color/v_text_muted"
                        android:textSize="9sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/lblRequested2"
                        android:layout_alignParentEnd="true"
                        android:layout_marginTop="2dp"
                        android:fontFamily="@font/manrope_bold"
                        android:text="$1,200,000.00"
                        android:textColor="@color/brand_blue"
                        android:textSize="17sp" />

                    <View
                        android:id="@+id/dividerLine2"
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_below="@id/tvApplicant2"
                        android:layout_marginTop="20dp"
                        android:background="@color/v_page_bg" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/dividerLine2"
                        android:layout_marginTop="20dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/manrope_bold"
                                android:letterSpacing="0.1"
                                android:text="SCORE"
                                android:textColor="@color/v_text_muted"
                                android:textSize="8sp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/manrope_bold"
                                android:text="795"
                                android:textColor="@color/v_text_dark"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/btnRejectElena"
                            android:layout_width="80dp"
                            android:layout_height="32dp"
                            android:layout_marginEnd="8dp"
                            android:background="@drawable/bg_btn_reject"
                            android:fontFamily="@font/manrope_bold"
                            android:gravity="center"
                            android:letterSpacing="0.05"
                            android:text="REJECT"
                            android:textColor="#FFFFFF"
                            android:textSize="10sp" />

                        <TextView
                            android:id="@+id/btnAcceptElena"
                            android:layout_width="80dp"
                            android:layout_height="32dp"
                            android:background="@drawable/bg_btn_primary"
                            android:fontFamily="@font/manrope_bold"
                            android:gravity="center"
                            android:letterSpacing="0.05"
                            android:text="ACCEPT"
                            android:textColor="#FFFFFF"
                            android:textSize="10sp" />
                    </LinearLayout>
                </RelativeLayout>
            </androidx.cardview.widget.CardView>

            <!-- Payout Verifications Section -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:paddingHorizontal="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:fontFamily="@font/manrope_bold"
                    android:text="Payout Verifications"
                    android:textColor="@color/v_text_dark"
                    android:textSize="20sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:fontFamily="@font/manrope_bold"
                    android:letterSpacing="0.05"
                    android:text="LIQUIDITY CONT..."
                    android:textColor="@color/v_text_muted"
                    android:textSize="8sp"
                    android:textStyle="bold" />
            </RelativeLayout>

            <!-- Verification Table -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="@color/card_surface"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Headers -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@color/v_page_bg"
                        android:orientation="horizontal"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="12dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="3.4"
                            android:fontFamily="@font/manrope_bold"
                            android:letterSpacing="0.1"
                            android:text="RECIPIENT"
                            android:textColor="@color/v_text_mid"
                            android:textSize="8sp" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1.0"
                            android:fontFamily="@font/manrope_bold"
                            android:gravity="end"
                            android:letterSpacing="0.1"
                            android:text="ACTION"
                            android:textColor="@color/v_text_mid"
                            android:textSize="8sp" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/v_page_bg" />

                    <!-- Row 1 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="16dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="3.4"
                            android:fontFamily="@font/manrope_bold"
                            android:lineSpacingExtra="2dp"
                            android:text="Alexander Sterling"
                            android:textColor="@color/v_text_dark"
                            android:textSize="15sp" />

                        <TextView
                            android:id="@+id/btnViewAlexander"
                            android:layout_width="0dp"
                            android:layout_height="36dp"
                            android:layout_weight="1.0"
                            android:background="@drawable/bg_btn_primary"
                            android:fontFamily="@font/manrope_bold"
                            android:gravity="center"
                            android:letterSpacing="0.05"
                            android:text="VIEW"
                            android:textColor="#FFFFFF"
                            android:textSize="10sp" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/v_page_bg" />

                    <!-- Row 2 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="16dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="3.4"
                            android:fontFamily="@font/manrope_bold"
                            android:lineSpacingExtra="2dp"
                            android:text="Victoria Windward"
                            android:textColor="@color/v_text_dark"
                            android:textSize="15sp" />

                        <TextView
                            android:id="@+id/btnViewVictoria"
                            android:layout_width="0dp"
                            android:layout_height="36dp"
                            android:layout_weight="1.0"
                            android:background="@drawable/bg_btn_primary"
                            android:fontFamily="@font/manrope_bold"
                            android:gravity="center"
                            android:letterSpacing="0.05"
                            android:text="VIEW"
                            android:textColor="#FFFFFF"
                            android:textSize="10sp" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/v_page_bg" />

                    <!-- Row 3 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="16dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="3.4"
                            android:fontFamily="@font/manrope_bold"
                            android:lineSpacingExtra="2dp"
                            android:text="Dr. Aris Thorne"
                            android:textColor="@color/v_text_dark"
                            android:textSize="15sp" />

                        <TextView
                            android:id="@+id/btnViewAris"
                            android:layout_width="0dp"
                            android:layout_height="36dp"
                            android:layout_weight="1.0"
                            android:background="@drawable/bg_btn_primary"
                            android:fontFamily="@font/manrope_bold"
                            android:gravity="center"
                            android:letterSpacing="0.05"
                            android:text="VIEW"
                            android:textColor="#FFFFFF"
                            android:textSize="10sp" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Footer Note -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:gravity="center"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:src="@drawable/ic_shield_auth"
                    app:tint="@color/v_text_muted" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:fontFamily="@font/manrope_bold"
                    android:letterSpacing="0.05"
                    android:text="SECURED BY SAVE VAULT TECHNOLOGY"
                    android:textColor="@color/v_text_muted"
                    android:textSize="9sp" />
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
