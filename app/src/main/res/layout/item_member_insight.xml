<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingVertical="12dp"
    android:gravity="center_vertical">

    <TextView
        android:id="@+id/tvInsightName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1.2"
        android:fontFamily="@font/manrope_bold"
        android:text="Julia Vance"
        android:textColor="@color/v_text_dark"
        android:textSize="13sp" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1.2"
        android:gravity="center"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/imgTrend"
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:layout_marginEnd="4dp"
            android:src="@drawable/ic_diagonal_arrow"
            app:tint="#10B981" />

        <TextView
            android:id="@+id/tvReliabilityScore"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/manrope_bold"
            android:text="98.4"
            android:textColor="#10B981"
            android:textSize="12sp" />
    </LinearLayout>

    <FrameLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="0.8">

        <TextView
            android:id="@+id/tvTierBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:background="@drawable/bg_tier_vip"
            android:fontFamily="@font/manrope_bold"
            android:paddingHorizontal="10dp"
            android:paddingVertical="2dp"
            android:text="VIP"
            android:textColor="@color/brand_blue"
            android:textSize="10sp" />
    </FrameLayout>

    <TextView
        android:id="@+id/tvLastPayDate"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:fontFamily="@font/manrope_medium"
        android:gravity="end"
        android:text="Oct 12"
        android:textColor="@color/v_text_mid"
        android:textSize="12sp" />

</LinearLayout>
