<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:clipChildren="false">

    <!-- CONFETTI -->
    <FrameLayout
        android:id="@+id/confettiContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipChildren="false">

        <View android:layout_width="18dp" android:layout_height="7dp" android:background="#EF4444" android:rotation="35" android:layout_gravity="top|start" android:layout_marginStart="28dp" android:layout_marginTop="52dp"/>
        <View android:layout_width="10dp" android:layout_height="10dp" android:background="@drawable/shape_circle_blue" android:backgroundTint="#3B82F6" android:layout_gravity="top|start" android:layout_marginStart="95dp" android:layout_marginTop="22dp"/>
        <View android:layout_width="14dp" android:layout_height="6dp" android:background="#06B6D4" android:rotation="-18" android:layout_gravity="top|start" android:layout_marginStart="14dp" android:layout_marginTop="95dp"/>
        <View android:layout_width="12dp" android:layout_height="12dp" android:background="@drawable/shape_circle_blue" android:backgroundTint="#EC4899" android:layout_gravity="top|start" android:layout_marginStart="52dp" android:layout_marginTop="138dp"/>
        <View android:layout_width="16dp" android:layout_height="6dp" android:background="#22C55E" android:rotation="22" android:layout_gravity="top|start" android:layout_marginStart="140dp" android:layout_marginTop="48dp"/>
        <View android:layout_width="8dp" android:layout_height="8dp" android:background="@drawable/shape_circle_blue" android:backgroundTint="#EF4444" android:layout_gravity="top|start" android:layout_marginStart="175dp" android:layout_marginTop="18dp"/>
        <View android:layout_width="10dp" android:layout_height="10dp" android:background="@drawable/shape_circle_blue" android:backgroundTint="#06B6D4" android:layout_gravity="top|start" android:layout_marginStart="22dp" android:layout_marginTop="190dp"/>

        <View android:layout_width="18dp" android:layout_height="7dp" android:background="#3B82F6" android:rotation="-28" android:layout_gravity="top|end" android:layout_marginEnd="35dp" android:layout_marginTop="28dp"/>
        <View android:layout_width="14dp" android:layout_height="14dp" android:background="@drawable/shape_circle_blue" android:backgroundTint="#EF4444" android:layout_gravity="top|end" android:layout_marginEnd="110dp" android:layout_marginTop="14dp"/>
        <View android:layout_width="10dp" android:layout_height="10dp" android:background="@drawable/shape_circle_blue" android:backgroundTint="#06B6D4" android:layout_gravity="top|end" android:layout_marginEnd="18dp" android:layout_marginTop="78dp"/>
        <View android:layout_width="16dp" android:layout_height="6dp" android:background="#EC4899" android:rotation="15" android:layout_gravity="top|end" android:layout_marginEnd="68dp" android:layout_marginTop="105dp"/>
        <View android:layout_width="12dp" android:layout_height="12dp" android:background="@drawable/shape_circle_blue" android:backgroundTint="#22C55E" android:layout_gravity="top|end" android:layout_marginEnd="145dp" android:layout_marginTop="72dp"/>
        <View android:layout_width="8dp" android:layout_height="8dp" android:background="@drawable/shape_circle_blue" android:backgroundTint="#F97316" android:layout_gravity="top|end" android:layout_marginEnd="28dp" android:layout_marginTop="145dp"/>

        <ImageView android:layout_width="16dp" android:layout_height="16dp" android:src="@drawable/ic_star" app:tint="#EF4444" android:layout_gravity="top|start" android:layout_marginStart="42dp" android:layout_marginTop="30dp"/>
        <ImageView android:layout_width="14dp" android:layout_height="14dp" android:src="@drawable/ic_star" app:tint="#3B82F6" android:layout_gravity="top|start" android:layout_marginStart="130dp" android:layout_marginTop="155dp"/>
        <ImageView android:layout_width="16dp" android:layout_height="16dp" android:src="@drawable/ic_star" app:tint="#06B6D4" android:layout_gravity="top|end" android:layout_marginEnd="55dp" android:layout_marginTop="55dp"/>
        <ImageView android:layout_width="14dp" android:layout_height="14dp" android:src="@drawable/ic_star" app:tint="#EC4899" android:layout_gravity="top|end" android:layout_marginEnd="130dp" android:layout_marginTop="135dp"/>

    </FrameLayout>

    <!-- CONTENT -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingHorizontal="28dp">

        <RelativeLayout
            android:id="@+id/navBar"
            android:layout_width="match_parent" android:layout_height="64dp">
            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="44dp" android:layout_height="44dp"
                android:layout_centerVertical="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="10dp"
                android:src="@drawable/ic_arrow_left"
                app:tint="@color/v_text_dark" />
            <TextView
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:fontFamily="@font/manrope_bold"
                android:text="Support"
                android:textColor="@color/v_text_dark"
                android:textSize="16sp" />
        </RelativeLayout>

        <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />

        <!-- Blue circle icon -->
        <FrameLayout
            android:layout_width="100dp" android:layout_height="100dp"
            android:background="@drawable/shape_circle_blue"
            android:backgroundTint="@color/brand_blue"
            android:elevation="4dp">
            <ImageView
                android:layout_width="50dp" android:layout_height="50dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_support_filled"
                app:tint="#FFFFFF" />
        </FrameLayout>

        <TextView
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:fontFamily="@font/manrope_bold"
            android:gravity="center"
            android:text="Ticket Submitted&#10;Successfully!"
            android:textColor="@color/v_text_dark"
            android:textSize="26sp" />

        <TextView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:fontFamily="@font/manrope"
            android:gravity="center"
            android:lineSpacingExtra="4dp"
            android:text="Our team has received your request. We'll get back to you within 24 hours."
            android:textColor="@color/v_text_mid"
            android:textSize="14sp" />

        <!-- Ticket ID row -->
        <LinearLayout
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_badge_lavender"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp">
            <TextView
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:fontFamily="@font/manrope"
                android:text="Ticket "
                android:textColor="@color/v_text_mid"
                android:textSize="13sp" />
            <TextView
                android:id="@+id/tvTicketId"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:fontFamily="@font/manrope_bold"
                android:text="#—"
                android:textColor="@color/brand_blue"
                android:textSize="13sp" />
            <TextView
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:fontFamily="@font/manrope"
                android:text="· "
                android:textColor="@color/v_text_mid"
                android:textSize="13sp" />
            <TextView
                android:id="@+id/tvCategoryName"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:fontFamily="@font/manrope_bold"
                android:text="—"
                android:textColor="@color/brand_blue"
                android:textSize="13sp" />
        </LinearLayout>

        <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />

    </LinearLayout>

    <!-- BUTTONS -->
    <LinearLayout
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="#FFFFFF"
        android:elevation="8dp"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="20dp"
        android:paddingBottom="32dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDone"
            android:layout_width="match_parent" android:layout_height="60dp"
            android:fontFamily="@font/manrope_bold"
            android:insetTop="0dp" android:insetBottom="0dp"
            android:text="Back to Home"
            android:textAllCaps="false" android:textSize="16sp"
            app:backgroundTint="@color/brand_blue"
            app:cornerRadius="30dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnStatus"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent" android:layout_height="56dp"
            android:layout_marginTop="10dp"
            android:fontFamily="@font/manrope_bold"
            android:insetTop="0dp" android:insetBottom="0dp"
            android:text="Track Ticket Status"
            android:textAllCaps="false" android:textColor="@color/brand_blue" android:textSize="15sp"
            app:cornerRadius="30dp"
            app:strokeColor="@color/brand_blue" app:strokeWidth="1.5dp" />

    </LinearLayout>

</FrameLayout>
