<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/v_page_bg">

    <!-- HEADER -->
    <RelativeLayout
        android:id="@+id/headerLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/card_surface"
        android:elevation="4dp"
        android:paddingHorizontal="16dp"
        android:paddingVertical="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/toolbar"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:background="@drawable/bg_input_bg_circle"
            android:padding="10dp"
            android:src="@drawable/ic_arrow_back"
            app:tint="@color/v_text_dark" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:fontFamily="@font/poppins"
            android:text="Member Profile"
            android:textColor="@color/v_text_dark"
            android:textSize="@dimen/text_size_normal" />
    </RelativeLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingBottom="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/headerLayout">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="16dp">

            <!-- ── Premium Hero Card ── -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="6dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_card_premium_blue"
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    android:padding="22dp">

                    <!-- Avatar -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="88dp"
                        android:layout_height="88dp"
                        app:cardBackgroundColor="@color/permanent_white"
                        app:cardCornerRadius="44dp"
                        app:cardElevation="0dp"
                        app:strokeColor="#33FFFFFF"
                        app:strokeWidth="3dp">

                        <ImageView
                            android:id="@+id/ivProfileAvatar"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:visibility="gone" />

                        <TextView
                            android:id="@+id/tvProfileInitials"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:fontFamily="@font/manrope_bold"
                            android:gravity="center"
                            android:textColor="@color/brand_blue"
                            android:textSize="30sp"
                            tools:text="JD" />
                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:id="@+id/tvMemberName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:fontFamily="@font/poppins"
                        android:textColor="@color/permanent_white"
                        android:textSize="22sp"
                        tools:text="Jane Doe" />

                    <TextView
                        android:id="@+id/tvMemberRole"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:alpha="0.85"
                        android:fontFamily="@font/montserrat"
                        android:textColor="@color/permanent_white"
                        android:textSize="13sp"
                        tools:text="Joined Jan 2026" />

                    <!-- Badges -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:gravity="center"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tvBadgeRole"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="8dp"
                            android:background="@drawable/bg_badge_success"
                            android:backgroundTint="#33FFFFFF"
                            android:fontFamily="@font/manrope_bold"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="5dp"
                            android:textColor="@color/permanent_white"
                            android:textSize="10sp"
                            tools:text="MEMBER" />

                        <TextView
                            android:id="@+id/tvBadgeReliability"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_badge_success"
                            android:backgroundTint="#33FFFFFF"
                            android:fontFamily="@font/manrope_bold"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="5dp"
                            android:textColor="@color/permanent_white"
                            android:textSize="10sp"
                            tools:text="RELIABLE" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="18dp"
                        android:background="@color/divider_color" />

                    <!-- Headline stats inside hero -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvTotalContributed"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/poppins"
                                android:textColor="@color/permanent_white"
                                android:textSize="@dimen/text_size_large"
                                tools:text="UGX 1,200,000" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:alpha="0.8"
                                android:fontFamily="@font/montserrat"
                                android:text="Total saved"
                                android:textColor="@color/permanent_white"
                                android:textSize="@dimen/text_size_xs" />
                        </LinearLayout>

                        <View
                            android:layout_width="1dp"
                            android:layout_height="match_parent"
                            android:background="@color/divider_color" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvStreak"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/poppins"
                                android:textColor="@color/permanent_white"
                                android:textSize="@dimen/text_size_large"
                                tools:text="1" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:alpha="0.8"
                                android:fontFamily="@font/montserrat"
                                android:text="Active loans"
                                android:textColor="@color/permanent_white"
                                android:textSize="@dimen/text_size_xs" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── Active Loan Details (only when a loan exists) ── -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cvActiveLoanDetails"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:visibility="gone"
                app:cardBackgroundColor="@color/card_surface"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:fontFamily="@font/manrope_bold"
                            android:text="Active Loan Details"
                            android:textColor="@color/v_text_dark"
                            android:textSize="16sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:background="@drawable/bg_badge_success"
                            android:backgroundTint="#FFF7ED"
                            android:fontFamily="@font/manrope_bold"
                            android:paddingHorizontal="10dp"
                            android:paddingVertical="3dp"
                            android:text="IN PROGRESS"
                            android:textColor="#D97706"
                            android:textSize="10sp" />
                    </RelativeLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="14dp"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/manrope_bold"
                                android:letterSpacing="0.06"
                                android:text="PRINCIPAL AMOUNT"
                                android:textColor="@color/v_text_muted"
                                android:textSize="10sp" />

                            <TextView
                                android:id="@+id/tvCreditScore"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:fontFamily="@font/manrope_bold"
                                android:textColor="@color/v_text_dark"
                                android:textSize="20sp"
                                tools:text="UGX 500,000" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/manrope_bold"
                                android:letterSpacing="0.06"
                                android:text="INTEREST RATE"
                                android:textColor="@color/v_text_muted"
                                android:textSize="10sp" />

                            <TextView
                                android:id="@+id/tvReliability"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:fontFamily="@font/manrope_bold"
                                android:textColor="@color/brand_blue"
                                android:textSize="20sp"
                                tools:text="10%" />
                        </LinearLayout>
                    </LinearLayout>

                    <ProgressBar
                        android:id="@+id/loanProgressBar"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="8dp"
                        android:layout_marginBottom="6dp"
                        android:max="100"
                        android:progress="0"
                        android:progressBackgroundTint="#EBF3FD"
                        android:progressTint="@color/brand_blue" />

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="14dp">

                        <TextView
                            android:id="@+id/tvLoanPaid"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/manrope_medium"
                            android:textColor="@color/v_text_mid"
                            android:textSize="12sp"
                            tools:text="Paid: UGX 0" />

                        <TextView
                            android:id="@+id/tvLoanRemaining"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:fontFamily="@font/manrope_medium"
                            android:textColor="@color/v_text_mid"
                            android:textSize="12sp"
                            tools:text="Remaining: UGX 550,000" />
                    </RelativeLayout>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:cardBackgroundColor="@color/v_page_bg"
                        app:cardCornerRadius="10dp"
                        app:cardElevation="0dp"
                        app:strokeColor="@color/divider_color"
                        app:strokeWidth="1dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:padding="12dp">

                            <com.google.android.material.card.MaterialCardView
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:layout_marginEnd="12dp"
                                app:cardBackgroundColor="#EBF3FD"
                                app:cardCornerRadius="8dp"
                                app:cardElevation="0dp"
                                app:strokeWidth="0dp">

                                <ImageView
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_calendar_month"
                                    app:tint="@color/brand_blue" />
                            </com.google.android.material.card.MaterialCardView>

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="@font/manrope_bold"
                                    android:letterSpacing="0.06"
                                    android:text="NEXT DUE DATE"
                                    android:textColor="@color/v_text_muted"
                                    android:textSize="10sp" />

                                <TextView
                                    android:id="@+id/tvLoanDueDate"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="@font/manrope_bold"
                                    android:textColor="@color/v_text_dark"
                                    android:textSize="14sp"
                                    tools:text="Aug 15, 2026" />
                            </LinearLayout>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── Payment History ── -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/card_surface"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/manrope_bold"
                        android:text="Payment History"
                        android:textColor="@color/v_text_dark"
                        android:textSize="16sp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="12dp"
                        android:layout_marginBottom="4dp"
                        android:background="@color/v_input_bg" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvTransactions"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false"
                        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

                    <TextView
                        android:id="@+id/tvEmptyHistory"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/manrope_medium"
                        android:gravity="center"
                        android:paddingVertical="24dp"
                        android:text="No payment history yet"
                        android:textColor="@color/v_text_muted"
                        android:textSize="13sp"
                        android:visibility="gone" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── Admin Actions (admins only) ── -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cvAdminActions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/card_surface"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:fontFamily="@font/manrope_bold"
                        android:text="Manage Member"
                        android:textColor="@color/v_text_dark"
                        android:textSize="16sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnPromoteMember"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:fontFamily="@font/manrope_bold"
                            android:text="Promote"
                            android:textAllCaps="false"
                            android:textColor="@android:color/white"
                            android:textSize="15sp"
                            app:backgroundTint="@color/brand_blue"
                            app:cornerRadius="12dp"
                            app:icon="@null" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnDemoteMember"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            android:fontFamily="@font/manrope_bold"
                            android:text="Demote"
                            android:textAllCaps="false"
                            android:textColor="@color/v_text_mid"
                            android:textSize="15sp"
                            app:cornerRadius="12dp"
                            app:icon="@null"
                            app:strokeColor="@color/divider_color"
                            app:strokeWidth="1.5dp" />
                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnDeleteMember"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="8dp"
                        android:fontFamily="@font/manrope_bold"
                        android:text="Remove Member"
                        android:textAllCaps="false"
                        android:textColor="@color/red_primary"
                        android:textSize="15sp"
                        app:cornerRadius="12dp"
                        app:icon="@null"
                        app:strokeColor="@color/red_primary"
                        app:strokeWidth="1.5dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
