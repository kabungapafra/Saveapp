<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="76dp"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    android:id="@+id/cardRoot"
    app:cardBackgroundColor="#FFFFFF"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp">

        <FrameLayout
            android:layout_width="52dp"
            android:layout_height="52dp">
            <TextView
                android:id="@+id/tvAvatar"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/circle_background"
                android:gravity="center"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold"
                tools:text="MT"
                tools:backgroundTint="#2D2D2D"/>
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="14dp">

            <TextView
                android:id="@+id/tvName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                tools:text="Marcus Thorne"
                android:textColor="#1A1D2E"
                android:textSize="16sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                tools:text="ELIGIBLE"
                tools:textColor="#16A34A"
                tools:backgroundTint="#DCFCE7"
                android:background="@drawable/bg_badge_pill"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                android:paddingHorizontal="10dp"
                android:paddingVertical="3dp"
                android:layout_marginTop="5dp"/>
        </LinearLayout>

        <FrameLayout
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginStart="14dp">

            <!-- Empty Circle -->
            <View
                android:id="@+id/viewUnselected"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_circle_outline_gray"
                android:visibility="visible"/>

            <!-- Checked Blue Circle -->
            <ImageView
                android:id="@+id/imgSelected"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_gravity="center"
                android:background="@drawable/circle_background"
                android:backgroundTint="#2563EB"
                android:src="@drawable/ic_check"
                app:tint="#FFFFFF"
                android:padding="6dp"
                android:elevation="4dp"
                android:visibility="gone"/>

            <!-- Locked Icon (No Circle) -->
            <ImageView
                android:id="@+id/imgLocked"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_lock"
                app:tint="#C4C9D4"
                android:visibility="gone"/>
        </FrameLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
