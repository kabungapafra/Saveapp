<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingHorizontal="16dp"
    android:paddingVertical="10dp">

    <!-- Avatar circle with initials -->
    <TextView
        android:id="@+id/tvMemberInitials"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:gravity="center"
        android:background="@drawable/bg_avatar_circle"
        android:backgroundTint="#E2E8F0"
        android:text="?"
        android:textColor="#475569"
        android:textSize="12sp"
        android:textStyle="bold" />

    <!-- Name + role -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="10dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvMemberName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Member Name"
            android:textColor="@color/dashboard_text_primary"
            android:textSize="13sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/tvMemberPhone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="1dp"
            android:text="--"
            android:textColor="@color/dashboard_text_secondary"
            android:textSize="11sp" />
    </LinearLayout>

    <!-- Contribution status badge -->
    <TextView
        android:id="@+id/tvMemberContribStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_badge_success"
        android:paddingHorizontal="10dp"
        android:paddingVertical="3dp"
        android:text="In Pool"
        android:textColor="#065F46"
        android:textSize="10sp"
        android:textStyle="bold" />

    <!-- Divider (drawn as bottom border via next item; use view below instead) -->
</LinearLayout>
