<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#ECEEF2"
    android:clipChildren="false"
    android:clipToPadding="false">

    <!-- HEADER BAR -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/header_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp"
        app:layout_constraintTop_toTopOf="parent">

        <FrameLayout
            android:id="@+id/back_btn"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_neumorphic_circle_back"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">
            
            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_arrow_back"
                app:tint="@color/v_text_dark" />
        </FrameLayout>

        <TextView
            android:id="@+id/header_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/manrope_bold"
            android:text="Security"
            android:textColor="@color/v_text_dark"
            android:textSize="17sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- HERO ILLUSTRATION -->

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/hero_illustration"
        android:layout_width="290dp"
        android:layout_height="290dp"
        android:layout_marginTop="156dp"
        android:background="@drawable/bg_outer_security_card"
        android:clipChildren="false"
        android:clipToPadding="false"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.495"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/header_bar">

        <!-- LAYER 2 RECESSED WELL (White space) -->
        <FrameLayout
            android:id="@+id/inner_card"
            android:layout_width="160dp"
            android:layout_height="160dp"
            android:background="@drawable/bg_inner_security_recessed"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <!-- MAIN SHIELD ICON -->
            <ImageView
                android:id="@+id/main_shield"
                android:layout_width="70dp"
                android:layout_height="80dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_shield_check" />
        </FrameLayout>

        <!-- FLOATING BADGE TOP LEFT (Lock) - Anchored to Inner Well -->
        <FrameLayout
            android:id="@+id/badge_lock"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginStart="-22dp"
            android:layout_marginTop="-22dp"
            android:background="@drawable/bg_security_badge"
            app:layout_constraintStart_toStartOf="@id/inner_card"
            app:layout_constraintTop_toTopOf="@id/inner_card">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_lock"
                app:tint="#F4A228" />
        </FrameLayout>

        <!-- FLOATING BADGE BOTTOM RIGHT (Mini Shield) - Anchored to Inner Well -->
        <FrameLayout
            android:id="@+id/badge_mini_shield"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginEnd="-20dp"
            android:layout_marginBottom="-20dp"
            android:background="@drawable/bg_security_badge"
            app:layout_constraintBottom_toBottomOf="@id/inner_card"
            app:layout_constraintEnd_toEndOf="@id/inner_card">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_shield"
                app:tint="#215DA1" />
        </FrameLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <LinearLayout
        android:id="@+id/text_section"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="28dp"
        android:layout_marginTop="42dp"
        android:gravity="center"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@id/hero_illustration">

        <TextView
            android:id="@+id/title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/manrope_bold"
            android:gravity="center"
            android:letterSpacing="-0.015"
            android:text="@string/bank_grade_security"
            android:textColor="@color/v_text_dark"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/subtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:fontFamily="@font/manrope_medium"
            android:gravity="center"
            android:lineSpacingMultiplier="1.5"
            android:text="@string/security_description"
            android:textColor="@color/v_text_mid"
            android:textSize="15sp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
