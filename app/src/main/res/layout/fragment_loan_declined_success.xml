<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:clipChildren="false">

    <!-- Muted confetti for declined (grey/red tones) -->
    <FrameLayout
        android:id="@+id/confettiContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipChildren="false">

        <View android:layout_width="18dp" android:layout_height="7dp" android:background="#EF4444" android:rotation="35" android:layout_gravity="top|start" android:layout_marginStart="28dp" android:layout_marginTop="52dp" android:alpha="0.4"/>
        <View android:layout_width="10dp" android:layout_height="10dp" android:background="@drawable/shape_circle_blue" android:backgroundTint="#CBD5E1" android:layout_gravity="top|start" android:layout_marginStart="95dp" android:layout_marginTop="22dp"/>
        <View android:layout_width="14dp" android:layout_height="6dp" android:background="#94A3B8" android:rotation="-18" android:layout_gravity="top|start" android:layout_marginStart="14dp" android:layout_marginTop="95dp"/>
        <View android:layout_width="12dp" android:layout_height="12dp" android:background="@drawable/shape_circle_blue" android:backgroundTint="#EF4444" android:layout_gravity="top|start" android:layout_marginStart="52dp" android:layout_marginTop="138dp" android:alpha="0.4"/>
        <View android:layout_width="16dp" android:layout_height="6dp" android:background="#CBD5E1" android:rotation="22" android:layout_gravity="top|start" android:layout_marginStart="140dp" android:layout_marginTop="48dp"/>
        <View android:layout_width="8dp" android:layout_height="8dp" android:background="@drawable/shape_circle_blue" android:backgroundTint="#94A3B8" android:layout_gravity="top|start" android:layout_marginStart="175dp" android:layout_marginTop="18dp"/>

        <View android:layout_width="18dp" android:layout_height="7dp" android:background="#94A3B8" android:rotation="-28" android:layout_gravity="top|end" android:layout_marginEnd="35dp" android:layout_marginTop="28dp"/>
        <View android:layout_width="14dp" android:layout_height="14dp" android:background="@drawable/shape_circle_blue" android:backgroundTint="#EF4444" android:layout_gravity="top|end" android:layout_marginEnd="110dp" android:layout_marginTop="14dp" android:alpha="0.4"/>
        <View android:layout_width="10dp" android:layout_height="10dp" android:background="@drawable/shape_circle_blue" android:backgroundTint="#CBD5E1" android:layout_gravity="top|end" android:layout_marginEnd="18dp" android:layout_marginTop="78dp"/>
        <View android:layout_width="16dp" android:layout_height="6dp" android:background="#94A3B8" android:rotation="15" android:layout_gravity="top|end" android:layout_marginEnd="68dp" android:layout_marginTop="105dp"/>
        <View android:layout_width="12dp" android:layout_height="12dp" android:background="@drawable/shape_circle_blue" android:backgroundTint="#EF4444" android:layout_gravity="top|end" android:layout_marginEnd="145dp" android:layout_marginTop="72dp" android:alpha="0.35"/>

    </FrameLayout>

    <!-- CONTENT -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingHorizontal="28dp">

        <RelativeLayout android:layout_width="match_parent" android:layout_height="64dp">
            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="44dp" android:layout_height="44dp"
                android:layout_centerVertical="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="10dp"
                android:src="@drawable/ic_arrow_back"
                app:tint="@color/v_text_dark" />
            <View android:id="@+id/headerDivider" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
        </RelativeLayout>

        <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />

        <FrameLayout
            android:id="@+id/declinedCircle"
            android:layout_width="100dp" android:layout_height="100dp"
            android:background="@drawable/shape_circle_blue"
            android:backgroundTint="#EF4444"
            android:elevation="4dp">
            <ImageView
                android:layout_width="46dp" android:layout_height="46dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_close"
                app:tint="#FFFFFF" />
        </FrameLayout>

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:fontFamily="@font/manrope_bold"
            android:gravity="center"
            android:text="Loan Request&#10;Declined"
            android:textColor="@color/v_text_dark"
            android:textSize="26sp" />

        <TextView
            android:id="@+id/tvDescription"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:fontFamily="@font/manrope"
            android:gravity="center"
            android:lineSpacingExtra="4dp"
            android:text="The loan request has been declined. The member will be notified."
            android:textColor="@color/v_text_mid"
            android:textSize="14sp" />

        <!-- Decline reason chip -->
        <LinearLayout
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_badge_red"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp">
            <TextView
                android:id="@+id/tvDeclineReason"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:fontFamily="@font/manrope_bold"
                android:text="—"
                android:textColor="#B91C1C"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- Data stubs -->
        <TextView android:id="@+id/tvBorrowerName" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
        <TextView android:id="@+id/tvAmount" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
        <TextView android:id="@+id/tvTransactionId" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>

        <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />

    </LinearLayout>

    <!-- BUTTON -->
    <FrameLayout
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="#FFFFFF"
        android:elevation="8dp"
        android:padding="24dp">
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnReturn"
            android:layout_width="match_parent" android:layout_height="60dp"
            android:fontFamily="@font/manrope_bold"
            android:insetTop="0dp" android:insetBottom="0dp"
            android:text="Back to Loans"
            android:textAllCaps="false" android:textSize="16sp"
            app:backgroundTint="@color/brand_blue"
            app:cornerRadius="30dp" />
    </FrameLayout>

</FrameLayout>
