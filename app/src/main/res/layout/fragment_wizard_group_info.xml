<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/v_page_bg"
    android:fillViewport="true"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Blue header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/brand_blue"
            android:orientation="vertical"
            android:paddingTop="52dp"
            android:paddingBottom="28dp"
            android:paddingHorizontal="24dp">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/bg_avatar_circle"
                android:backgroundTint="#2EFFFFFF"
                android:padding="8dp"
                android:src="@drawable/ic_arrow_back"
                app:tint="#FFFFFF" />

            <!-- Step dots -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:orientation="horizontal">

                <View android:layout_width="20dp" android:layout_height="6dp"
                    android:background="#FFFFFF" android:layout_marginEnd="5dp" />
                <View android:layout_width="8dp" android:layout_height="6dp"
                    android:background="#4DFFFFFF" android:layout_marginEnd="5dp" />
                <View android:layout_width="8dp" android:layout_height="6dp"
                    android:background="#4DFFFFFF" android:layout_marginEnd="5dp" />
                <View android:layout_width="8dp" android:layout_height="6dp"
                    android:background="#4DFFFFFF" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:fontFamily="@font/manrope_bold"
                android:text="Group Basics"
                android:textColor="#FFFFFF"
                android:textSize="28sp" />

            <TextView
                android:id="@+id/tvSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="@font/manrope_medium"
                android:text="Give your savings circle a name and currency."
                android:textColor="#B3C8E8"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tvStepIndicator"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="@font/manrope_medium"
                android:text="Step 1 of 5"
                android:textColor="#80FFFFFF"
                android:textSize="12sp" />

        </LinearLayout>

        <!-- Form card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="20dp"
            app:cardBackgroundColor="@color/card_surface"
            app:cardCornerRadius="20dp"
            app:cardElevation="2dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <!-- Group Name -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:fontFamily="@font/manrope_bold"
                    android:text="Group Name"
                    android:textColor="@color/v_text_dark"
                    android:textSize="13sp" />

                <EditText
                    android:id="@+id/etGroupName"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginBottom="24dp"
                    android:background="@drawable/bg_wizard_input_solid"
                    android:fontFamily="@font/manrope_medium"
                    android:hint="e.g. Kampala Savers 2024"
                    android:inputType="textCapWords"
                    android:paddingHorizontal="16dp"
                    android:textColor="@color/v_text_dark"
                    android:textColorHint="@color/v_text_muted"
                    android:textSize="15sp" />

                <!-- Currency -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:fontFamily="@font/manrope_bold"
                    android:text="Currency"
                    android:textColor="@color/v_text_dark"
                    android:textSize="13sp" />

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:background="@drawable/bg_wizard_input_solid">

                    <TextView
                        android:id="@+id/tvCurrencyText"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:fontFamily="@font/manrope_medium"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="16dp"
                        android:text="UGX - Uganda Shillings"
                        android:textColor="@color/v_text_dark"
                        android:textSize="15sp" />

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:layout_gravity="end|center_vertical"
                        android:layout_marginEnd="16dp"
                        android:src="@drawable/ic_chevron_down"
                        app:tint="@color/v_text_muted" />

                    <Spinner
                        android:id="@+id/spinnerCurrency"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@android:color/transparent"
                        android:spinnerMode="dropdown"
                        android:visibility="invisible" />
                </FrameLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
