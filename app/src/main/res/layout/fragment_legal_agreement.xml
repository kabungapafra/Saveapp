<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/v_page_bg">

    <!-- Blue header -->
    <LinearLayout
        android:id="@+id/legalHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/brand_blue"
        android:orientation="vertical"
        android:paddingTop="52dp"
        android:paddingBottom="28dp"
        android:paddingHorizontal="24dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_avatar_circle"
            android:backgroundTint="#2EFFFFFF"
            android:padding="8dp"
            android:src="@drawable/ic_arrow_back"
            app:tint="#FFFFFF" />

        <!-- Step dots -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:orientation="horizontal">
            <View android:layout_width="8dp" android:layout_height="6dp"
                android:background="#4DFFFFFF" android:layout_marginEnd="5dp" />
            <View android:layout_width="8dp" android:layout_height="6dp"
                android:background="#4DFFFFFF" android:layout_marginEnd="5dp" />
            <View android:layout_width="8dp" android:layout_height="6dp"
                android:background="#4DFFFFFF" android:layout_marginEnd="5dp" />
            <View android:layout_width="20dp" android:layout_height="6dp"
                android:background="#FFFFFF" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:fontFamily="@font/manrope_bold"
            android:text="Legal Agreement"
            android:textColor="#FFFFFF"
            android:textSize="28sp" />

        <TextView
            android:id="@+id/tvSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:fontFamily="@font/manrope_medium"
            android:text="Review and accept our terms to continue."
            android:textColor="#B3C8E8"
            android:textSize="13sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:fontFamily="@font/manrope_medium"
            android:text="Step 4 of 5"
            android:textColor="#80FFFFFF"
            android:textSize="12sp" />

    </LinearLayout>

    <!-- Scrollable content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:scrollbars="none"
        android:clipToPadding="false"
        android:paddingBottom="16dp"
        app:layout_constraintTop_toBottomOf="@id/legalHeader"
        app:layout_constraintBottom_toTopOf="@id/bottomActions">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="20dp"
            android:paddingBottom="8dp">

            <!-- Summary highlight card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="#EBF0FF"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="16dp">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_avatar_circle"
                        android:backgroundTint="@color/brand_blue"
                        android:padding="10dp"
                        android:src="@drawable/ic_verified_user"
                        app:tint="#FFFFFF" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:fontFamily="@font/manrope_medium"
                        android:lineSpacingExtra="2dp"
                        android:text="By tapping Accept, you agree to Save's secure data encryption, verification protocols, and responsible usage policies."
                        android:textColor="@color/v_text_dark"
                        android:textSize="13sp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Tab row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_wizard_input_solid"
                android:padding="4dp">

                <TextView
                    android:id="@+id/tabTerms"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@drawable/bg_tab_selected_legal"
                    android:fontFamily="@font/manrope_bold"
                    android:gravity="center"
                    android:text="Terms of Service"
                    android:textColor="@color/brand_blue"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/tabPrivacy"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:fontFamily="@font/manrope_medium"
                    android:gravity="center"
                    android:text="Privacy Policy"
                    android:textColor="@color/v_text_muted"
                    android:textSize="13sp" />

            </LinearLayout>

            <!-- Content card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/card_surface"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="22dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/manrope_bold"
                        android:letterSpacing="0.07"
                        android:text="1. ACCEPTANCE"
                        android:textColor="@color/brand_blue"
                        android:textSize="11sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:fontFamily="@font/manrope_medium"
                        android:lineSpacingExtra="4dp"
                        android:text="By creating a Save account, you agree to these terms. Our service is designed to help you automate savings through secure bank integrations."
                        android:textColor="@color/v_text_muted"
                        android:textSize="14sp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:layout_marginVertical="18dp"
                        android:background="#F1F5F9" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/manrope_bold"
                        android:letterSpacing="0.07"
                        android:text="2. USER ELIGIBILITY"
                        android:textColor="@color/brand_blue"
                        android:textSize="11sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:fontFamily="@font/manrope_medium"
                        android:lineSpacingExtra="4dp"
                        android:text="You must be at least 18 years of age and a resident of a supported region to use our financial management tools."
                        android:textColor="@color/v_text_muted"
                        android:textSize="14sp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:layout_marginVertical="18dp"
                        android:background="#F1F5F9" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/manrope_bold"
                        android:letterSpacing="0.07"
                        android:text="3. ACCOUNT SECURITY"
                        android:textColor="@color/brand_blue"
                        android:textSize="11sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:fontFamily="@font/manrope_medium"
                        android:lineSpacingExtra="4dp"
                        android:text="You are responsible for maintaining the confidentiality of your login credentials and for all activities that occur under your account."
                        android:textColor="@color/v_text_muted"
                        android:textSize="14sp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:layout_marginVertical="18dp"
                        android:background="#F1F5F9" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/manrope_bold"
                        android:letterSpacing="0.07"
                        android:text="4. LIMITATIONS OF LIABILITY"
                        android:textColor="@color/brand_blue"
                        android:textSize="11sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:fontFamily="@font/manrope_medium"
                        android:lineSpacingExtra="4dp"
                        android:text="To the maximum extent permitted by law, Save App shall not be liable for any indirect, incidental, special, consequential or punitive damages, or any loss of profits or revenues."
                        android:textColor="@color/v_text_muted"
                        android:textSize="14sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:fontFamily="@font/manrope_medium"
                        android:gravity="center"
                        android:text="Last updated: October 24, 2023 · v2.4.1"
                        android:textColor="@color/v_text_muted"
                        android:textSize="11sp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Actions -->
    <LinearLayout
        android:id="@+id/bottomActions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/card_surface"
        android:elevation="8dp"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="24dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAccept"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:fontFamily="@font/manrope_bold"
            android:text="I Accept the Terms"
            android:textAllCaps="false"
            android:textSize="16sp"
            app:backgroundTint="@color/brand_blue"
            app:cornerRadius="16dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:id="@+id/btnDecline"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:fontFamily="@font/manrope_bold"
                android:text="Decline"
                android:textAllCaps="false"
                android:textColor="@color/v_text_muted"
                app:backgroundTint="@color/v_page_bg"
                app:cornerRadius="14dp" />

            <View android:layout_width="10dp" android:layout_height="0dp" />

            <com.google.android.material.button.MaterialButton
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:id="@+id/btnPrint"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:fontFamily="@font/manrope_bold"
                android:text="Print / Save PDF"
                android:textAllCaps="false"
                android:textColor="@color/v_text_muted"
                app:backgroundTint="@color/v_page_bg"
                app:cornerRadius="14dp" />

        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
