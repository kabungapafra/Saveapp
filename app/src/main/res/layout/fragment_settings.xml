<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:scrollbars="none">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="120dp">

            <!-- Blue Header -->
            <View
                android:id="@+id/accountHeader"
                android:layout_width="match_parent"
                android:layout_height="260dp"
                android:background="@drawable/bg_account_header"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- Back Button -->
            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginStart="24dp"
                android:layout_marginTop="24dp"
                android:background="@drawable/bg_circle_white"
                android:backgroundTint="#33FFFFFF"
                android:padding="12dp"
                android:src="@drawable/ic_arrow_back"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:tint="@color/white" />

            <!-- Center Logo -->
            <ImageView
                android:id="@+id/headerLogo"
                android:layout_width="180dp"
                android:layout_height="80dp"
                android:scaleType="fitCenter"
                android:src="@drawable/save_logo"
                app:layout_constraintBottom_toBottomOf="@id/accountHeader"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="@id/accountHeader"
                app:layout_constraintVertical_bias="0.45"
                app:tint="@color/white" />

            <!-- Action Buttons Overlay -->
            <LinearLayout
                android:id="@+id/layoutActionButtons"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:orientation="horizontal"
                app:layout_constraintBottom_toBottomOf="@id/accountHeader"
                app:layout_constraintTop_toBottomOf="@id/accountHeader">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnUpgradePro"
                    android:layout_width="0dp"
                    android:layout_height="72dp"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:backgroundTint="#F25C19"
                    android:fontFamily="@font/manrope_bold"
                    android:text="Upgrade Pro"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    app:cornerRadius="36dp"
                    app:elevation="12dp"
                    app:icon="@drawable/ic_lightning_filled"
                    app:iconPadding="10dp"
                    app:iconSize="24dp"
                    app:iconTint="@color/white" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnReferFriend"
                    android:layout_width="0dp"
                    android:layout_height="72dp"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:backgroundTint="@color/white"
                    android:fontFamily="@font/manrope_bold"
                    android:text="Refer Friend"
                    android:textAllCaps="false"
                    android:textColor="#0F172A"
                    android:textSize="14sp"
                    app:cornerRadius="36dp"
                    app:elevation="12dp"
                    app:icon="@drawable/ic_share_filled"
                    app:iconPadding="10dp"
                    app:iconSize="24dp"
                    app:iconTint="#0F172A"
                    app:strokeColor="#F1F5F9"
                    app:strokeWidth="1dp" />
            </LinearLayout>

            <!-- Account Management Section -->
            <TextView
                android:id="@+id/titleAccountMgmt"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginTop="36dp"
                android:fontFamily="@font/manrope_bold"
                android:text="Account Management"
                android:textColor="#0F172A"
                android:textSize="18sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/layoutActionButtons" />

            <GridLayout
                android:id="@+id/gridAccountMgmt"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="16dp"
                android:columnCount="2"
                app:layout_constraintTop_toBottomOf="@id/titleAccountMgmt">

                <!-- Personal Info Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardPersonal"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_rowWeight="1"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    app:cardBackgroundColor="@color/white"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="2dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="start"
                        android:orientation="vertical"
                        android:padding="24dp">

                        <FrameLayout
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:layout_marginBottom="16dp">

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@drawable/bg_icon_squircle"
                                android:backgroundTint="#EFF6FF" />

                            <ImageView
                                android:layout_width="26dp"
                                android:layout_height="26dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_person"
                                app:tint="#3B82F6" />
                        </FrameLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/manrope_bold"
                            android:text="Personal Info"
                            android:textColor="#1E293B"
                            android:textSize="15sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Scheduled Actions Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardAutomation"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_rowWeight="1"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    app:cardBackgroundColor="@color/white"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="2dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="start"
                        android:orientation="vertical"
                        android:padding="24dp">

                        <FrameLayout
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:layout_marginBottom="16dp">

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@drawable/bg_icon_squircle"
                                android:backgroundTint="#FFF7ED" />

                            <ImageView
                                android:layout_width="26dp"
                                android:layout_height="26dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_clock_orange"
                                app:tint="#F97316" />
                        </FrameLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/manrope_bold"
                            android:text="Scheduled Actions"
                            android:textColor="#1E293B"
                            android:textSize="15sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Wallets Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardBank"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_rowWeight="1"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    app:cardBackgroundColor="@color/white"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="2dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="start"
                        android:orientation="vertical"
                        android:padding="24dp">

                        <FrameLayout
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:layout_marginBottom="16dp">

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@drawable/bg_icon_squircle"
                                android:backgroundTint="#F0FDF4" />

                            <ImageView
                                android:layout_width="26dp"
                                android:layout_height="26dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_wallet_green"
                                app:tint="#22C55E" />
                        </FrameLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/manrope_bold"
                            android:text="Wallets"
                            android:textColor="#1E293B"
                            android:textSize="15sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- General Settings Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardGeneral"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_rowWeight="1"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    app:cardBackgroundColor="@color/white"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="2dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="start"
                        android:orientation="vertical"
                        android:padding="24dp">

                        <FrameLayout
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:layout_marginBottom="16dp">

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@drawable/bg_icon_squircle"
                                android:backgroundTint="#F5F3FF" />

                            <ImageView
                                android:layout_width="26dp"
                                android:layout_height="26dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_gear_purple"
                                app:tint="#8B5CF6" />
                        </FrameLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/manrope_bold"
                            android:text="General Settings"
                            android:textColor="#1E293B"
                            android:textSize="15sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </GridLayout>

            <!-- Support Section -->
            <TextView
                android:id="@+id/titleSupport"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginTop="36dp"
                android:fontFamily="@font/manrope_bold"
                android:text="Support"
                android:textColor="#0F172A"
                android:textSize="18sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/gridAccountMgmt" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/supportCardContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="24dp"
                app:cardElevation="2dp"
                app:layout_constraintTop_toBottomOf="@id/titleSupport"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Help Center -->
                    <RelativeLayout
                        android:id="@+id/rowHelpCenter"
                        android:layout_width="match_parent"
                        android:layout_height="64dp"
                        android:background="?attr/selectableItemBackground"
                        android:paddingHorizontal="20dp">

                        <ImageView
                            android:id="@+id/iconHelp"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_centerVertical="true"
                            android:src="@drawable/ic_help_question"
                            app:tint="#64748B" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:layout_marginStart="16dp"
                            android:layout_toEndOf="@id/iconHelp"
                            android:fontFamily="@font/manrope_bold"
                            android:text="Help Center"
                            android:textColor="#1E293B"
                            android:textSize="15sp" />

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:src="@drawable/ic_chevron_right"
                            app:tint="#CBD5E1" />
                    </RelativeLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#F1F5F9" />

                    <!-- Terms of Service -->
                    <RelativeLayout
                        android:id="@+id/rowTOS"
                        android:layout_width="match_parent"
                        android:layout_height="64dp"
                        android:background="?attr/selectableItemBackground"
                        android:paddingHorizontal="20dp">

                        <ImageView
                            android:id="@+id/iconTOS"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_centerVertical="true"
                            android:src="@drawable/ic_tos_document"
                            app:tint="#64748B" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:layout_marginStart="16dp"
                            android:layout_toEndOf="@id/iconTOS"
                            android:fontFamily="@font/manrope_bold"
                            android:text="Terms of Service"
                            android:textColor="#1E293B"
                            android:textSize="15sp" />

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:src="@drawable/ic_chevron_right"
                            app:tint="#CBD5E1" />
                    </RelativeLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Sign Out Button -->
            <LinearLayout
                android:id="@+id/btnSignOut"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingHorizontal="24dp"
                android:paddingVertical="12dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/supportCardContainer">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_logout_red"
                    app:tint="#EF4444" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:fontFamily="@font/manrope_bold"
                    android:text="Sign Out"
                    android:textColor="#EF4444"
                    android:textSize="18sp" />
            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
