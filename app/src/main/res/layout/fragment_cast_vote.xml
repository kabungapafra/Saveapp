<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/v_page_bg">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/contentScroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="100dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ── HERO HEADER ─────────────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_gradient_blue_card"
                android:orientation="vertical"
                android:paddingHorizontal="24dp"
                android:paddingTop="52dp"
                android:paddingBottom="28dp">

                <!-- Top bar: close + info -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:layout_marginBottom="24dp">

                    <ImageView
                        android:id="@+id/btnClose"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/bg_circle_white_border"
                        android:padding="8dp"
                        android:src="@drawable/ic_close"
                        android:clickable="true"
                        android:focusable="true"
                        app:tint="#FFFFFF" />

                    <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1"/>

                    <ImageView
                        android:id="@+id/btnInfo"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/bg_circle_white_border"
                        android:padding="8dp"
                        android:src="@drawable/ic_info"
                        android:clickable="true"
                        android:focusable="true"
                        app:tint="#FFFFFF" />
                </LinearLayout>

                <!-- Election label -->
                <TextView
                    android:id="@+id/tvGroupName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_circle_white_border"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="5dp"
                    android:fontFamily="@font/manrope_bold"
                    android:text="ACTIVE BALLOT"
                    android:textColor="#FFFFFF"
                    android:textSize="10sp"
                    android:alpha="0.85"
                    android:layout_marginBottom="12dp" />

                <!-- Poll title -->
                <TextView
                    android:id="@+id/tvPollTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/manrope_bold"
                    android:text="Nomination Poll"
                    android:textColor="#FFFFFF"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp" />

                <!-- Vote progress + time row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:layout_marginBottom="10dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:fontFamily="sans-serif"
                        android:text="Participation"
                        android:textColor="#B3FFFFFF"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/tvVoteProgress"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/manrope_bold"
                        android:text=""
                        android:textColor="#FFFFFF"
                        android:textSize="12sp" />

                    <FrameLayout
                        android:id="@+id/countdownRingContainer"
                        android:layout_width="46dp"
                        android:layout_height="46dp"
                        android:layout_marginStart="12dp">

                        <com.google.android.material.progressindicator.CircularProgressIndicator
                            android:id="@+id/countdownRing"
                            android:layout_width="46dp"
                            android:layout_height="46dp"
                            android:layout_gravity="center"
                            android:indeterminate="false"
                            android:progress="100"
                            app:indicatorColor="#4CAF50"
                            app:indicatorInset="0dp"
                            app:indicatorSize="46dp"
                            app:trackColor="#40FFFFFF"
                            app:trackThickness="4dp" />

                        <TextView
                            android:id="@+id/tvTimeRemaining"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:fontFamily="@font/manrope_bold"
                            android:gravity="center"
                            android:text=""
                            android:textColor="#FFFFFF"
                            android:textSize="10sp" />
                    </FrameLayout>
                </LinearLayout>

                <com.google.android.material.progressindicator.LinearProgressIndicator
                    android:id="@+id/pbVoting"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:progress="0"
                    app:indicatorColor="#FFFFFF"
                    app:trackColor="#40FFFFFF"
                    app:trackCornerRadius="4dp"
                    app:trackThickness="6dp" />

            </LinearLayout>

            <!-- ── ONE VOTE NOTICE ─────────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FFF8F0"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="20dp"
                android:paddingVertical="12dp">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_info"
                    app:tint="#D97706" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:fontFamily="sans-serif"
                    android:text="You have one vote. Choose carefully — this cannot be changed."
                    android:textColor="#92400E"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- ── NOMINEES SECTION ────────────────────────────────── -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="@color/card_surface"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/manrope_bold"
                        android:letterSpacing="0.07"
                        android:text="NOMINEES"
                        android:textColor="@color/v_text_muted"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="14dp" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvNominees"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false" />

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:layout_marginVertical="8dp"
                        android:background="@color/divider_color" />

                    <!-- Abstain -->
                    <LinearLayout
                        android:id="@+id/cardAbstain"
                        android:layout_width="match_parent"
                        android:layout_height="64dp"
                        android:background="@drawable/bg_rounded_gray"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="16dp">

                        <RelativeLayout
                            android:layout_width="42dp"
                            android:layout_height="42dp"
                            android:background="@drawable/bg_icon_circle_gray_light">

                            <ImageView
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:layout_centerInParent="true"
                                android:src="@drawable/ic_block_abstain" />
                        </RelativeLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/manrope_bold"
                                android:text="Abstain"
                                android:textColor="@color/v_text_dark"
                                android:textSize="15sp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="sans-serif"
                                android:text="Skip this vote"
                                android:textColor="@color/v_text_muted"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <ImageView
                            android:id="@+id/radioAbstain"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/bg_circle_outline_gray" />
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── SUBMIT BUTTON ───────────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="16dp"
                android:paddingTop="16dp">

                <LinearLayout
                    android:id="@+id/btnSubmitVote"
                    android:layout_width="match_parent"
                    android:layout_height="58dp"
                    android:background="@drawable/bg_loan_submit_btn"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="10dp"
                        android:fontFamily="@font/manrope_bold"
                        android:text="Submit My Vote"
                        android:textColor="#FFFFFF"
                        android:textSize="17sp" />

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_check_circle"
                        app:tint="#FFFFFF" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:fontFamily="sans-serif"
                    android:gravity="center"
                    android:text="Your vote is anonymous and cannot be undone."
                    android:textColor="@color/v_text_muted"
                    android:textSize="12sp" />
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Empty state -->
    <LinearLayout
        android:id="@+id/emptyState"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/v_page_bg"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="32dp"
        android:visibility="gone">

        <ImageView
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:src="@drawable/ic_how_to_vote"
            app:tint="@color/v_text_muted" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:fontFamily="@font/manrope_bold"
            android:text="No polls right now"
            android:textColor="@color/v_text_mid"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:fontFamily="sans-serif"
            android:gravity="center"
            android:text="You've voted on all active polls, or none have been created yet."
            android:textColor="@color/v_text_muted"
            android:textSize="14sp" />
    </LinearLayout>

    <ProgressBar
        android:id="@+id/loadingIndicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
