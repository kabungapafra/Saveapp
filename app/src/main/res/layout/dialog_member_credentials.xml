<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/white"
    android:orientation="vertical">

    <!-- Top Navigation Bar -->
    <RelativeLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:paddingHorizontal="20dp">

        <ImageView
            android:id="@+id/btnCloseCredentials"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_centerVertical="true"
            android:background="@drawable/blue_50_circle"
            android:padding="12dp"
            android:src="@drawable/ic_arrow_back"
            app:tint="@color/brand_blue" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:fontFamily="@font/manrope_bold"
            android:text="@string/share_login_details"
            android:textColor="@color/text_slate_900"
            android:textSize="18sp" />
    </RelativeLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="16dp"
            android:paddingBottom="24dp">

            <!-- Success Icon -->
            <RelativeLayout
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_marginBottom="24dp">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/blue_50_circle" />

                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_centerInParent="true"
                    android:src="@drawable/ic_person_add"
                    app:tint="@color/brand_blue" />
            </RelativeLayout>

            <!-- Main Title & Desc -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:fontFamily="@font/manrope_bold"
                android:text="@string/share_login_details"
                android:textColor="@color/text_slate_900"
                android:textSize="24sp" />

            <TextView
                android:id="@+id/tvCredGroupName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:fontFamily="@font/manrope_bold"
                android:text="Weekend Savers Club"
                android:textColor="@color/brand_blue"
                android:textSize="14sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp"
                android:fontFamily="@font/manrope_medium"
                android:gravity="center"
                android:lineSpacingExtra="4dp"
                android:text="@string/share_credentials_desc"
                android:textColor="@color/text_slate_500"
                android:textSize="14sp" />

            <!-- New Member Info Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardBackgroundColor="@color/slate_50"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="16dp">

                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/ivCredMemberAvatar"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/ic_profile_placeholder"
                        app:shapeAppearanceOverlay="@style/ShapeAppearance.App.Circle" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/manrope_bold"
                            android:text="@string/new_member_label"
                            android:textColor="@color/text_slate_400"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/tvCredMemberName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/manrope_bold"
                            android:text="Sarah Jenkins"
                            android:textColor="@color/text_slate_900"
                            android:textSize="18sp" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Email Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:fontFamily="@font/manrope_bold"
                    android:text="@string/member_email_label"
                    android:textColor="@color/text_slate_900"
                    android:textSize="14sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:background="@drawable/bg_input_add_member"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="16dp">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_email"
                        app:tint="@color/text_slate_400" />

                    <TextView
                        android:id="@+id/tvCredEmail"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:fontFamily="@font/manrope_medium"
                        android:text="sarah.jenkins@email.com"
                        android:textColor="@color/text_slate_900"
                        android:textSize="15sp" />

                    <ImageView
                        android:id="@+id/btnCopyEmail"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_copy"
                        app:tint="@color/brand_blue" />
                </LinearLayout>
            </LinearLayout>

            <!-- Phone Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:fontFamily="@font/manrope_bold"
                    android:text="@string/phone"
                    android:textColor="@color/text_slate_900"
                    android:textSize="14sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:background="@drawable/bg_input_add_member"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="16dp">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_phone"
                        app:tint="@color/text_slate_400" />

                    <TextView
                        android:id="@+id/tvCredPhone"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:fontFamily="@font/manrope_medium"
                        android:text="+256 700 000 000"
                        android:textColor="@color/text_slate_900"
                        android:textSize="15sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- OTP Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:fontFamily="@font/manrope_bold"
                    android:text="@string/invitation_otp"
                    android:textColor="@color/text_slate_900"
                    android:textSize="14sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="80dp"
                    android:background="@drawable/bg_otp_box_soft"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_marginEnd="16dp"
                        android:src="@drawable/ic_key"
                        app:tint="@color/brand_blue" />

                    <TextView
                        android:id="@+id/tvCredOTP"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/manrope_bold"
                        android:letterSpacing="0.2"
                        android:text="8 8 2  1 4 9"
                        android:textColor="@color/brand_blue"
                        android:textSize="26sp" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:fontFamily="@font/manrope_medium"
                    android:text="@string/this_code_will_expire_in_24_hours"
                    android:textColor="@color/text_slate_400"
                    android:textSize="12sp" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- Bottom Action Area -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:elevation="8dp"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="16dp"
        android:paddingBottom="24dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSendEmail"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:fontFamily="@font/manrope_bold"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:text="@string/send_email_btn"
            android:textAllCaps="false"
            android:textSize="16sp"
            app:backgroundTint="@color/brand_blue"
            app:cornerRadius="16dp"
            app:icon="@drawable/ic_send"
            app:iconGravity="textStart"
            app:iconPadding="10dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnShareDetails"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_outlined_button_blue"
            android:fontFamily="@font/manrope_bold"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:text="@string/share_details_btn"
            android:textAllCaps="false"
            android:textColor="@color/brand_blue"
            android:textSize="16sp"
            app:backgroundTint="@null"
            app:cornerRadius="16dp"
            app:icon="@drawable/ic_share_filled"
            app:iconGravity="textStart"
            app:iconPadding="10dp"
            app:iconTint="@color/brand_blue"
            app:strokeWidth="0dp" />

        <TextView
            android:id="@+id/btnDone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:fontFamily="@font/manrope_bold"
            android:gravity="center"
            android:padding="8dp"
            android:text="@string/done_btn"
            android:textColor="@color/text_slate_400"
            android:textSize="16sp" />
    </LinearLayout>

</LinearLayout>
