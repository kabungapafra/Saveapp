<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/card_surface"
        app:cardCornerRadius="24dp"
        app:cardElevation="8dp"
        app:strokeWidth="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="24dp"
            android:paddingBottom="20dp">

            <!-- Header row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp">

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_avatar_circle"
                    android:backgroundTint="#EBF0FF"
                    android:padding="10dp"
                    android:src="@drawable/ic_person"
                    app:tint="@color/brand_blue" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/manrope_bold"
                        android:text="Member Added!"
                        android:textColor="@color/v_text_dark"
                        android:textSize="16sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:fontFamily="@font/manrope_medium"
                        android:text="Share the invite below"
                        android:textColor="@color/v_text_muted"
                        android:textSize="12sp" />

                </LinearLayout>

                <ImageButton
                    android:id="@+id/btnCloseCredentials"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="@drawable/bg_avatar_circle"
                    android:backgroundTint="#F1F5F9"
                    android:padding="8dp"
                    android:src="@drawable/ic_close"
                    app:tint="@color/v_text_muted" />

            </LinearLayout>

            <!-- Info rows -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_wizard_input_solid"
                android:orientation="vertical"
                android:paddingHorizontal="16dp"
                android:paddingVertical="4dp"
                android:layout_marginBottom="12dp">

                <!-- Group Name -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:fontFamily="@font/manrope_medium"
                        android:text="Group"
                        android:textColor="@color/v_text_muted"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/tvCredGroupName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/manrope_bold"
                        android:textColor="@color/v_text_dark"
                        android:textSize="13sp" />

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="0.5dp"
                    android:background="#F1F5F9" />

                <!-- Member Name -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:fontFamily="@font/manrope_medium"
                        android:text="Name"
                        android:textColor="@color/v_text_muted"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/tvCredMemberName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/manrope_bold"
                        android:textColor="@color/v_text_dark"
                        android:textSize="13sp" />

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="0.5dp"
                    android:background="#F1F5F9" />

                <!-- Phone -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:fontFamily="@font/manrope_medium"
                        android:text="Phone"
                        android:textColor="@color/v_text_muted"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/tvCredPhone"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/manrope_bold"
                        android:textColor="@color/v_text_dark"
                        android:textSize="13sp" />

                </LinearLayout>

            </LinearLayout>

            <!-- Hidden OTP field (stub for future use) -->
            <TextView
                android:id="@+id/tvCredOTP"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:visibility="gone" />

            <!-- Action buttons -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnShareDetails"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:fontFamily="@font/manrope_bold"
                android:text="Share Invite"
                android:textSize="14sp"
                app:backgroundTint="@color/brand_blue"
                app:cornerRadius="14dp"
                app:icon="@drawable/ic_share_filled"
                app:iconGravity="start"
                app:iconPadding="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDone"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="10dp"
                android:fontFamily="@font/manrope_bold"
                android:text="Done"
                android:textSize="14sp"
                app:backgroundTint="#F1F5F9"
                app:cornerRadius="14dp"
                app:strokeWidth="0dp" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</layout>
