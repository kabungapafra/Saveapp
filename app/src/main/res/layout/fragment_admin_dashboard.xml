<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dashboard_bg">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/main_content_scroll_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="100dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Premium Header Area -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_dashboard_header"
                android:paddingBottom="40dp">

                <RelativeLayout
                    android:id="@+id/brandArea"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingTop="32dp"
                    android:paddingBottom="8dp"
                    android:paddingHorizontal="20dp">

                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical">
                        <ImageView android:layout_width="56dp" android:layout_height="56dp" android:layout_marginBottom="12dp" android:src="@drawable/white" />
                        <TextView android:id="@+id/tvTopGreeting" android:layout_width="wrap_content" android:layout_height="wrap_content" android:fontFamily="@font/manrope" android:text="Good Morning," android:textColor="@color/white" android:textSize="18sp" />
                        <TextView android:id="@+id/tvTopName" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:fontFamily="@font/manrope" android:text="Admin" android:textColor="@color/white" android:textSize="24sp" android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:gravity="center_vertical" android:orientation="horizontal">
                        <RelativeLayout android:id="@+id/btnNotificationsContainer" android:layout_width="wrap_content" android:layout_height="wrap_content">
                            <ImageView android:id="@+id/btnNotifications" android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_notifications" app:tint="@color/white" />
                            <View android:id="@+id/notificationBadgeDot" android:layout_width="8dp" android:layout_height="8dp" android:layout_alignTop="@id/btnNotifications" android:layout_alignEnd="@id/btnNotifications" android:layout_marginTop="2dp" android:layout_marginEnd="2dp" android:background="@drawable/bg_badge_red" android:visibility="gone" />
                        </RelativeLayout>
                        <com.google.android.material.imageview.ShapeableImageView android:id="@+id/profileIcon" android:layout_width="32dp" android:layout_height="32dp" android:layout_marginStart="16dp" android:background="#33FFFFFF" android:padding="4dp" android:src="@drawable/ic_person" app:shapeAppearanceOverlay="@style/ShapeAppearance.App.Circle" app:tint="@color/white" />
                    </LinearLayout>
                </RelativeLayout>

                <LinearLayout android:id="@+id/balanceContainer" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_below="@id/brandArea" android:orientation="vertical" android:paddingHorizontal="20dp" android:paddingTop="10dp">
                    <TextView android:id="@+id/tvBalanceLabel" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="TOTAL GROUP BALANCE" android:textColor="#E0E7FF" android:textSize="12sp" android:textStyle="bold" android:letterSpacing="0.05" />
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="bottom" android:orientation="horizontal">
                        <TextView android:id="@+id/currentBalance" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="UGX 142,580" android:textColor="@color/white" android:textSize="36sp" android:textStyle="bold" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="12dp" android:layout_marginBottom="8dp" android:background="@drawable/bg_status_pills" android:backgroundTint="#215DA1" android:paddingHorizontal="8dp" android:paddingVertical="2dp" android:text="+ 12.5%" android:textColor="@color/white" android:textSize="10sp" android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_below="@id/balanceContainer" android:layout_marginTop="24dp" android:orientation="horizontal" android:paddingHorizontal="20dp">
                    <com.google.android.material.card.MaterialCardView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginEnd="8dp" app:cardBackgroundColor="#215DA1" app:cardCornerRadius="12dp" app:cardElevation="0dp">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                            <TextView android:id="@+id/tvMonthlyLabel" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Monthly Contributions" android:textColor="#E9F2FB" android:textSize="11sp" />
                            <TextView android:id="@+id/monthlyContrib" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="UGX 12,450" android:textColor="@color/white" android:textSize="18sp" android:textStyle="bold" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="8dp" app:cardBackgroundColor="#215DA1" app:cardCornerRadius="12dp" app:cardElevation="0dp">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                            <TextView android:id="@+id/tvInterestLabel" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Interest Earned" android:textColor="#E9F2FB" android:textSize="11sp" />
                            <TextView android:id="@+id/interestEarned" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="UGX 3,120" android:textColor="@color/dashboard_accent_orange" android:textSize="18sp" android:textStyle="bold" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>
            </RelativeLayout>

            <!-- Savings Targets Card -->
            <com.google.android.material.card.MaterialCardView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginHorizontal="20dp" android:layout_marginTop="-20dp" app:cardBackgroundColor="@color/white" app:cardCornerRadius="16dp" app:cardElevation="4dp" app:strokeWidth="0dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="20dp">
                    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Savings Targets" android:textColor="@color/dashboard_text_primary" android:textSize="16sp" android:textStyle="bold" />
                        <TextView android:id="@+id/viewAllTargets" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:text="View All" android:textColor="@color/dashboard_accent_blue" android:textSize="14sp" android:textStyle="bold" />
                    </RelativeLayout>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:layout_marginTop="20dp">
                        <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Emergency Fund" android:textColor="@color/dashboard_text_secondary" android:textSize="13sp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:text="UGX 15k / UGX 20k" android:textColor="@color/dashboard_text_secondary" android:textSize="13sp" android:textStyle="bold"/>
                        </RelativeLayout>
                        <com.google.android.material.progressindicator.LinearProgressIndicator android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:progress="75" app:indicatorColor="@color/dashboard_accent_blue" app:trackColor="#F1F5F9" app:trackCornerRadius="4dp" app:trackThickness="6dp"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:layout_marginTop="20dp">
                        <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Community Project" android:textColor="@color/dashboard_text_secondary" android:textSize="13sp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:text="UGX 8.2k / UGX 10k" android:textColor="@color/dashboard_text_secondary" android:textSize="13sp" android:textStyle="bold"/>
                        </RelativeLayout>
                        <com.google.android.material.progressindicator.LinearProgressIndicator android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:progress="82" app:indicatorColor="@color/dashboard_accent_orange" app:trackColor="#F1F5F9" app:trackCornerRadius="4dp" app:trackThickness="6dp"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:layout_marginTop="20dp">
                        <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Annual Reserve" android:textColor="@color/dashboard_text_secondary" android:textSize="13sp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:text="UGX 45k / UGX 100k" android:textColor="@color/dashboard_text_secondary" android:textSize="13sp" android:textStyle="bold"/>
                        </RelativeLayout>
                        <com.google.android.material.progressindicator.LinearProgressIndicator android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:progress="45" app:indicatorColor="#94A3B8" app:trackColor="#F1F5F9" app:trackCornerRadius="4dp" app:trackThickness="6dp"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Group Growth Section -->
            <com.google.android.material.card.MaterialCardView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginHorizontal="20dp" android:layout_marginTop="16dp" app:cardBackgroundColor="@color/white" app:cardCornerRadius="16dp" app:cardElevation="1dp" app:strokeWidth="0dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="20dp">
                    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Group Growth" android:textColor="@color/dashboard_text_primary" android:textSize="16sp" android:textStyle="bold"/>
                    </RelativeLayout>
                    <com.github.mikephil.charting.charts.BarChart android:id="@+id/growthBarChart" android:layout_width="match_parent" android:layout_height="180dp" android:layout_marginTop="20dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Active Loans Card -->
            <com.google.android.material.card.MaterialCardView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginHorizontal="20dp" android:layout_marginTop="16dp" app:cardBackgroundColor="@color/white" app:cardCornerRadius="16dp" app:cardElevation="1dp" app:strokeWidth="0dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="20dp">
                    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Active Loans" android:textColor="@color/dashboard_text_primary" android:textSize="16sp" android:textStyle="bold"/>
                        <TextView android:id="@+id/viewAllLoans" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:background="@drawable/bg_status_pills" android:backgroundTint="#E9F2FB" android:paddingHorizontal="10dp" android:paddingVertical="4dp" android:text="24 Total" android:textColor="@color/dashboard_accent_blue" android:textSize="11sp" android:textStyle="bold"/>
                    </RelativeLayout>
                    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="20dp">
                        <com.google.android.material.imageview.ShapeableImageView android:id="@+id/avatar1" android:layout_width="40dp" android:layout_height="40dp" android:src="@drawable/ic_search" android:background="#F1F5F9" android:padding="8dp" app:shapeAppearanceOverlay="@style/ShapeAppearance.App.Circle"/>
                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_toEndOf="@id/avatar1" android:layout_marginStart="12dp" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Marcus Thompson" android:textColor="@color/dashboard_text_primary" android:textSize="14sp" android:textStyle="bold"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Business Expansion" android:textColor="@color/dashboard_text_secondary" android:textSize="12sp"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:gravity="end" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="UGX 4,200" android:textColor="@color/dashboard_text_primary" android:textSize="14sp" android:textStyle="bold"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Due in 12 days" android:textColor="#E11D48" android:textSize="11sp" android:textStyle="bold"/>
                        </LinearLayout>
                    </RelativeLayout>
                    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp">
                        <com.google.android.material.imageview.ShapeableImageView android:id="@+id/avatar2" android:layout_width="40dp" android:layout_height="40dp" android:src="@drawable/ic_search" android:background="#F1F5F9" android:padding="8dp" app:shapeAppearanceOverlay="@style/ShapeAppearance.App.Circle"/>
                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_toEndOf="@id/avatar2" android:layout_marginStart="12dp" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Elena Rodriguez" android:textColor="@color/dashboard_text_primary" android:textSize="14sp" android:textStyle="bold"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Education Loan" android:textColor="@color/dashboard_text_secondary" android:textSize="12sp"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:gravity="end" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="UGX 1,850" android:textColor="@color/dashboard_text_primary" android:textSize="14sp" android:textStyle="bold"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Paid 65%" android:textColor="@color/dashboard_accent_blue" android:textSize="11sp" android:textStyle="bold"/>
                        </LinearLayout>
                    </RelativeLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Recent Payouts -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:paddingHorizontal="20dp" android:paddingTop="16dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Recent Payouts" android:textColor="@color/dashboard_text_primary" android:textSize="16sp" android:textStyle="bold"/>
                <com.google.android.material.card.MaterialCardView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" app:cardBackgroundColor="@color/white" app:cardCornerRadius="16dp" app:cardElevation="1dp" app:strokeWidth="0dp">
                   <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="16dp">
                        <ImageView android:id="@+id/check1" android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_check_circle" app:tint="@color/dashboard_accent_green"/>
                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_toEndOf="@id/check1" android:layout_marginStart="12dp" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Sarah Jenkins" android:textColor="@color/dashboard_text_primary" android:textSize="15sp" android:textStyle="bold"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Payout - Round 14" android:textColor="@color/dashboard_text_secondary" android:textSize="12sp"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:gravity="end" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="UGX 12,000" android:textColor="@color/dashboard_text_primary" android:textSize="15sp" android:textStyle="bold"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Oct 24, 2023" android:textColor="@color/dashboard_text_secondary" android:textSize="11sp"/>
                        </LinearLayout>
                   </RelativeLayout>
                </com.google.android.material.card.MaterialCardView>
                <com.google.android.material.card.MaterialCardView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" app:cardBackgroundColor="@color/white" app:cardCornerRadius="16dp" app:cardElevation="1dp" app:strokeWidth="0dp">
                   <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="16dp">
                        <ImageView android:id="@+id/check2" android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_check_circle" app:tint="@color/dashboard_accent_green"/>
                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_toEndOf="@id/check2" android:layout_marginStart="12dp" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="David Chen" android:textColor="@color/dashboard_text_primary" android:textSize="15sp" android:textStyle="bold"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Payout - Round 13" android:textColor="@color/dashboard_text_secondary" android:textSize="12sp"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:gravity="end" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="UGX 12,000" android:textColor="@color/dashboard_text_primary" android:textSize="15sp" android:textStyle="bold"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Oct 10, 2023" android:textColor="@color/dashboard_text_secondary" android:textSize="11sp"/>
                        </LinearLayout>
                   </RelativeLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- Upcoming Payouts -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:paddingHorizontal="20dp" android:paddingTop="20dp">
                  <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Upcoming Payouts" android:textColor="@color/dashboard_text_primary" android:textSize="16sp" android:textStyle="bold"/>
                  <com.google.android.material.card.MaterialCardView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" app:cardBackgroundColor="@color/white" app:cardCornerRadius="16dp" app:cardElevation="1dp" app:strokeWidth="0dp">
                     <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="16dp">
                          <com.google.android.material.card.MaterialCardView android:id="@+id/calIcon1" android:layout_width="36dp" android:layout_height="36dp" app:cardBackgroundColor="#E9F2FB" app:cardCornerRadius="8dp" app:cardElevation="0dp">
                              <ImageView android:layout_width="match_parent" android:layout_height="match_parent" android:padding="8dp" android:src="@drawable/ic_calendar_month" app:tint="@color/dashboard_accent_blue"/>
                          </com.google.android.material.card.MaterialCardView>
                          <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_toEndOf="@id/calIcon1" android:layout_marginStart="12dp" android:orientation="vertical">
                              <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Michael Abiodun" android:textColor="@color/dashboard_text_primary" android:textSize="15sp" android:textStyle="bold"/>
                              <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Payout - Round 15" android:textColor="@color/dashboard_text_secondary" android:textSize="12sp"/>
                          </LinearLayout>
                          <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:gravity="end" android:orientation="vertical">
                              <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="UGX 12,000" android:textColor="@color/dashboard_text_primary" android:textSize="15sp" android:textStyle="bold"/>
                              <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Nov 07, 2023" android:textColor="@color/dashboard_accent_orange" android:textSize="11sp" android:textStyle="bold"/>
                          </LinearLayout>
                          <TextView android:id="@+id/btnMarkPaid1" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_below="@id/calIcon1" android:layout_marginTop="12dp" android:background="@drawable/bg_btn_mark_paid" android:gravity="center" android:paddingVertical="6dp" android:text="MARK PAID" android:textColor="#64748B" android:textSize="10sp" android:textStyle="bold" android:letterSpacing="0.02" />
                     </RelativeLayout>
                  </com.google.android.material.card.MaterialCardView>
                  <com.google.android.material.card.MaterialCardView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" app:cardBackgroundColor="@color/white" app:cardCornerRadius="16dp" app:cardElevation="1dp" app:strokeWidth="0dp">
                     <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="16dp">
                          <com.google.android.material.card.MaterialCardView android:id="@+id/calIcon2" android:layout_width="36dp" android:layout_height="36dp" app:cardBackgroundColor="#E9F2FB" app:cardCornerRadius="8dp" app:cardElevation="0dp">
                              <ImageView android:layout_width="match_parent" android:layout_height="match_parent" android:padding="8dp" android:src="@drawable/ic_calendar_month" app:tint="@color/dashboard_accent_blue"/>
                          </com.google.android.material.card.MaterialCardView>
                          <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_toEndOf="@id/calIcon2" android:layout_marginStart="12dp" android:orientation="vertical">
                              <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Linda Okafor" android:textColor="@color/dashboard_text_primary" android:textSize="15sp" android:textStyle="bold"/>
                              <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Payout - Round 16" android:textColor="@color/dashboard_text_secondary" android:textSize="12sp"/>
                          </LinearLayout>
                          <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:gravity="end" android:orientation="vertical">
                              <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="UGX 12,000" android:textColor="@color/dashboard_text_primary" android:textSize="15sp" android:textStyle="bold"/>
                              <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Nov 21, 2023" android:textColor="@color/dashboard_accent_orange" android:textSize="11sp" android:textStyle="bold"/>
                          </LinearLayout>
                          <TextView android:id="@+id/btnMarkPaid2" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_below="@id/calIcon2" android:layout_marginTop="12dp" android:background="@drawable/bg_btn_mark_paid" android:gravity="center" android:paddingVertical="6dp" android:text="MARK PAID" android:textColor="#64748B" android:textSize="10sp" android:textStyle="bold" android:letterSpacing="0.02" />
                     </RelativeLayout>
                  </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- Payout Schedule Section -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:paddingHorizontal="20dp" android:paddingTop="32dp" android:paddingBottom="24dp">
                <com.google.android.material.card.MaterialCardView android:layout_width="match_parent" android:layout_height="wrap_content" app:cardBackgroundColor="@color/white" app:cardCornerRadius="16dp" app:cardElevation="1dp" app:strokeWidth="0dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="20dp">
