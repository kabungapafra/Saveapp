<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dashboard_bg">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/main_content_scroll_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Top bar: logo + greeting + icons (outside the blue card) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="90dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="24dp"
                android:paddingTop="36dp"
                android:paddingBottom="14dp">

                <ImageView
                    android:id="@+id/imgLogo"
                    android:layout_width="68dp"
                    android:layout_height="68dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/save_logo" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvTopGreeting"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/roboto"
                        android:text="Good Morning,"
                        android:textColor="@color/dashboard_text_secondary"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/tvTopName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/roboto"
                        android:text="Admin"
                        android:textColor="@color/dashboard_text_primary"
                        android:textSize="@dimen/text_size_normal"
                        android:textStyle="bold" />
                </LinearLayout>

                <FrameLayout
                    android:id="@+id/btnThemeToggle"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?attr/selectableItemBackgroundBorderless">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_theme_toggle"
                        app:tint="@color/brand_blue" />
                </FrameLayout>

                <RelativeLayout
                    android:id="@+id/btnNotificationsContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp">

                    <ImageView
                        android:id="@+id/btnNotifications"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_notifications"
                        app:tint="@color/brand_blue" />

                    <View
                        android:id="@+id/notificationBadgeDot"
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:layout_alignTop="@id/btnNotifications"
                        android:layout_alignEnd="@id/btnNotifications"
                        android:layout_marginTop="2dp"
                        android:layout_marginEnd="2dp"
                        android:background="@drawable/bg_badge_red"
                        android:visibility="gone" />
                </RelativeLayout>
            </LinearLayout>

            <!-- Blue balance section (no logo/greeting inside) -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_dashboard_header"
                android:paddingBottom="40dp">

                <LinearLayout
                    android:id="@+id/balanceContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="24dp"
                    android:paddingTop="20dp">
                    <TextView
                        android:id="@+id/tvBalanceLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="TOTAL GROUP BALANCE"
                        android:textColor="#E0E7FF"
                        android:textSize="@dimen/text_size_xs"
                        android:textStyle="bold"
                        android:letterSpacing="0.05" />
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="bottom"
                        android:orientation="horizontal">
                        <TextView
                            android:id="@+id/currentBalance"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="UGX 0"
                            android:textColor="#FFFFFF"
                            android:textSize="@dimen/text_size_xxxl"
                            android:textStyle="bold" />
                        <TextView
                            android:id="@+id/tvBalanceTrend"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_marginBottom="8dp"
                            android:background="@drawable/bg_status_pills"
                            android:backgroundTint="@color/brand_blue"
                            android:paddingHorizontal="8dp"
                            android:paddingVertical="2dp"
                            android:text="+ 0%"
                            android:textColor="#FFFFFF"
                            android:textSize="@dimen/text_size_xs"
                            android:textStyle="bold"
                            android:visibility="gone" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/miniCardsRow"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/balanceContainer"
                    android:layout_marginTop="24dp"
                    android:orientation="horizontal"
                    android:paddingHorizontal="24dp">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        app:cardBackgroundColor="@color/dashboard_blue_header"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="0dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp">
                            <TextView
                                android:id="@+id/tvMonthlyLabel"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Available Savings"
                                android:textColor="#E9F2FB"
                                android:textSize="@dimen/text_size_xs" />
                            <TextView
                                android:id="@+id/monthlyContrib"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="UGX 0"
                                android:textColor="#FFFFFF"
                                android:textSize="@dimen/text_size_normal"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        app:cardBackgroundColor="@color/dashboard_blue_header"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="0dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp">
                            <TextView
                                android:id="@+id/tvInterestLabel"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Loan Balance"
                                android:textColor="#E9F2FB"
                                android:textSize="@dimen/text_size_xs" />
                            <TextView
                                android:id="@+id/interestEarned"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="UGX 0"
                                android:textColor="@color/dashboard_accent_orange"
                                android:textSize="@dimen/text_size_normal"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/miniCardsRow"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal"
                    android:paddingHorizontal="24dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Next Contribution"
                        android:textColor="#B0C8E8"
                        android:textSize="@dimen/text_size_xs" />

                    <TextView
                        android:id="@+id/tvNextContribDate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="--"
                        android:textColor="#FFFFFF"
                        android:textSize="@dimen/text_size_xs"
                        android:textStyle="bold" />

                </LinearLayout>
            </RelativeLayout>

            <!-- Savings Targets Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/sectionSavingsTargets"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="-24dp"
                app:cardBackgroundColor="@color/card_surface"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Savings Targets"
                            android:textColor="@color/dashboard_text_primary"
                            android:textSize="@dimen/text_size_normal"
                            android:textStyle="bold" />
                    </RelativeLayout>

                    <LinearLayout
                        android:id="@+id/containerSavingsTargets"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:orientation="vertical">

                        <!-- Monthly projection -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/tvTarget1Name"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Monthly Projection"
                                android:textColor="@color/dashboard_text_secondary"
                                android:textSize="@dimen/text_size_xs" />

                            <TextView
                                android:id="@+id/tvTarget1Amount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="UGX 0"
                                android:textColor="@color/dashboard_accent_blue"
                                android:textSize="@dimen/text_size_xs"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <com.google.android.material.progressindicator.LinearProgressIndicator
                            android:id="@+id/pbTarget1"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:progress="0"
                            app:indicatorColor="@color/dashboard_accent_blue"
                            app:trackColor="@color/v_page_bg"
                            app:trackCornerRadius="4dp"
                            app:trackThickness="4dp" />

                        <!-- Yearly projection -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/tvTarget2Name"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Year Projection"
                                android:textColor="@color/dashboard_text_secondary"
                                android:textSize="@dimen/text_size_xs" />

                            <TextView
                                android:id="@+id/tvTarget2Amount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="UGX 0"
                                android:textColor="@color/dashboard_accent_orange"
                                android:textSize="@dimen/text_size_xs"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <com.google.android.material.progressindicator.LinearProgressIndicator
                            android:id="@+id/pbTarget2"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:progress="0"
                            app:indicatorColor="@color/dashboard_accent_orange"
                            app:trackColor="@color/v_page_bg"
                            app:trackCornerRadius="4dp"
                            app:trackThickness="4dp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvNoTargets"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:gravity="center"
                        android:text="No active targets"
                        android:textColor="@color/v_text_muted"
                        android:textSize="13sp"
                        android:visibility="gone" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Active Poll / Election banner — shown only when there is an active poll the user hasn't voted on -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/activePollBanner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="20dp"
                android:clickable="true"
                android:focusable="true"
                android:visibility="gone"
                app:cardBackgroundColor="@color/card_surface"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="#FF5252"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="14dp">

                    <View
                        android:id="@+id/activePollDot"
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:background="@drawable/bg_badge_red" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Active election"
                            android:textColor="@color/dashboard_text_primary"
                            android:textSize="@dimen/text_size_normal"
                            android:textStyle="bold" />
                        <TextView
                            android:id="@+id/tvActivePollTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="A vote needs your attention"
                            android:textColor="@color/dashboard_text_secondary"
                            android:textSize="@dimen/text_size_xs" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_status_pills"
                        android:backgroundTint="#FF5252"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="6dp"
                        android:text="Vote now"
                        android:textColor="#FFFFFF"
                        android:textSize="@dimen/text_size_xs"
                        android:textStyle="bold" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Quick Actions -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="20dp"
                android:paddingTop="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Quick Actions"
                    android:textColor="@color/dashboard_text_primary"
                    android:textSize="@dimen/text_size_normal"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:orientation="horizontal"
                    android:baselineAligned="false">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/btnQuickContribute"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        app:cardBackgroundColor="@color/card_surface"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="0dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:paddingTop="16dp"
                            android:paddingBottom="12dp"
                            android:paddingHorizontal="8dp">
                            <ImageView
                                android:layout_width="26dp"
                                android:layout_height="26dp"
                                android:src="@drawable/ic_contribution_purple"
                                app:tint="@color/dashboard_text_primary" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:gravity="center"
                                android:text="Contribute"
                                android:textColor="@color/dashboard_text_primary"
                                android:textSize="11sp" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/btnQuickRequestLoan"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:layout_marginEnd="6dp"
                        app:cardBackgroundColor="@color/card_surface"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="0dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:paddingTop="16dp"
                            android:paddingBottom="12dp"
                            android:paddingHorizontal="8dp">
                            <ImageView
                                android:layout_width="26dp"
                                android:layout_height="26dp"
                                android:src="@drawable/ic_request_loan_orange"
                                app:tint="@color/dashboard_text_primary" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:gravity="center"
                                android:text="Apply Loan"
                                android:textColor="@color/dashboard_text_primary"
                                android:textSize="11sp" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/btnQuickRepayLoan"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:layout_marginEnd="6dp"
                        app:cardBackgroundColor="@color/card_surface"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="0dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:paddingTop="16dp"
                            android:paddingBottom="12dp"
                            android:paddingHorizontal="8dp">
                            <ImageView
                                android:layout_width="26dp"
                                android:layout_height="26dp"
                                android:src="@drawable/ic_wallet_green"
                                app:tint="@color/dashboard_text_primary" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:gravity="center"
                                android:text="Repay Loan"
                                android:textColor="@color/dashboard_text_primary"
                                android:textSize="11sp" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/btnQuickMembers"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        app:cardBackgroundColor="@color/card_surface"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="0dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:paddingTop="16dp"
                            android:paddingBottom="12dp"
                            android:paddingHorizontal="8dp">
                            <ImageView
                                android:layout_width="26dp"
                                android:layout_height="26dp"
                                android:src="@drawable/ic_people_group"
                                app:tint="@color/dashboard_text_primary" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:gravity="center"
                                android:text="@string/members"
                                android:textColor="@color/dashboard_text_primary"
                                android:textSize="11sp" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>
            </LinearLayout>

            <!-- Upcoming Payouts -->
            <LinearLayout
                android:id="@+id/sectionUpcomingPayouts"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="20dp"
                android:paddingTop="20dp">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/card_surface"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <!-- Row 1: "UPCOMING PAYOUT" + frequency pill -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="UPCOMING PAYOUT"
                                android:textColor="@color/dashboard_text_secondary"
                                android:textSize="11sp"
                                android:letterSpacing="0.05"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tvPayoutFrequency"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:background="@drawable/bg_badge_success"
                                android:backgroundTint="@color/h_green_100"
                                android:paddingHorizontal="12dp"
                                android:paddingVertical="4dp"
                                android:text="Monthly"
                                android:textColor="@color/h_green_700"
                                android:textSize="11sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <!-- Row 2: large green amount -->
                        <TextView
                            android:id="@+id/tvUpcomingPayoutAmount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:text="UGX 0"
                            android:textColor="@color/dashboard_accent_green"
                            android:textSize="@dimen/text_size_xxxl"
                            android:textStyle="bold" />

                        <!-- Row 3: receiver name -->
                        <TextView
                            android:id="@+id/tvUpcomingPayoutReceiver"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="--"
                            android:textColor="@color/dashboard_text_secondary"
                            android:textSize="12sp" />

                        <!-- Row 4: date (left) + View all (right) -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <ImageView
                                android:layout_width="14dp"
                                android:layout_height="14dp"
                                android:src="@drawable/ic_calendar_month"
                                android:layout_marginEnd="6dp"
                                app:tint="@color/dashboard_text_secondary" />

                            <TextView
                                android:id="@+id/tvUpcomingPayoutDate"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="--"
                                android:textColor="@color/dashboard_text_secondary"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/btnViewQueue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="View all →"
                                android:textColor="@color/dashboard_accent_blue"
                                android:textSize="12sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- Recent Transactions -->
            <LinearLayout
                android:id="@+id/sectionRecentTransactions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="20dp"
                android:paddingTop="16dp">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/card_surface"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">
                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:paddingHorizontal="16dp"
                            android:paddingTop="16dp"
                            android:paddingBottom="12dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Recent Transactions"
                                android:textColor="@color/dashboard_text_primary"
                                android:textSize="@dimen/text_size_normal"
                                android:textStyle="bold" />
                            <TextView
                                android:id="@+id/btnSeeAllTransactions"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentEnd="true"
                                android:text="See all"
                                android:textColor="@color/dashboard_accent_blue"
                                android:textSize="@dimen/text_size_xs"
                                android:textStyle="bold" />
                        </RelativeLayout>
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="@color/divider_color" />
                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/rvRecentTransactions"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:nestedScrollingEnabled="false"
                            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />
                        <TextView
                            android:id="@+id/tvNoRecentTransactions"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:padding="20dp"
                            android:text="No recent transactions"
                            android:textColor="@color/v_text_muted"
                            android:textSize="@dimen/text_size_xs"
                            android:visibility="gone" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>


        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
