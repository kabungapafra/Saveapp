<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/v_page_bg">

    <!-- Scrollable Content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingBottom="80dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Page Title Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/v_page_bg"
                android:orientation="vertical"
                android:paddingHorizontal="20dp"
                android:paddingTop="48dp"
                android:paddingBottom="24dp">

                <!-- Back button -->
                <ImageView
                    android:id="@+id/btnBack"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginBottom="16dp"
                    android:background="@drawable/bg_icon_circle_gray_light"
                    android:padding="8dp"
                    android:src="@drawable/ic_arrow_back"
                    android:clickable="true"
                    android:focusable="true"
                    app:tint="#1E293B" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/manrope_bold"
                    android:text="Create Poll"
                    android:textColor="@color/v_text_dark"
                    android:textSize="28sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:fontFamily="sans-serif"
                    android:text="Nominate members for official group roles to begin a community vote."
                    android:textColor="@color/v_text_mid"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- SELECT ROLE Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@color/v_page_bg"
                android:orientation="vertical"
                android:paddingTop="20dp"
                android:paddingBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="20dp"
                    android:fontFamily="@font/manrope_bold"
                    android:letterSpacing="0.08"
                    android:text="SELECT ROLE"
                    android:textColor="@color/v_text_muted"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <!-- Row 1: Main Role Cards (horizontal scroll) -->
                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:paddingHorizontal="16dp"
                    android:scrollbars="none">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <!-- Admin Card (Selected by default) -->
                        <FrameLayout
                            android:id="@+id/cardAdmin"
                            android:layout_width="130dp"
                            android:layout_height="100dp"
                            android:layout_marginEnd="12dp"
                            android:background="@drawable/bg_role_card_selected"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?attr/selectableItemBackgroundBorderless">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:gravity="center_vertical"
                                android:orientation="vertical"
                                android:padding="14dp">

                                <RelativeLayout
                                    android:layout_width="38dp"
                                    android:layout_height="38dp"
                                    android:background="@drawable/bg_circle_blue">

                                    <ImageView
                                        android:layout_width="20dp"
                                        android:layout_height="20dp"
                                        android:layout_centerInParent="true"
                                        android:src="@drawable/ic_admin_panel_settings"
                                        app:tint="#FFFFFF" />
                                </RelativeLayout>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="8dp"
                                    android:fontFamily="@font/manrope_bold"
                                    android:text="Admin"
                                    android:textColor="@color/v_text_dark"
                                    android:textSize="13sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="2dp"
                                    android:fontFamily="sans-serif"
                                    android:text="Core governance"
                                    android:textColor="@color/v_text_muted"
                                    android:textSize="11sp" />
                            </LinearLayout>

                            <!-- Selected checkmark badge -->
                            <RelativeLayout
                                android:id="@+id/badgeAdminSelected"
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:layout_gravity="top|end"
                                android:layout_margin="8dp"
                                android:background="@drawable/bg_circle_blue"
                                android:visibility="visible">

                                <ImageView
                                    android:layout_width="13dp"
                                    android:layout_height="13dp"
                                    android:layout_centerInParent="true"
                                    android:src="@drawable/ic_check"
                                    app:tint="#FFFFFF" />
                            </RelativeLayout>

                        </FrameLayout>

                        <!-- Treasurer Card (Unselected) -->
                        <FrameLayout
                            android:id="@+id/cardTreasurer"
                            android:layout_width="130dp"
                            android:layout_height="100dp"
                            android:layout_marginEnd="12dp"
                            android:background="@drawable/bg_role_card_unselected"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?attr/selectableItemBackgroundBorderless">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:gravity="center_vertical"
                                android:orientation="vertical"
                                android:padding="14dp">

                                <RelativeLayout
                                    android:layout_width="38dp"
                                    android:layout_height="38dp"
                                    android:background="@drawable/bg_icon_circle_gray_light">

                                    <ImageView
                                        android:layout_width="20dp"
                                        android:layout_height="20dp"
                                        android:layout_centerInParent="true"
                                        android:src="@drawable/ic_account_balance_wallet"
                                        app:tint="@color/v_text_mid" />
                                </RelativeLayout>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="8dp"
                                    android:fontFamily="@font/manrope_bold"
                                    android:text="Treasurer"
                                    android:textColor="@color/v_text_dark"
                                    android:textSize="13sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="2dp"
                                    android:fontFamily="sans-serif"
                                    android:text="Financial oversight"
                                    android:textColor="@color/v_text_muted"
                                    android:textSize="11sp" />
                            </LinearLayout>

                            <RelativeLayout
                                android:id="@+id/badgeTreasurerSelected"
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:layout_gravity="top|end"
                                android:layout_margin="8dp"
                                android:background="@drawable/bg_circle_blue"
                                android:visibility="gone">

                                <ImageView
                                    android:layout_width="13dp"
                                    android:layout_height="13dp"
                                    android:layout_centerInParent="true"
                                    android:src="@drawable/ic_check"
                                    app:tint="#FFFFFF" />
                            </RelativeLayout>

                        </FrameLayout>

                    </LinearLayout>
                </HorizontalScrollView>

                <!-- Row 2: Chip pills (Secretary, Moderator, + Custom) -->
                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:paddingHorizontal="16dp"
                    android:scrollbars="none">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/chipSecretary"
                            android:layout_width="wrap_content"
                            android:layout_height="34dp"
                            android:layout_marginEnd="8dp"
                            android:background="@drawable/bg_pill_white_border"
                            android:clickable="true"
                            android:focusable="true"
                            android:fontFamily="sans-serif"
                            android:gravity="center"
                            android:paddingHorizontal="16dp"
                            android:text="Secretary"
                            android:textColor="@color/v_text_mid"
                            android:textSize="13sp" />

                        <TextView
                            android:id="@+id/chipModerator"
                            android:layout_width="wrap_content"
                            android:layout_height="34dp"
                            android:layout_marginEnd="8dp"
                            android:background="@drawable/bg_pill_white_border"
                            android:clickable="true"
                            android:focusable="true"
                            android:fontFamily="sans-serif"
                            android:gravity="center"
                            android:paddingHorizontal="16dp"
                            android:text="Moderator"
                            android:textColor="@color/v_text_mid"
                            android:textSize="13sp" />

                        <TextView
                            android:id="@+id/chipCustom"
                            android:layout_width="wrap_content"
                            android:layout_height="34dp"
                            android:background="@drawable/bg_pill_white_border"
                            android:clickable="true"
                            android:focusable="true"
                            android:fontFamily="sans-serif"
                            android:gravity="center"
                            android:paddingHorizontal="16dp"
                            android:text="+ Custom"
                            android:textColor="@color/v_text_mid"
                            android:textSize="13sp" />

                    </LinearLayout>
                </HorizontalScrollView>

            </LinearLayout>

            <!-- NOMINATE MEMBERS Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@color/v_page_bg"
                android:orientation="vertical"
                android:paddingTop="20dp"
                android:paddingBottom="8dp">

                <!-- Header row: NOMINATE MEMBERS + X selected -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="20dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:fontFamily="@font/manrope_bold"
                        android:letterSpacing="0.08"
                        android:text="NOMINATE MEMBERS"
                        android:textColor="@color/v_text_muted"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvSelectedCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/manrope_bold"
                        android:text="0 selected"
                        android:textColor="@color/brand_blue"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:visibility="invisible" />
                </LinearLayout>

                <!-- Search Bar -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="46dp"
                    android:layout_marginHorizontal="16dp"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/bg_rounded_search"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="14dp">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_search"
                        app:tint="@color/v_text_muted" />

                    <EditText
                        android:id="@+id/etSearchMembers"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginStart="10dp"
                        android:layout_weight="1"
                        android:background="@null"
                        android:fontFamily="sans-serif"
                        android:hint="Search members by name or tag..."
                        android:inputType="text"
                        android:maxLines="1"
                        android:textColor="@color/v_text_dark"
                        android:textColorHint="@color/v_text_muted"
                        android:textSize="14sp" />
                </LinearLayout>

                <!-- Member RecyclerView -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvNominees"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="16dp"
                    android:layout_marginTop="10dp"
                    android:nestedScrollingEnabled="false" />

                <!-- Empty state -->
                <TextView
                    android:id="@+id/tvNoMembers"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="16dp"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="16dp"
                    android:fontFamily="sans-serif"
                    android:gravity="center"
                    android:text="No members found"
                    android:textColor="@color/v_text_muted"
                    android:textSize="13sp"
                    android:visibility="gone" />

            </LinearLayout>

            <!-- Launch Button + Disclaimer -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@color/v_page_bg"
                android:orientation="vertical"
                android:paddingHorizontal="20dp"
                android:paddingTop="20dp"
                android:paddingBottom="20dp">

                <LinearLayout
                    android:id="@+id/btnLaunch"
                    android:layout_width="match_parent"
                    android:layout_height="58dp"
                    android:background="@drawable/bg_loan_submit_btn"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <ProgressBar
                        android:id="@+id/launchProgress"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_marginEnd="10dp"
                        android:indeterminateTint="#FFFFFF"
                        android:visibility="gone" />

                    <ImageView
                        android:id="@+id/ivLaunchIcon"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_marginEnd="10dp"
                        android:src="@drawable/ic_rocket_launch"
                        app:tint="#FFFFFF" />

                    <TextView
                        android:id="@+id/tvLaunchText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/manrope_bold"
                        android:text="Launch Nomination Poll"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:fontFamily="sans-serif"
                    android:gravity="center"
                    android:text="By launching, all group members will be notified to cast their votes. This poll will automatically expire after 24 hours."
                    android:textColor="@color/v_text_muted"
                    android:textSize="12sp" />

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
