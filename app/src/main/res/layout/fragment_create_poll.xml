<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/v_page_bg">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="100dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ── HERO HEADER ─────────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card_premium_blue"
                android:orientation="vertical"
                android:padding="24dp"
                android:paddingTop="52dp">

                <!-- Back button row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:layout_marginBottom="20dp">

                    <ImageView
                        android:id="@+id/btnBack"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/bg_circle_white_border"
                        android:padding="8dp"
                        android:src="@drawable/ic_arrow_back"
                        android:clickable="true"
                        android:focusable="true"
                        app:tint="#FFFFFF" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:fontFamily="@font/manrope_bold"
                        android:text="Create Poll"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:alpha="0.9" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_circle_white_border"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="5dp"
                    android:fontFamily="@font/manrope_bold"
                    android:text="NEW NOMINATION"
                    android:textColor="#FFFFFF"
                    android:textSize="10sp"
                    android:alpha="0.85"
                    android:layout_marginBottom="10dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/manrope_bold"
                    android:text="Nominate &amp; Vote"
                    android:textColor="#FFFFFF"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif"
                    android:text="Choose a role, select nominees, and let your group decide."
                    android:textColor="#CCDFFF"
                    android:textSize="14sp"
                    android:lineSpacingExtra="2dp" />

            </LinearLayout>

            <!-- ── SELECT ROLE ───────────────────────────────────── -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="@color/card_surface"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/manrope_bold"
                        android:letterSpacing="0.07"
                        android:text="SELECT ROLE"
                        android:textColor="@color/v_text_muted"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="14dp" />

                    <!-- Role cards (horizontal scroll) -->
                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:scrollbars="none"
                        android:layout_marginHorizontal="-4dp">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:paddingHorizontal="4dp">

                            <!-- Admin Card -->
                            <FrameLayout
                                android:id="@+id/cardAdmin"
                                android:layout_width="112dp"
                                android:layout_height="90dp"
                                android:layout_marginEnd="10dp"
                                android:background="@drawable/bg_role_card_selected"
                                android:clickable="true"
                                android:focusable="true">

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:gravity="center_vertical"
                                    android:orientation="vertical"
                                    android:padding="12dp">

                                    <RelativeLayout
                                        android:layout_width="34dp"
                                        android:layout_height="34dp"
                                        android:background="@drawable/bg_circle_blue"
                                        android:layout_marginBottom="8dp">
                                        <ImageView
                                            android:layout_width="18dp"
                                            android:layout_height="18dp"
                                            android:layout_centerInParent="true"
                                            android:src="@drawable/ic_admin_panel_settings"
                                            app:tint="#FFFFFF" />
                                    </RelativeLayout>

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:fontFamily="@font/manrope_bold"
                                        android:text="Admin"
                                        android:textColor="@color/v_text_dark"
                                        android:textSize="13sp" />

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:fontFamily="sans-serif"
                                        android:text="Governance"
                                        android:textColor="@color/v_text_muted"
                                        android:textSize="10sp" />
                                </LinearLayout>

                                <RelativeLayout
                                    android:id="@+id/badgeAdminSelected"
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:layout_gravity="top|end"
                                    android:layout_margin="6dp"
                                    android:background="@drawable/bg_circle_blue"
                                    android:visibility="visible">
                                    <ImageView
                                        android:layout_width="11dp"
                                        android:layout_height="11dp"
                                        android:layout_centerInParent="true"
                                        android:src="@drawable/ic_check"
                                        app:tint="#FFFFFF" />
                                </RelativeLayout>
                            </FrameLayout>

                            <!-- Treasurer Card -->
                            <FrameLayout
                                android:id="@+id/cardTreasurer"
                                android:layout_width="112dp"
                                android:layout_height="90dp"
                                android:layout_marginEnd="10dp"
                                android:background="@drawable/bg_role_card_unselected"
                                android:clickable="true"
                                android:focusable="true">

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:gravity="center_vertical"
                                    android:orientation="vertical"
                                    android:padding="12dp">

                                    <RelativeLayout
                                        android:layout_width="34dp"
                                        android:layout_height="34dp"
                                        android:background="@drawable/bg_icon_circle_gray_light"
                                        android:layout_marginBottom="8dp">
                                        <ImageView
                                            android:layout_width="18dp"
                                            android:layout_height="18dp"
                                            android:layout_centerInParent="true"
                                            android:src="@drawable/ic_account_balance_wallet"
                                            app:tint="@color/v_text_mid" />
                                    </RelativeLayout>

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:fontFamily="@font/manrope_bold"
                                        android:text="Treasurer"
                                        android:textColor="@color/v_text_dark"
                                        android:textSize="13sp" />

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:fontFamily="sans-serif"
                                        android:text="Finance"
                                        android:textColor="@color/v_text_muted"
                                        android:textSize="10sp" />
                                </LinearLayout>

                                <RelativeLayout
                                    android:id="@+id/badgeTreasurerSelected"
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:layout_gravity="top|end"
                                    android:layout_margin="6dp"
                                    android:background="@drawable/bg_circle_blue"
                                    android:visibility="gone">
                                    <ImageView
                                        android:layout_width="11dp"
                                        android:layout_height="11dp"
                                        android:layout_centerInParent="true"
                                        android:src="@drawable/ic_check"
                                        app:tint="#FFFFFF" />
                                </RelativeLayout>
                            </FrameLayout>

                        </LinearLayout>
                    </HorizontalScrollView>

                    <!-- Chip pills -->
                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:scrollbars="none"
                        android:layout_marginHorizontal="-4dp">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:paddingHorizontal="4dp">

                            <TextView
                                android:id="@+id/chipSecretary"
                                android:layout_width="wrap_content"
                                android:layout_height="34dp"
                                android:layout_marginEnd="8dp"
                                android:background="@drawable/bg_pill_white_border"
                                android:clickable="true"
                                android:focusable="true"
                                android:fontFamily="sans-serif"
                                android:gravity="center"
                                android:paddingHorizontal="16dp"
                                android:text="Secretary"
                                android:textColor="@color/v_text_mid"
                                android:textSize="13sp" />

                            <TextView
                                android:id="@+id/chipModerator"
                                android:layout_width="wrap_content"
                                android:layout_height="34dp"
                                android:layout_marginEnd="8dp"
                                android:background="@drawable/bg_pill_white_border"
                                android:clickable="true"
                                android:focusable="true"
                                android:fontFamily="sans-serif"
                                android:gravity="center"
                                android:paddingHorizontal="16dp"
                                android:text="Moderator"
                                android:textColor="@color/v_text_mid"
                                android:textSize="13sp" />

                            <TextView
                                android:id="@+id/chipCustom"
                                android:layout_width="wrap_content"
                                android:layout_height="34dp"
                                android:background="@drawable/bg_pill_white_border"
                                android:clickable="true"
                                android:focusable="true"
                                android:fontFamily="sans-serif"
                                android:gravity="center"
                                android:paddingHorizontal="16dp"
                                android:text="+ Custom"
                                android:textColor="@color/brand_blue"
                                android:textSize="13sp" />
                        </LinearLayout>
                    </HorizontalScrollView>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── NOMINATE MEMBERS ─────────────────────────────── -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="@color/card_surface"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Header row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:layout_marginBottom="14dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:fontFamily="@font/manrope_bold"
                            android:letterSpacing="0.07"
                            android:text="NOMINATE MEMBERS"
                            android:textColor="@color/v_text_muted"
                            android:textSize="11sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvSelectedCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_pill_light_blue"
                            android:paddingHorizontal="10dp"
                            android:paddingVertical="4dp"
                            android:fontFamily="@font/manrope_bold"
                            android:text="0 selected"
                            android:textColor="@color/brand_blue"
                            android:textSize="11sp"
                            android:visibility="invisible" />
                    </LinearLayout>

                    <!-- Search -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="46dp"
                        android:background="@drawable/bg_rounded_search"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="14dp"
                        android:layout_marginBottom="12dp">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_search"
                            app:tint="@color/v_text_muted" />

                        <EditText
                            android:id="@+id/etSearchMembers"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_marginStart="10dp"
                            android:layout_weight="1"
                            android:background="@null"
                            android:fontFamily="sans-serif"
                            android:hint="Search members…"
                            android:inputType="text"
                            android:maxLines="1"
                            android:textColor="@color/v_text_dark"
                            android:textColorHint="@color/v_text_muted"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <!-- Member list -->
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvNominees"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false" />

                    <TextView
                        android:id="@+id/tvNoMembers"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:fontFamily="sans-serif"
                        android:gravity="center"
                        android:text="No members found"
                        android:textColor="@color/v_text_muted"
                        android:textSize="13sp"
                        android:visibility="gone" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── LAUNCH BUTTON ───────────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="16dp"
                android:paddingTop="16dp">

                <LinearLayout
                    android:id="@+id/btnLaunch"
                    android:layout_width="match_parent"
                    android:layout_height="58dp"
                    android:background="@drawable/bg_loan_submit_btn"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <ProgressBar
                        android:id="@+id/launchProgress"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_marginEnd="10dp"
                        android:indeterminateTint="#FFFFFF"
                        android:visibility="gone" />

                    <ImageView
                        android:id="@+id/ivLaunchIcon"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_marginEnd="10dp"
                        android:src="@drawable/ic_rocket_launch"
                        app:tint="#FFFFFF" />

                    <TextView
                        android:id="@+id/tvLaunchText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/manrope_bold"
                        android:text="Launch Nomination Poll"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:fontFamily="sans-serif"
                    android:gravity="center"
                    android:text="All group members will be notified to vote. Poll expires in 24 hours."
                    android:textColor="@color/v_text_muted"
                    android:textSize="12sp" />
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
