<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingVertical="10dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="4dp">

        <!-- Avatar Circle -->
        <FrameLayout
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_circle_white"
            android:backgroundTint="#F1F5F9">

            <TextView
                android:id="@+id/tvAvatarInitials"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fontFamily="@font/manrope_bold"
                android:gravity="center"
                android:text="SC"
                android:textColor="#64748B"
                android:textSize="12sp" />
        </FrameLayout>

        <!-- Name + Sub -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvMemberName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/manrope_bold"
                android:text="Sunrise Cooperative"
                android:textColor="#0F172A"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tvMemberSub"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/manrope_medium"
                android:text="Top 1 Contributor"
                android:textColor="#94A3B8"
                android:textSize="11sp" />
        </LinearLayout>

        <!-- Efficiency Pct + Progress (Right Aligned) -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvEfficiencyPct"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_badge_success"
                android:backgroundTint="#D1FAE5"
                android:fontFamily="@font/manrope_bold"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"
                android:text="99.2%"
                android:textColor="#10B981"
                android:textSize="10sp" />

            <com.google.android.material.progressindicator.LinearProgressIndicator
                android:id="@+id/progressEfficiency"
                android:layout_width="100dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:progress="99"
                app:indicatorColor="#10B981"
                app:trackColor="#D1FAE5"
                app:trackCornerRadius="4dp"
                app:trackThickness="6dp" />
        </LinearLayout>

        <!-- Amount -->
        <TextView
            android:id="@+id/tvEfficiencyValue"
            android:layout_width="70dp"
            android:layout_height="wrap_content"
            android:fontFamily="@font/manrope_bold"
            android:gravity="end"
            android:text="12.4"
            android:textColor="#0F172A"
            android:textSize="14sp" />
    </LinearLayout>
</LinearLayout>
