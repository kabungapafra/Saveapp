<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="@color/card_surface">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp">

        <TextView
            android:id="@+id/lblApplicant"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/manrope_bold"
            android:letterSpacing="0.1"
            android:text="APPLICANT"
            android:textColor="@color/v_text_muted"
            android:textSize="9sp" />

        <TextView
            android:id="@+id/tvApplicantName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/lblApplicant"
            android:layout_marginTop="4dp"
            android:fontFamily="@font/manrope_bold"
            android:text="Applicant Name"
            android:textColor="@color/v_text_dark"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/lblRequested"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:fontFamily="@font/manrope_bold"
            android:letterSpacing="0.1"
            android:text="REQUESTED"
            android:textColor="@color/v_text_muted"
            android:textSize="9sp" />

        <TextView
            android:id="@+id/tvAmount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/lblRequested"
            android:layout_alignParentEnd="true"
            android:layout_marginTop="2dp"
            android:fontFamily="@font/manrope_bold"
            android:text="$0.00"
            android:textColor="@color/brand_blue"
            android:textSize="17sp" />

        <View
            android:id="@+id/dividerLine"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_below="@id/tvApplicantName"
            android:layout_marginTop="20dp"
            android:background="@color/v_page_bg" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/dividerLine"
            android:layout_marginTop="20dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/manrope_bold"
                    android:letterSpacing="0.1"
                    android:text="SCORE"
                    android:textColor="@color/v_text_muted"
                    android:textSize="8sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/manrope_bold"
                    android:text="795"
                    android:textColor="@color/v_text_dark"
                    android:textSize="12sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="2"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/manrope_bold"
                    android:letterSpacing="0.1"
                    android:text="TIER"
                    android:textColor="@color/v_text_muted"
                    android:textSize="8sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/manrope_bold"
                    android:text="Sovereign Elite"
                    android:textColor="@color/brand_blue"
                    android:textSize="12sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/btnApprove"
                android:layout_width="90dp"
                android:layout_height="32dp"
                android:background="@drawable/bg_btn_primary"
                android:fontFamily="@font/manrope_bold"
                android:gravity="center"
                android:letterSpacing="0.05"
                android:text="REVIEW"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:clickable="true"
                android:focusable="true"/>
                
        </LinearLayout>

    </RelativeLayout>
</androidx.cardview.widget.CardView>
