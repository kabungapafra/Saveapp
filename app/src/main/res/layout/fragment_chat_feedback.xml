<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F2F5">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="64dp">

            <!-- Success Icon -->
            <ImageView
                android:id="@+id/ivSuccess"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:src="@drawable/ic_feedback_success" />

            <!-- Heading -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:fontFamily="sans-serif"
                android:gravity="center"
                android:text="Thank you for chatting with us!"
                android:textColor="#000000"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:fontFamily="sans-serif"
                android:gravity="center"
                android:text="Your session has ended. We'd love to hear about your experience with our support team."
                android:textColor="#6B7280"
                android:textSize="14sp" />

            <!-- Feedback Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif"
                        android:letterSpacing="0.1"
                        android:text="HOW WAS YOUR EXPERIENCE?"
                        android:textColor="#9CA3AF"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <!-- Rating Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:gravity="center"
                        android:orientation="horizontal">

                        <!-- Rating 1 -->
                        <LinearLayout
                            android:id="@+id/llRate1"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">

                            <ImageView
                                android:id="@+id/ivEmoji1"
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:src="@drawable/ic_angry_face" />

                            <TextView
                                android:id="@+id/tvLabel1"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:text="POOR"
                                android:textColor="#9CA3AF"
                                android:textSize="10sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <!-- Rating 2 -->
                        <LinearLayout
                            android:id="@+id/llRate2"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">

                            <ImageView
                                android:id="@+id/ivEmoji2"
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:src="@drawable/ic_sad_face" />

                            <TextView
                                android:id="@+id/tvLabel2"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:text="FAIR"
                                android:textColor="#9CA3AF"
                                android:textSize="10sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <!-- Rating 3 -->
                        <LinearLayout
                            android:id="@+id/llRate3"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">

                            <ImageView
                                android:id="@+id/ivEmoji3"
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:src="@drawable/ic_neutral_face" />

                            <TextView
                                android:id="@+id/tvLabel3"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:text="GOOD"
                                android:textColor="#9CA3AF"
                                android:textSize="10sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <!-- Rating 4 (Selected by default in prompt) -->
                        <LinearLayout
                            android:id="@+id/llRate4"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">

                            <ImageView
                                android:id="@+id/ivEmoji4"
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:src="@drawable/ic_smiling_star_face" />

                            <TextView
                                android:id="@+id/tvLabel4"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:text="GREAT"
                                android:textColor="#215DA1"
                                android:textSize="10sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <!-- Rating 5 -->
                        <LinearLayout
                            android:id="@+id/llRate5"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">

                            <ImageView
                                android:id="@+id/ivEmoji5"
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:src="@drawable/ic_star_struck_face" />

                            <TextView
                                android:id="@+id/tvLabel5"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:text="AMAZING"
                                android:textColor="#9CA3AF"
                                android:textSize="10sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="28dp"
                        android:fontFamily="sans-serif"
                        android:text="Additional Feedback"
                        android:textColor="#374151"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/etFeedback"
                        android:layout_width="match_parent"
                        android:layout_height="120dp"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/bg_feedback_input"
                        android:fontFamily="sans-serif"
                        android:gravity="top"
                        android:hint="Tell us what we did well or how we can improve..."
                        android:padding="16dp"
                        android:textColor="#000000"
                        android:textColorHint="#9CA3AF"
                        android:textSize="14sp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSubmit"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginTop="24dp"
                        android:backgroundTint="#215DA1"
                        android:fontFamily="sans-serif"
                        android:text="Submit &amp; Close"
                        android:textAllCaps="false"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        app:cornerRadius="28dp" />

                    <!-- Session Info Footer -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="28dp"
                        android:background="#F3F4F6" />

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp">

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/clAgentAvatar"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:layout_centerVertical="true"
                            app:cardCornerRadius="18dp"
                            app:cardElevation="0dp">

                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:src="@drawable/ic_profile_placeholder" />
                        </com.google.android.material.card.MaterialCardView>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:layout_marginStart="12dp"
                            android:layout_toEndOf="@id/clAgentAvatar"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="sans-serif"
                                android:text="CHATTING WITH"
                                android:textColor="#9CA3AF"
                                android:textSize="9sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="sans-serif"
                                android:text="Support Specialist Sarah"
                                android:textColor="#374151"
                                android:textSize="12sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:gravity="end"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="sans-serif"
                                android:text="SESSION TIME"
                                android:textColor="#9CA3AF"
                                android:textSize="9sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="sans-serif"
                                android:text="12m 43s"
                                android:textColor="#374151"
                                android:textSize="12sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </RelativeLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- FAQ Row -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="40dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="14dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cvLamp"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        app:cardBackgroundColor="#F3F4F6"
                        app:cardCornerRadius="10dp"
                        app:cardElevation="0dp">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_lightbulb" />
                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:id="@+id/tvFaqText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:layout_marginStart="14dp"
                        android:layout_toStartOf="@id/ivChevron"
                        android:layout_toEndOf="@id/cvLamp"
                        android:fontFamily="sans-serif"
                        android:lineSpacingExtra="2dp"
                        android:text="Found what you were looking for? Check our FAQs for quick answers next time."
                        android:textColor="#374151"
                        android:textSize="13sp" />

                    <ImageView
                        android:id="@+id/ivChevron"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:src="@drawable/ic_chevron_right"
                        app:tint="#D1D5DB" />
                </RelativeLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
