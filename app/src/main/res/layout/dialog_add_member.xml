<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_dialog_rounded"
    android:orientation="vertical">

    <!-- Blue header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/brand_blue"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="22dp"
        android:paddingBottom="26dp">

        <!-- Close row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/btnCloseDialog"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/bg_avatar_circle"
                android:backgroundTint="#22FFFFFF"
                android:padding="9dp"
                android:src="@drawable/ic_close"
                app:tint="#FFFFFF" />

            <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/manrope_bold"
                android:text="Add New Member"
                android:textColor="#FFFFFF"
                android:textSize="15sp" />

            <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />
            <View android:layout_width="36dp" android:layout_height="36dp" />

        </LinearLayout>

        <!-- Icon + tagline -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <FrameLayout
                android:layout_width="56dp"
                android:layout_height="56dp">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_avatar_circle"
                    android:backgroundTint="#2EFFFFFF"
                    android:padding="14dp"
                    android:src="@drawable/ic_person_add"
                    app:tint="#FFFFFF" />

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="end|bottom"
                    android:background="@drawable/bg_avatar_circle"
                    android:backgroundTint="#10B981"
                    android:padding="5dp"
                    android:src="@drawable/ic_add"
                    app:tint="#FFFFFF" />

            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/manrope_bold"
                    android:text="Invite to your group"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:fontFamily="@font/manrope_medium"
                    android:text="They'll receive an SMS to complete setup"
                    android:textColor="#90AECF"
                    android:textSize="12sp" />

            </LinearLayout>
        </LinearLayout>

    </LinearLayout>

    <!-- Form -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@color/v_page_bg"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="22dp"
            android:paddingBottom="12dp">

            <!-- Name -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:fontFamily="@font/manrope_bold"
                android:text="Full Name"
                android:textColor="@color/v_text_dark"
                android:textSize="13sp" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/nameInputLayout"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:boxBackgroundColor="@color/card_surface"
                app:boxCornerRadiusBottomEnd="14dp"
                app:boxCornerRadiusBottomStart="14dp"
                app:boxCornerRadiusTopEnd="14dp"
                app:boxCornerRadiusTopStart="14dp"
                app:boxStrokeColor="@color/v_input_bg"
                app:boxStrokeWidth="0dp"
                app:boxStrokeWidthFocused="1.5dp"
                app:hintEnabled="false"
                app:startIconDrawable="@drawable/ic_person"
                app:startIconTint="@color/v_text_muted">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etMemberName"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:fontFamily="@font/manrope_medium"
                    android:hint="e.g. John Doe"
                    android:inputType="textPersonName"
                    android:textColor="@color/v_text_dark"
                    android:textColorHint="@color/v_text_muted"
                    android:textSize="14sp" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Phone -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:fontFamily="@font/manrope_bold"
                android:text="Phone Number"
                android:textColor="@color/v_text_dark"
                android:textSize="13sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="22dp"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="88dp"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_wizard_input_solid"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:paddingHorizontal="10dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/manrope_medium"
                        android:text="🇺🇬 +256"
                        android:textColor="@color/v_text_dark"
                        android:textSize="13sp" />

                    <ImageView
                        android:layout_width="13dp"
                        android:layout_height="13dp"
                        android:layout_marginStart="4dp"
                        android:src="@drawable/ic_chevron_down"
                        app:tint="@color/v_text_muted" />

                </LinearLayout>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    app:boxBackgroundColor="@color/card_surface"
                    app:boxCornerRadiusBottomEnd="14dp"
                    app:boxCornerRadiusBottomStart="14dp"
                    app:boxCornerRadiusTopEnd="14dp"
                    app:boxCornerRadiusTopStart="14dp"
                    app:boxStrokeColor="@color/v_input_bg"
                    app:boxStrokeWidth="0dp"
                    app:boxStrokeWidthFocused="1.5dp"
                    app:hintEnabled="false">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etMemberPhone"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:fontFamily="@font/manrope_medium"
                        android:hint="700 000 000"
                        android:inputType="phone"
                        android:textColor="@color/v_text_dark"
                        android:textColorHint="@color/v_text_muted"
                        android:textSize="14sp" />

                </com.google.android.material.textfield.TextInputLayout>

            </LinearLayout>

            <!-- PIN (hidden) -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/pinInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"
                app:hintEnabled="false">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etMemberPin"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:inputType="numberPassword"
                    android:maxLength="4" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Role label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:fontFamily="@font/manrope_bold"
                android:text="Role"
                android:textColor="@color/v_text_dark"
                android:textSize="13sp" />

            <!-- Role cards side-by-side -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardRoleMember"
                    android:layout_width="0dp"
                    android:layout_height="120dp"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    app:cardBackgroundColor="@color/card_surface"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/brand_blue"
                    app:strokeWidth="2dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="0dp"
                            android:layout_weight="1">

                            <ImageView
                                android:id="@+id/checkMember"
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:layout_gravity="end|top"
                                android:src="@drawable/ic_check_circle"
                                app:tint="@color/brand_blue" />

                        </FrameLayout>

                        <ImageView
                            android:id="@+id/iconContainerMember"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:layout_marginBottom="6dp"
                            android:background="@drawable/bg_avatar_circle"
                            android:backgroundTint="#EBF0FF"
                            android:padding="9dp"
                            android:src="@drawable/ic_person"
                            app:tint="@color/brand_blue" />

                        <TextView
                            android:id="@+id/titleMember"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/manrope_bold"
                            android:text="Member"
                            android:textColor="@color/v_text_dark"
                            android:textSize="13sp" />

                        <TextView
                            android:id="@+id/descMember"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:fontFamily="@font/manrope_medium"
                            android:gravity="center"
                            android:text="Saves &amp; borrows"
                            android:textColor="@color/v_text_muted"
                            android:textSize="11sp" />

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardRoleAdmin"
                    android:layout_width="0dp"
                    android:layout_height="120dp"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    app:cardBackgroundColor="@color/v_input_bg"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/divider_color"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="0dp"
                            android:layout_weight="1">

                            <ImageView
                                android:id="@+id/checkAdmin"
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:layout_gravity="end|top"
                                android:src="@drawable/ic_check_circle"
                                android:visibility="gone"
                                app:tint="@color/brand_blue" />

                        </FrameLayout>

                        <ImageView
                            android:id="@+id/iconContainerAdmin"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:layout_marginBottom="6dp"
                            android:background="@drawable/bg_avatar_circle"
                            android:backgroundTint="#F1F5F9"
                            android:padding="9dp"
                            android:src="@drawable/ic_shield_auth"
                            app:tint="@color/v_text_muted" />

                        <TextView
                            android:id="@+id/titleAdmin"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/manrope_bold"
                            android:text="Admin"
                            android:textColor="@color/v_text_dark"
                            android:textSize="13sp" />

                        <TextView
                            android:id="@+id/descAdmin"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:fontFamily="@font/manrope_medium"
                            android:gravity="center"
                            android:text="Manages group"
                            android:textColor="@color/v_text_muted"
                            android:textSize="11sp" />

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- CTA -->
    <LinearLayout
        android:id="@+id/bottomContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/card_surface"
        android:elevation="6dp"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="14dp"
        android:paddingBottom="24dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCreateMember"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:fontFamily="@font/manrope_bold"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:text="Add Member"
            android:textAllCaps="false"
            android:textSize="15sp"
            app:backgroundTint="@color/brand_blue"
            app:cornerRadius="16dp"
            app:icon="@drawable/ic_chevron_right"
            app:iconGravity="end"
            app:iconPadding="12dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:fontFamily="@font/manrope_medium"
            android:gravity="center"
            android:text="Member sets their own PIN via SMS verification"
            android:textColor="@color/v_text_muted"
            android:textSize="12sp" />

    </LinearLayout>

</LinearLayout>
