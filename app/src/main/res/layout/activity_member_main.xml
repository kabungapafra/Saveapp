<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FE"
    android:clipChildren="false"
    android:clipToPadding="false">

    <!-- Fragment Container -->
    <FrameLayout
        android:id="@+id/fragment_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- Floating Blue Nav Bar with Cutout (Admin Style) -->
    <com.example.save.ui.views.CutoutNavView
        android:id="@+id/navContainer"
        android:layout_width="0dp"
        android:layout_height="72dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="20dp"
        android:background="@drawable/bg_nav_bar_blue"
        android:elevation="0dp"
        android:clipChildren="false"
        android:clipToPadding="false"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal">

            <!-- Home -->
            <LinearLayout
                android:id="@+id/nav_dashboard"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:background="?attr/selectableItemBackgroundBorderless">
                <ImageView
                    android:id="@+id/img_dashboard"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_home"
                    app:tint="#FFFFFF" />
                <TextView
                    android:id="@+id/txt_dashboard"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:fontFamily="@font/manrope_bold"
                    android:text="Home"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp" />
            </LinearLayout>

            <!-- Members -->
            <LinearLayout
                android:id="@+id/nav_members"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:background="?attr/selectableItemBackgroundBorderless">
                <ImageView
                    android:id="@+id/img_members"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_people"
                    app:tint="#B3FFFFFF" />
                <TextView
                    android:id="@+id/txt_members"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:fontFamily="@font/manrope_bold"
                    android:text="Members"
                    android:textColor="#B3FFFFFF"
                    android:textSize="11sp" />
            </LinearLayout>

            <!-- Action Spacer -->
            <View
                android:id="@+id/nav_action_space"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:visibility="invisible" />

            <!-- Analysis -->
            <LinearLayout
                android:id="@+id/nav_analysis"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:background="?attr/selectableItemBackgroundBorderless">
                <ImageView
                    android:id="@+id/img_analysis"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_analytics"
                    app:tint="#B3FFFFFF" />
                <TextView
                    android:id="@+id/txt_analysis"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:fontFamily="@font/manrope_bold"
                    android:text="Analysis"
                    android:textColor="#B3FFFFFF"
                    android:textSize="11sp" />
            </LinearLayout>

            <!-- Settings -->
            <LinearLayout
                android:id="@+id/nav_settings"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:background="?attr/selectableItemBackgroundBorderless">
                <ImageView
                    android:id="@+id/img_settings"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_settings"
                    app:tint="#B3FFFFFF" />
                <TextView
                    android:id="@+id/txt_settings"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:fontFamily="@font/manrope_bold"
                    android:text="Settings"
                    android:textColor="#B3FFFFFF"
                    android:textSize="11sp" />
            </LinearLayout>

        </LinearLayout>
    </com.example.save.ui.views.CutoutNavView>

    <!-- Protruding White FAB (Admin Style) -->
    <FrameLayout
        android:id="@+id/navAction"
        android:layout_width="84dp"
        android:layout_height="84dp"
        android:layout_marginTop="-16dp"
        android:elevation="16dp"
        android:clipChildren="false"
        android:clipToPadding="false"
        app:layout_constraintEnd_toEndOf="@id/navContainer"
        app:layout_constraintStart_toStartOf="@id/navContainer"
        app:layout_constraintTop_toTopOf="@id/navContainer">

        <View
            android:id="@+id/navActionDashedRing"
            android:layout_width="84dp"
            android:layout_height="84dp"
            android:layout_gravity="center"
            android:background="@drawable/bg_nav_center_dashed_ring_white" />

        <View
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_gravity="center"
            android:background="@drawable/bg_nav_center_action_blue"
            android:elevation="2dp" />

        <ImageView
            android:id="@+id/navActionPlusIcon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="center"
            android:elevation="3dp"
            android:src="@drawable/ic_add"
            app:tint="@color/white" />
    </FrameLayout>

    <!-- Quick Actions Overlay -->
    <include
        android:id="@+id/quickActionsOverlay"
        layout="@layout/layout_quick_actions_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:elevation="30dp"
        android:visibility="gone" />

</androidx.constraintlayout.widget.ConstraintLayout>
