<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dashboard_bg">

    <!-- Content area — constrained above the nav bar -->
    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipeRefreshLayout"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/navContainer">

        <FrameLayout
            android:id="@+id/fragment_container"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    <!-- Stub so R.id.navAction still compiles in fragments that reference it -->
    <View
        android:id="@+id/navAction"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Bottom nav — full width, flush to screen bottom -->
    <LinearLayout
        android:id="@+id/navContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/card_surface"
        android:elevation="10dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Hairline separator -->
        <View
            android:layout_width="match_parent"
            android:layout_height="0.8dp"
            android:background="@color/divider_color" />

        <!-- Nav items -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="8dp"
            android:paddingTop="8dp"
            android:paddingBottom="16dp">

            <!-- HOME -->
            <LinearLayout
                android:id="@+id/navDashboard"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <LinearLayout
                    android:id="@+id/pillDashboard"
                    android:layout_width="52dp"
                    android:layout_height="32dp"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:background="@drawable/bg_nav_pill_active">

                    <ImageView
                        android:id="@+id/imgDashboard"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_home"
                        app:tint="#FFFFFF" />
                </LinearLayout>

                <TextView
                    android:id="@+id/txtDashboard"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:text="Home"
                    android:textColor="#FFFFFF"
                    android:textSize="9sp"
                    android:fontFamily="@font/manrope_bold"
                    android:maxLines="1"
                    android:ellipsize="none"
                    android:visibility="visible" />
            </LinearLayout>

            <!-- SAVINGS -->
            <LinearLayout
                android:id="@+id/navLoans"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <LinearLayout
                    android:id="@+id/pillLoans"
                    android:layout_width="52dp"
                    android:layout_height="32dp"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <ImageView
                        android:id="@+id/imgLoans"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_wallet_safe_blue"
                        app:tint="#9CA3AF" />
                </LinearLayout>

                <TextView
                    android:id="@+id/txtLoans"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:text="Savings"
                    android:textColor="#9CA3AF"
                    android:textSize="9sp"
                    android:fontFamily="@font/manrope_bold"
                    android:maxLines="1"
                    android:ellipsize="none"
                    android:visibility="visible" />
            </LinearLayout>

            <!-- LOANS — hidden on member side -->
            <LinearLayout
                android:id="@+id/navSavings"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:visibility="gone">

                <LinearLayout
                    android:id="@+id/pillSavings"
                    android:layout_width="52dp"
                    android:layout_height="32dp"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <ImageView
                        android:id="@+id/imgSavings"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_bank_filled"
                        app:tint="#9CA3AF" />
                </LinearLayout>

                <TextView
                    android:id="@+id/txtSavings"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:text="Loans"
                    android:textColor="#9CA3AF"
                    android:textSize="9sp"
                    android:fontFamily="@font/manrope_bold"
                    android:maxLines="1"
                    android:ellipsize="none"
                    android:visibility="visible" />
            </LinearLayout>

            <!-- ACTIVITY -->
            <LinearLayout
                android:id="@+id/navPayouts"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <LinearLayout
                    android:id="@+id/pillPayouts"
                    android:layout_width="52dp"
                    android:layout_height="32dp"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <ImageView
                        android:id="@+id/imgPayouts"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_history"
                        app:tint="#9CA3AF" />
                </LinearLayout>

                <TextView
                    android:id="@+id/txtPayouts"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:text="Activity"
                    android:textColor="#9CA3AF"
                    android:textSize="9sp"
                    android:fontFamily="@font/manrope_bold"
                    android:maxLines="1"
                    android:ellipsize="none"
                    android:visibility="visible" />
            </LinearLayout>

            <!-- PROFILE -->
            <LinearLayout
                android:id="@+id/navSettings"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <LinearLayout
                    android:id="@+id/pillSettings"
                    android:layout_width="52dp"
                    android:layout_height="32dp"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <ImageView
                        android:id="@+id/imgSettings"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_person"
                        app:tint="#9CA3AF" />
                </LinearLayout>

                <TextView
                    android:id="@+id/txtSettings"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:text="Profile"
                    android:textColor="#9CA3AF"
                    android:textSize="9sp"
                    android:fontFamily="@font/manrope_bold"
                    android:maxLines="1"
                    android:ellipsize="none"
                    android:visibility="visible" />
            </LinearLayout>

        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
