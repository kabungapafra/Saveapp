<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_geometric_pattern">

    <!-- Fragment Container -->
    <FrameLayout
        android:id="@+id/fragment_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Enhanced Bottom Navigation Bar -->
    <androidx.cardview.widget.CardView
        android:id="@+id/navContainer"
        android:layout_width="340dp"
        android:layout_height="65dp"
        android:layout_marginBottom="24dp"
        app:cardBackgroundColor="#1E293B"
        app:cardCornerRadius="32dp"
        app:cardElevation="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingHorizontal="12dp">

            <!-- Home (Dashboard) -->
            <LinearLayout
                android:id="@+id/nav_dashboard"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/img_dashboard"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_home"
                    app:tint="#94A3B8" />

                <TextView
                    android:id="@+id/txt_dashboard"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:fontFamily="sans-serif-bold"
                    android:text="HOME"
                    android:textColor="#94A3B8"
                    android:textSize="10sp"
                    android:visibility="gone" />
            </LinearLayout>


            <!-- Loans (Members) -->
            <LinearLayout
                android:id="@+id/nav_members"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/img_members"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_bank_filled"
                    app:tint="#94A3B8" />

                <TextView
                    android:id="@+id/txt_members"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:fontFamily="sans-serif-bold"
                    android:text="LOANS"
                    android:textColor="#94A3B8"
                    android:textSize="10sp"
                    android:visibility="gone" />
            </LinearLayout>

            <!-- Notifications -->
            <LinearLayout
                android:id="@+id/nav_notifications"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="horizontal">

                <FrameLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">
                    <ImageView
                        android:id="@+id/img_notifications"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_bell_premium"
                        app:tint="#94A3B8" />
                    <View
                        android:id="@+id/dot_notifications"
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:layout_gravity="top|end"
                        android:background="@drawable/bg_circle_blue_glow"
                        android:visibility="visible" />
                </FrameLayout>

                <TextView
                    android:id="@+id/txt_notifications"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:fontFamily="sans-serif-bold"
                    android:text="NOTIFS"
                    android:textColor="#94A3B8"
                    android:textSize="10sp"
                    android:visibility="gone" />
            </LinearLayout>

            <!-- Stats (REPORTS) -->
            <LinearLayout
                android:id="@+id/nav_stats"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1.2"
                android:gravity="center"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/img_stats"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_stats"
                    app:tint="#3B82F6" />

                <TextView
                    android:id="@+id/txt_stats"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:fontFamily="sans-serif-bold"
                    android:text="REPORTS"
                    android:textColor="#3B82F6"
                    android:textSize="10sp"
                    android:visibility="visible" />
            </LinearLayout>

            <!-- Settings (PROFILE) -->
            <LinearLayout
                android:id="@+id/nav_settings"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/img_settings"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_person"
                    app:tint="#94A3B8" />

                <TextView
                    android:id="@+id/txt_settings"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:fontFamily="sans-serif-bold"
                    android:text="PROFILE"
                    android:textColor="#94A3B8"
                    android:textSize="10sp"
                    android:visibility="gone" />
            </LinearLayout>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>
