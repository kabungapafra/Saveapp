<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F6F9">

    <!-- Pager centered in the remaining space -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPager"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- Bottom Actions Container -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/bottomActions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_bottom_sheet_rounded"
        android:backgroundTint="@color/white"
        android:elevation="24dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Page Indicators -->
        <LinearLayout
            android:id="@+id/pagerIndicators"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="horizontal"
            android:gravity="center"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <View
                android:id="@+id/indicator1"
                android:layout_width="24dp"
                android:layout_height="6dp"
                android:background="@drawable/bg_pill_tab_selected"
                android:backgroundTint="#215DA1"
                android:layout_marginHorizontal="4dp" />
            
            <View
                android:id="@+id/indicator2"
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:background="@drawable/bg_pill_tab_selected"
                android:backgroundTint="#E2E8F0"
                android:layout_marginHorizontal="4dp" />
            
            <View
                android:id="@+id/indicator3"
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:background="@drawable/bg_pill_tab_selected"
                android:backgroundTint="#E2E8F0"
                android:layout_marginHorizontal="4dp" />
        </LinearLayout>

        <!-- Next Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnNext"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="24dp"
            android:text="Next"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:fontFamily="@font/manrope_bold"
            app:backgroundTint="#215DA1"
            app:cornerRadius="16dp"
            app:layout_constraintTop_toBottomOf="@id/pagerIndicators" />

        <!-- Terms Text -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="32dp"
            android:fontFamily="@font/manrope_medium"
            android:text="By continuing, you agree to the Circle Terms of Service"
            android:textColor="#94A3B8"
            android:textSize="12sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/btnNext" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
