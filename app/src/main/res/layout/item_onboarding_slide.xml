<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Top Soft Gradient Header -->
    <View
        android:id="@+id/gradientHeader"
        android:layout_width="match_parent"
        android:layout_height="350dp"
        android:background="#1A3B8CF8"
        app:layout_constraintTop_toTopOf="parent" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:clipToPadding="false"
        android:paddingBottom="120dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:gravity="center_horizontal"
            android:paddingTop="60dp">

            <!-- Logo Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/logoCard"
                android:layout_width="96dp"
                android:layout_height="96dp"
                app:cardBackgroundColor="@color/card_surface"
                app:cardCornerRadius="24dp"
                app:cardElevation="8dp"
                app:strokeWidth="0dp">

                <ImageView
                    android:id="@+id/slideLogo"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:layout_gravity="center"
                    android:src="@drawable/save_logo"
                    android:scaleType="fitCenter" />
            </com.google.android.material.card.MaterialCardView>

            <!-- Pill -->
            <TextView
                android:id="@+id/slidePill"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:background="@drawable/bg_pill_light_blue"
                android:backgroundTint="#FFEDD5"
                android:fontFamily="@font/manrope_bold"
                android:paddingHorizontal="16dp"
                android:paddingVertical="6dp"
                android:text="NEW MEMBER"
                android:textColor="#C2410C"
                android:textSize="11sp"
                android:letterSpacing="0.05" />

            <!-- Title -->
            <TextView
                android:id="@+id/slideTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:fontFamily="@font/manrope_bold"
                android:text="Welcome to the\nCircle."
                android:gravity="center"
                android:textColor="@color/v_text_dark"
                android:textSize="36sp"
                android:lineSpacingExtra="-4dp" />

            <!-- Subtitle -->
            <TextView
                android:id="@+id/slideSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginHorizontal="8dp"
                android:fontFamily="@font/manrope_medium"
                android:text="You've been hand-invited to join a trusted ecosystem of collaborative savers."
                android:gravity="center"
                android:textColor="@color/v_text_mid"
                android:textSize="16sp"
                android:lineSpacingExtra="4dp" />

            <!-- Cards Container -->
            <LinearLayout
                android:id="@+id/featuresContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="32dp">

                <!-- Feature Card 1 Template -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/featureCard1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardBackgroundColor="@color/card_surface"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="20dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <FrameLayout
                            android:id="@+id/featureIconBg1"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_icon_squircle"
                            android:backgroundTint="#E9F2FB">
                            
                            <ImageView
                                android:id="@+id/featureIcon1"
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_people"
                                app:tint="@color/brand_blue" />
                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="16dp"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/featureTitle1"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/manrope_bold"
                                android:text="Community Trust"
                                android:textColor="@color/v_text_dark"
                                android:textSize="16sp" />

                            <TextView
                                android:id="@+id/featureSub1"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:fontFamily="@font/manrope_medium"
                                android:text="Join an exclusive group where every member is verified by the circle."
                                android:textColor="@color/v_text_mid"
                                android:textSize="13sp"
                                android:lineSpacingExtra="2dp" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Feature Card 2 Template -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/featureCard2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardBackgroundColor="@color/card_surface"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="20dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <FrameLayout
                            android:id="@+id/featureIconBg2"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_icon_squircle"
                            android:backgroundTint="#FFF7ED">
                            
                            <ImageView
                                android:id="@+id/featureIcon2"
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_trending_up"
                                app:tint="#EA580C" />
                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="16dp"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/featureTitle2"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/manrope_bold"
                                android:text="Collaborative Growth"
                                android:textColor="@color/v_text_dark"
                                android:textSize="16sp" />

                            <TextView
                                android:id="@+id/featureSub2"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:fontFamily="@font/manrope_medium"
                                android:text="Build collective wealth through scheduled and transparent group funds."
                                android:textColor="@color/v_text_mid"
                                android:textSize="13sp"
                                android:lineSpacingExtra="2dp" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
