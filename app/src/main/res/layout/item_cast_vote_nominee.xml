<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="84dp"
    android:layout_marginBottom="16dp"
    android:background="@drawable/bg_neumorphic_card_raised"
    android:clickable="true"
    android:focusable="true"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingHorizontal="20dp">

    <!-- Avatar -->
    <RelativeLayout
        android:id="@+id/avatarBg"
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:background="@drawable/bg_avatar_purple">

        <TextView
            android:id="@+id/tvNomineeInitials"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:fontFamily="@font/manrope_bold"
            android:text="?"
            android:textColor="#FFFFFF"
            android:textSize="18sp" />
    </RelativeLayout>

    <!-- Name and role -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvNomineeName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/manrope_bold"
            android:text=""
            android:textColor="@color/v_text_dark"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvNomineeRole"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:fontFamily="sans-serif"
            android:text=""
            android:textColor="@color/v_text_mid"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- Radio indicator -->
    <ImageView
        android:id="@+id/ivRadio"
        android:layout_width="26dp"
        android:layout_height="26dp"
        android:src="@drawable/bg_circle_outline_gray" />

</LinearLayout>
