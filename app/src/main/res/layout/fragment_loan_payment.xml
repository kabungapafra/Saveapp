<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/v_page_bg">

    <!-- HEADER -->
    <RelativeLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/card_surface"
        android:elevation="4dp"
        android:paddingHorizontal="16dp"
        android:paddingVertical="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:background="@drawable/bg_input_bg_circle"
            android:padding="10dp"
            android:src="@drawable/ic_arrow_back"
            app:tint="@color/v_text_dark" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:fontFamily="@font/poppins"
            android:text="Repay Loan"
            android:textColor="@color/v_text_dark"
            android:textSize="@dimen/text_size_normal" />

        <ImageView
            android:id="@+id/btnHistory"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="@drawable/bg_input_bg_circle"
            android:padding="9dp"
            android:src="@drawable/ic_history"
            app:tint="@color/v_text_dark" />
    </RelativeLayout>

    <!-- EMPTY STATE (no active loan) -->
    <LinearLayout
        android:id="@+id/emptyState"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingHorizontal="40dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/header">

        <ImageView
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:src="@drawable/ic_shield_check"
            app:tint="#10B981" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:fontFamily="@font/manrope_bold"
            android:text="You're all clear!"
            android:textColor="@color/v_text_dark"
            android:textSize="20sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:fontFamily="@font/manrope_medium"
            android:gravity="center"
            android:lineSpacingMultiplier="1.4"
            android:text="You have no active loan to repay right now."
            android:textColor="@color/v_text_muted"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- CONTENT -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/contentScroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@id/bottomAction"
        app:layout_constraintTop_toBottomOf="@id/header">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="24dp">

            <!-- LOAN SUMMARY HERO -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="24dp"
                app:cardElevation="6dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_card_premium_blue"
                    android:orientation="vertical"
                    android:padding="22dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:alpha="0.85"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.08"
                        android:text="OUTSTANDING BALANCE"
                        android:textColor="@color/permanent_white"
                        android:textSize="@dimen/text_size_xs" />

                    <TextView
                        android:id="@+id/tvRemainingAmount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:fontFamily="@font/poppins"
                        android:text="UGX 0"
                        android:textColor="@color/permanent_white"
                        android:textSize="@dimen/text_size_xxxl"
                        tools:text="UGX 550,000" />

                    <com.google.android.material.progressindicator.LinearProgressIndicator
                        android:id="@+id/loanProgressRail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:progress="0"
                        app:indicatorColor="@color/permanent_white"
                        app:trackColor="#55FFFFFF"
                        app:trackCornerRadius="6dp"
                        app:trackThickness="8dp" />

                    <TextView
                        android:id="@+id/tvRepaidPercentBadge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:alpha="0.9"
                        android:fontFamily="@font/manrope_medium"
                        android:text="0% repaid"
                        android:textColor="@color/permanent_white"
                        android:textSize="13sp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="18dp"
                        android:background="@color/divider_color" />

                    <!-- Loan breakdown -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:alpha="0.8"
                                android:fontFamily="@font/montserrat"
                                android:text="Principal"
                                android:textColor="@color/permanent_white"
                                android:textSize="@dimen/text_size_xs" />

                            <TextView
                                android:id="@+id/tvPrincipal"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:fontFamily="@font/manrope_bold"
                                android:text="—"
                                android:textColor="@color/permanent_white"
                                android:textSize="14sp"
                                tools:text="500,000" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:alpha="0.8"
                                android:fontFamily="@font/montserrat"
                                android:text="Interest"
                                android:textColor="@color/permanent_white"
                                android:textSize="@dimen/text_size_xs" />

                            <TextView
                                android:id="@+id/tvInterest"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:fontFamily="@font/manrope_bold"
                                android:text="—"
                                android:textColor="@color/permanent_white"
                                android:textSize="14sp"
                                tools:text="50,000" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:alpha="0.8"
                                android:fontFamily="@font/montserrat"
                                android:text="Due date"
                                android:textColor="@color/permanent_white"
                                android:textSize="@dimen/text_size_xs" />

                            <TextView
                                android:id="@+id/tvDueDate"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:fontFamily="@font/manrope_bold"
                                android:text="—"
                                android:textColor="@color/permanent_white"
                                android:textSize="14sp"
                                tools:text="Aug 15" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- AMOUNT TO PAY -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:fontFamily="@font/manrope_bold"
                android:text="Amount to Pay"
                android:textColor="@color/v_text_dark"
                android:textSize="15sp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                app:cardBackgroundColor="@color/card_surface"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/divider_color"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="18dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:fontFamily="@font/manrope_bold"
                        android:text="UGX"
                        android:textColor="@color/v_text_muted"
                        android:textSize="16sp" />

                    <EditText
                        android:id="@+id/etAmount"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@null"
                        android:fontFamily="@font/manrope_bold"
                        android:hint="0"
                        android:inputType="number"
                        android:textColor="@color/v_text_dark"
                        android:textColorHint="@color/v_text_muted"
                        android:textSize="24sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Quick amounts -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnQuarter"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:fontFamily="@font/manrope_bold"
                    android:text="25%"
                    android:textAllCaps="false"
                    android:textColor="@color/brand_blue"
                    android:textSize="13sp"
                    app:cornerRadius="12dp"
                    app:strokeColor="@color/divider_color"
                    app:strokeWidth="1dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnHalf"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:fontFamily="@font/manrope_bold"
                    android:text="50%"
                    android:textAllCaps="false"
                    android:textColor="@color/brand_blue"
                    android:textSize="13sp"
                    app:cornerRadius="12dp"
                    app:strokeColor="@color/divider_color"
                    app:strokeWidth="1dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnMax"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:fontFamily="@font/manrope_bold"
                    android:text="Full"
                    android:textAllCaps="false"
                    android:textColor="@color/brand_blue"
                    android:textSize="13sp"
                    app:cornerRadius="12dp"
                    app:strokeColor="@color/divider_color"
                    app:strokeWidth="1dp" />
            </LinearLayout>

            <!-- PHONE NUMBER -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:fontFamily="@font/manrope_bold"
                android:text="Mobile Money Number"
                android:textColor="@color/v_text_dark"
                android:textSize="15sp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                app:cardBackgroundColor="@color/card_surface"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/divider_color"
                app:strokeWidth="1dp">

                <EditText
                    android:id="@+id/etPhoneNumber"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:background="@null"
                    android:fontFamily="@font/manrope_bold"
                    android:hint="e.g. 0755123456"
                    android:inputType="phone"
                    android:paddingHorizontal="18dp"
                    android:textColor="@color/v_text_dark"
                    android:textColorHint="@color/v_text_muted"
                    android:textSize="17sp" />
            </com.google.android.material.card.MaterialCardView>

            <!-- PAYMENT METHOD -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:fontFamily="@font/manrope_bold"
                android:text="Payment Method"
                android:textColor="@color/v_text_dark"
                android:textSize="15sp" />

            <!-- Airtel -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/cardAirtel"
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_item_premium_white"
                android:elevation="4dp"
                android:paddingHorizontal="16dp">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/logoAirtel"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="0dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:strokeColor="@color/v_page_bg"
                    app:strokeWidth="1dp">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="8dp"
                        android:src="@drawable/ic_airtel_logo" />
                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:fontFamily="@font/manrope_bold"
                    android:text="Airtel Money"
                    android:textColor="@color/v_text_dark"
                    android:textSize="16sp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/radioAirtel"
                    app:layout_constraintStart_toEndOf="@id/logoAirtel"
                    app:layout_constraintTop_toTopOf="parent" />

                <RadioButton
                    android:id="@+id/radioAirtel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:buttonTint="@color/brand_blue"
                    android:checked="true"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- MTN -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/cardMTN"
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_payment_card_unselected"
                android:paddingHorizontal="16dp">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/logoMTN"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="0dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:strokeColor="@color/v_page_bg"
                    app:strokeWidth="1dp">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="8dp"
                        android:src="@drawable/ic_mtn_logo" />
                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:fontFamily="@font/manrope_bold"
                    android:text="MTN MoMo"
                    android:textColor="@color/v_text_dark"
                    android:textSize="16sp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/radioMTN"
                    app:layout_constraintStart_toEndOf="@id/logoMTN"
                    app:layout_constraintTop_toTopOf="parent" />

                <RadioButton
                    android:id="@+id/radioMTN"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:buttonTint="@color/v_text_muted"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />
            </androidx.constraintlayout.widget.ConstraintLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- FOOTER ACTION -->
    <LinearLayout
        android:id="@+id/bottomAction"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/card_surface"
        android:elevation="8dp"
        android:orientation="vertical"
        android:padding="16dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPayLoan"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:fontFamily="@font/manrope_bold"
            android:stateListAnimator="@null"
            android:text="Pay Now"
            android:textAllCaps="false"
            android:textSize="17sp"
            app:backgroundTint="@color/brand_blue"
            app:cornerRadius="16dp"
            app:icon="@drawable/ic_lock"
            app:iconGravity="textStart"
            app:iconPadding="10dp"
            app:iconTint="#FFFFFF" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="12dp"
            android:drawableStart="@drawable/ic_lock"
            android:drawablePadding="6dp"
            android:fontFamily="@font/manrope_bold"
            android:gravity="center_vertical"
            android:letterSpacing="0.08"
            android:text="SECURE ENCRYPTED TRANSACTION"
            android:textColor="@color/v_text_muted"
            android:textSize="10sp"
            app:drawableTint="@color/v_text_muted" />
    </LinearLayout>

    <!-- SUCCESS ANIMATION OVERLAY -->
    <View
        android:id="@+id/animationOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#80000000"
        android:elevation="100dp"
        android:visibility="gone" />

    <com.airbnb.lottie.LottieAnimationView
        android:id="@+id/successAnimation"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:elevation="101dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:lottie_autoPlay="false"
        app:lottie_loop="false"
        app:lottie_rawRes="@raw/success_animation" />

</androidx.constraintlayout.widget.ConstraintLayout>
