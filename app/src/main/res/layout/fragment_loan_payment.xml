<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FBFBFB">

    <!-- HEADER -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="8dp"
            android:src="@drawable/ic_arrow_back"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="#215DA1" />

        <ImageView
            android:id="@+id/logo"
            android:layout_width="100dp"
            android:layout_height="40dp"
            android:src="@drawable/save_logo"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/btnHistory"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="8dp"
            android:src="@drawable/ic_history"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="#215DA1" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@id/bottomAction"
        app:layout_constraintTop_toBottomOf="@id/header">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="24dp"
            android:paddingTop="32dp">

            <!-- CIRCULAR PROGRESS SECTION -->
            <FrameLayout
                android:id="@+id/progressContainer"
                android:layout_width="260dp"
                android:layout_height="260dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <com.google.android.material.progressindicator.CircularProgressIndicator
                    android:id="@+id/loanProgressRail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    app:indicatorColor="#215DA1"
                    app:indicatorSize="240dp"
                    app:trackColor="#E1EAFE"
                    app:trackThickness="16dp"
                    android:progress="75"
                    app:trackCornerRadius="8dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/manrope_bold"
                        android:text="REMAINING"
                        android:textColor="#64748B"
                        android:textSize="14sp"
                        android:letterSpacing="0.05" />

                    <TextView
                        android:id="@+id/tvRemainingAmount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/manrope_bold"
                        android:text="450,000"
                        android:textColor="#0F172A"
                        android:textSize="36sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/manrope_bold"
                        android:text="UGX"
                        android:textColor="#215DA1"
                        android:textSize="15sp" />

                    <TextView
                        android:id="@+id/tvRepaidPercentBadge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:background="@drawable/bg_pill_repaid_badge"
                        android:fontFamily="@font/manrope_bold"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="8dp"
                        android:text="75% Repaid"
                        android:textColor="#92400E"
                        android:textSize="13sp" />
                </LinearLayout>
            </FrameLayout>

            <!-- AMOUNT TO PAY SECTION -->
            <TextView
                android:id="@+id/lblAmountToPay"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="48dp"
                android:fontFamily="@font/manrope_medium"
                android:text="Amount to Pay"
                android:textColor="#475569"
                android:textSize="15sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/progressContainer" />

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/amountInputContainer"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_repayment_amount_input"
                android:paddingHorizontal="20dp"
                app:layout_constraintTop_toBottomOf="@id/lblAmountToPay">

                <EditText
                    android:id="@+id/etAmount"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:background="@null"
                    android:fontFamily="@font/manrope_bold"
                    android:hint="0"
                    android:inputType="numberDecimal"
                    android:text="150,000"
                    android:textColor="#0F172A"
                    android:textSize="28sp"
                    app:layout_constraintEnd_toStartOf="@id/currencyGroup"
                    app:layout_constraintStart_toStartOf="parent" />

                <LinearLayout
                    android:id="@+id/currencyGroup"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/manrope_bold"
                        android:text="UGX"
                        android:layout_marginEnd="12dp"
                        android:textColor="#475569"
                        android:textSize="15sp" />

                    <TextView
                        android:id="@+id/btnMax"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_max_button"
                        android:clickable="true"
                        android:focusable="true"
                        android:fontFamily="@font/manrope_bold"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="8dp"
                        android:text="MAX"
                        android:textColor="#215DA1"
                        android:textSize="12sp" />
                </LinearLayout>
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- PHONE NUMBER SECTION -->
            <TextView
                android:id="@+id/lblPhoneNumber"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:fontFamily="@font/manrope_medium"
                android:text="Phone Number"
                android:textColor="#475569"
                android:textSize="15sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/amountInputContainer" />

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/phoneInputContainer"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_repayment_amount_input"
                android:paddingHorizontal="20dp"
                app:layout_constraintTop_toBottomOf="@id/lblPhoneNumber">

                <EditText
                    android:id="@+id/etPhoneNumber"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@null"
                    android:fontFamily="@font/manrope_bold"
                    android:hint="e.g. 0755123456"
                    android:inputType="phone"
                    android:textColor="#0F172A"
                    android:textSize="18sp" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- PAYMENT METHOD SECTION -->
            <TextView
                android:id="@+id/lblPaymentMethod"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:fontFamily="@font/manrope_medium"
                android:text="Payment Method"
                android:textColor="#475569"
                android:textSize="15sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/phoneInputContainer" />

            <!-- Airtel Money Item -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/cardAirtel"
                android:layout_width="match_parent"
                android:layout_height="88dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_item_premium_white"
                android:elevation="4dp"
                android:paddingHorizontal="16dp"
                app:layout_constraintTop_toBottomOf="@id/lblPaymentMethod">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/logoAirtel"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="0dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:strokeWidth="1dp"
                    app:strokeColor="#F1F5F9">
                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/ic_airtel_logo"
                        android:padding="8dp"/>
                </com.google.android.material.card.MaterialCardView>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:orientation="vertical"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/radioAirtel"
                    app:layout_constraintStart_toEndOf="@id/logoAirtel"
                    app:layout_constraintTop_toTopOf="parent">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/manrope_bold"
                        android:text="Airtel Money"
                        android:textColor="#0F172A"
                        android:textSize="16sp" />

                    <TextView
                        android:id="@+id/tvAirtelNumber"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:fontFamily="@font/manrope_medium"
                        android:text="0755 • • • 432"
                        android:textColor="#64748B"
                        android:textSize="13sp" />
                </LinearLayout>

                <RadioButton
                    android:id="@+id/radioAirtel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:buttonTint="#215DA1"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- MTN MoMo Item -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/cardMTN"
                android:layout_width="match_parent"
                android:layout_height="88dp"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="32dp"
                android:background="@drawable/bg_payment_card_unselected"
                android:paddingHorizontal="16dp"
                app:layout_constraintTop_toBottomOf="@id/cardAirtel">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/logoMTN"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="0dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:strokeWidth="1dp"
                    app:strokeColor="#F1F5F9">
                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/ic_mtn_logo"
                        android:padding="8dp"/>
                </com.google.android.material.card.MaterialCardView>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:orientation="vertical"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/radioMTN"
                    app:layout_constraintStart_toEndOf="@id/logoMTN"
                    app:layout_constraintTop_toTopOf="parent">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/manrope_bold"
                        android:text="MTN MoMo"
                        android:textColor="#0F172A"
                        android:textSize="16sp" />

                    <TextView
                        android:id="@+id/tvMTNNumber"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:fontFamily="@font/manrope_medium"
                        android:text="0772 • • • 891"
                        android:textColor="#64748B"
                        android:textSize="13sp" />
                </LinearLayout>

                <RadioButton
                    android:id="@+id/radioMTN"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="false"
                    android:buttonTint="#CBD5E1"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="100dp"
                app:layout_constraintTop_toBottomOf="@id/cardMTN"/>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- FOOTER ACTION -->
    <LinearLayout
        android:id="@+id/bottomAction"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:orientation="vertical"
        android:padding="20dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPayLoan"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:fontFamily="@font/manrope_bold"
            android:text="Pay Now"
            android:textAllCaps="false"
            android:textSize="18sp"
            app:backgroundTint="#215DA1"
            app:cornerRadius="16dp"
            app:icon="@drawable/ic_lock"
            app:iconGravity="textStart"
            app:iconPadding="12dp"
            app:iconTint="@color/white"
            android:elevation="8dp"
            android:stateListAnimator="@null" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="16dp"
            android:fontFamily="@font/manrope_bold"
            android:letterSpacing="0.1"
            android:text="SECURE SSL ENCRYPTED TRANSACTION"
            android:textColor="#94A3B8"
            android:textSize="10sp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
