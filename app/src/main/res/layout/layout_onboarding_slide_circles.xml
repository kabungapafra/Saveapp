<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/neumorphic_bg">

    <!-- HEADER: logo badge + centered "Save" -->
    <FrameLayout
        android:id="@+id/logo_icon"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="24dp"
        android:layout_marginTop="24dp"
        android:background="@drawable/bg_neumorphic_pill"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <com.google.android.material.imageview.ShapeableImageView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_gravity="center"
            android:scaleType="centerCrop"
            android:src="@mipmap/ic_launcher"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.App.Circle" />
    </FrameLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/manrope_bold"
        android:text="Save"
        android:textColor="@color/neumorphic_text_dark"
        android:textSize="18sp"
        app:layout_constraintBottom_toBottomOf="@id/logo_icon"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/logo_icon" />

    <!-- HERO -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/hero_circles"
        android:layout_width="320dp"
        android:layout_height="320dp"
        app:layout_constraintBottom_toTopOf="@id/text_section_circles"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/logo_icon"
        app:layout_constraintVertical_bias="0.5">

        <!-- Outer recessed ring (pulse target) -->
        <View
            android:id="@+id/outer_ring"
            android:layout_width="256dp"
            android:layout_height="256dp"
            android:background="@drawable/bg_neumorphic_recessed"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Inner raised ring with blue border -->
        <View
            android:id="@+id/inner_ring"
            android:layout_width="192dp"
            android:layout_height="192dp"
            android:background="@drawable/bg_neumorphic_circle"
            app:layout_constraintBottom_toBottomOf="@id/outer_ring"
            app:layout_constraintEnd_toEndOf="@id/outer_ring"
            app:layout_constraintStart_toStartOf="@id/outer_ring"
            app:layout_constraintTop_toTopOf="@id/outer_ring" />

        <!-- Center group icon -->
        <ImageView
            android:id="@+id/center_icon"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:src="@drawable/ic_people"
            app:layout_constraintBottom_toBottomOf="@id/inner_ring"
            app:layout_constraintEnd_toEndOf="@id/inner_ring"
            app:layout_constraintStart_toStartOf="@id/inner_ring"
            app:layout_constraintTop_toTopOf="@id/inner_ring"
            app:tint="@color/onboard_primary" />

        <!-- Node: top, right-quarter (orange) -->
        <FrameLayout
            android:id="@+id/bubble_top_right"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/bg_neumorphic_pill"
            android:padding="12dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.78"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/ic_person_circle"
                app:tint="@color/onboard_secondary" />
        </FrameLayout>

        <!-- Node: left, bottom-quarter (blue) -->
        <FrameLayout
            android:id="@+id/bubble_left_center"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/bg_neumorphic_pill"
            android:padding="12dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_bias="0.72">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/ic_person_circle"
                app:tint="@color/onboard_primary" />
        </FrameLayout>

        <!-- Node: bottom, right-quarter (orange) -->
        <FrameLayout
            android:id="@+id/bubble_bottom_right"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/bg_neumorphic_pill"
            android:padding="12dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.72"
            app:layout_constraintStart_toStartOf="parent">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/ic_person_circle"
                app:tint="@color/onboard_secondary" />
        </FrameLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- TEXT -->
    <LinearLayout
        android:id="@+id/text_section_circles"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="32dp"
        android:layout_marginBottom="56dp"
        android:gravity="center"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent">

        <TextView
            android:id="@+id/title_circles"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/manrope_bold"
            android:text="The Power of Circles"
            android:textColor="@color/neumorphic_text_dark"
            android:textSize="32sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/subtitle_circles"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:fontFamily="@font/manrope_medium"
            android:gravity="center"
            android:lineSpacingMultiplier="1.5"
            android:text="Experience the strength of saving together. Join a circle of friends to reach your financial goals faster."
            android:textColor="#475569"
            android:textSize="16sp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
