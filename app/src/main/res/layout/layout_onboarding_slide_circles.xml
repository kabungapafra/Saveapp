<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/neumorphic_bg">

    <ImageView
        android:id="@+id/logo_icon"
        android:layout_width="wrap_content"
        android:layout_height="48dp"
        android:layout_marginStart="24dp"
        android:layout_marginTop="48dp"
        android:adjustViewBounds="true"
        android:src="@drawable/save_logo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- HERO SECTION (Concentric Rings & Avatars) -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/hero_circles"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@id/text_section_circles"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/logo_icon"
        app:layout_constraintVertical_bias="0.4">

        <!-- Outer Ring (Pulse Target) -->
        <View
            android:id="@+id/outer_ring"
            android:layout_width="300dp"
            android:layout_height="300dp"
            android:background="@drawable/bg_neumorphic_circle"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Blue Gradient Ring Border (behind inner_ring) -->
        <View
            android:id="@+id/inner_ring_border"
            android:layout_width="218dp"
            android:layout_height="218dp"
            android:background="@drawable/bg_blue_gradient_ring"
            app:layout_constraintBottom_toBottomOf="@id/outer_ring"
            app:layout_constraintEnd_toEndOf="@id/outer_ring"
            app:layout_constraintStart_toStartOf="@id/outer_ring"
            app:layout_constraintTop_toTopOf="@id/outer_ring" />

        <!-- Inner Recessed Ring -->
        <View
            android:id="@+id/inner_ring"
            android:layout_width="210dp"
            android:layout_height="210dp"
            android:background="@drawable/bg_neumorphic_recessed"
            app:layout_constraintBottom_toBottomOf="@id/outer_ring"
            app:layout_constraintEnd_toEndOf="@id/outer_ring"
            app:layout_constraintStart_toStartOf="@id/outer_ring"
            app:layout_constraintTop_toTopOf="@id/outer_ring" />

        <!-- Center Icon (Group of People) -->
        <ImageView
            android:id="@+id/center_icon"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:padding="20dp"
            android:src="@drawable/ic_people"
            app:layout_constraintBottom_toBottomOf="@id/inner_ring"
            app:layout_constraintEnd_toEndOf="@id/inner_ring"
            app:layout_constraintStart_toStartOf="@id/inner_ring"
            app:layout_constraintTop_toTopOf="@id/inner_ring"
            app:tint="@color/neumorphic_blue" />

        <!-- Floating Bubbles -->
        <!-- Top-Right Bubble -->
        <FrameLayout
            android:id="@+id/bubble_top_right"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="@drawable/bg_neumorphic_pill"
            android:padding="14dp"
            app:layout_constraintCircle="@id/outer_ring"
            app:layout_constraintCircleAngle="35"
            app:layout_constraintCircleRadius="165dp"
            tools:ignore="MissingConstraints">
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/ic_person_circle"
                app:tint="@color/neumorphic_orange" />
        </FrameLayout>

        <!-- Left-Center Bubble -->
        <FrameLayout
            android:id="@+id/bubble_left_center"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="@drawable/bg_neumorphic_pill"
            android:padding="14dp"
            app:layout_constraintCircle="@id/outer_ring"
            app:layout_constraintCircleAngle="270"
            app:layout_constraintCircleRadius="165dp"
            tools:ignore="MissingConstraints">
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/ic_person_circle"
                app:tint="@color/neumorphic_blue" />
        </FrameLayout>

        <!-- Bottom-Right Bubble -->
        <FrameLayout
            android:id="@+id/bubble_bottom_right"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="@drawable/bg_neumorphic_pill"
            android:padding="14dp"
            app:layout_constraintCircle="@id/outer_ring"
            app:layout_constraintCircleAngle="145"
            app:layout_constraintCircleRadius="165dp"
            tools:ignore="MissingConstraints">
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/ic_person_circle"
                app:tint="@color/neumorphic_orange" />
        </FrameLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- TEXT SECTION -->
    <LinearLayout
        android:id="@+id/text_section_circles"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="32dp"
        android:layout_marginBottom="48dp"
        android:gravity="center"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent">

        <TextView
            android:id="@+id/title_circles"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/manrope_bold"
            android:text="The Power of Circles"
            android:textColor="@color/neumorphic_text_dark"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/subtitle_circles"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:fontFamily="@font/manrope_medium"
            android:gravity="center"
            android:lineSpacingMultiplier="1.6"
            android:text="Experience the strength of saving together. Join a circle of friends to reach your financial goals faster."
            android:textColor="@color/neumorphic_text_muted"
            android:textSize="15sp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
