<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F2F7"
    android:id="@+id/mainContainer">

    <!-- Scrollable Content -->
    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingBottom="90dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:clipChildren="false"
            android:paddingTop="120dp">

            <!-- Hero Illustration Area -->
            <RelativeLayout
                android:id="@+id/heroArea"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:paddingTop="32dp"
                android:paddingBottom="24dp">

                <RelativeLayout
                    android:id="@+id/mainCard"
                    android:layout_width="300dp"
                    android:layout_height="wrap_content"
                    android:layout_centerHorizontal="true"
                    android:background="@drawable/bg_white_rounded_24"
                    android:elevation="8dp"
                    android:paddingTop="32dp"
                    android:paddingBottom="24dp">

                    <FrameLayout
                        android:id="@+id/circlesContainer"
                        android:layout_width="220dp"
                        android:layout_height="220dp"
                        android:layout_centerHorizontal="true">

                        <View
                            android:id="@+id/outerRing"
                            android:layout_width="220dp"
                            android:layout_height="220dp"
                            android:layout_gravity="center"
                            android:background="@drawable/bg_ring_pale" />

                        <View
                            android:id="@+id/midRing"
                            android:layout_width="170dp"
                            android:layout_height="170dp"
                            android:layout_gravity="center"
                            android:background="@drawable/bg_ring_mid" />

                        <RelativeLayout
                            android:layout_width="110dp"
                            android:layout_height="110dp"
                            android:layout_gravity="center"
                            android:background="@drawable/bg_connecting_inner_card"
                            android:elevation="6dp">

                            <ImageView
                                android:layout_width="52dp"
                                android:layout_height="48dp"
                                android:layout_centerInParent="true"
                                android:src="@drawable/ic_connecting_chat" />
                        </RelativeLayout>
                    </FrameLayout>

                    <!-- Dot Indicators -->
                    <LinearLayout
                        android:id="@+id/dotsContainer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/circlesContainer"
                        android:layout_centerHorizontal="true"
                        android:layout_marginTop="20dp"
                        android:orientation="horizontal">

                        <View
                            android:id="@+id/dot1"
                            android:layout_width="9dp"
                            android:layout_height="9dp"
                            android:layout_marginEnd="8dp"
                            android:background="@drawable/bg_dot_dark" />

                        <View
                            android:id="@+id/dot2"
                            android:layout_width="9dp"
                            android:layout_height="9dp"
                            android:layout_marginEnd="8dp"
                            android:background="@drawable/bg_dot_mid" />

                        <View
                            android:id="@+id/dot3"
                            android:layout_width="9dp"
                            android:layout_height="9dp"
                            android:background="@drawable/bg_dot_pale" />
                    </LinearLayout>
                </RelativeLayout>

                <!-- Floating Badges Outside the Main Card -->
                <RelativeLayout
                    android:id="@+id/badgePeach"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:layout_alignTop="@id/mainCard"
                    android:layout_alignEnd="@id/mainCard"
                    android:layout_marginTop="-16dp"
                    android:layout_marginEnd="-16dp"
                    android:background="@drawable/bg_badge_peach"
                    android:elevation="10dp">
                    <ImageView
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:layout_centerInParent="true"
                        android:src="@drawable/ic_stopwatch" />
                </RelativeLayout>

                <RelativeLayout
                    android:id="@+id/badgeLavender"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:layout_alignBottom="@id/mainCard"
                    android:layout_alignStart="@id/mainCard"
                    android:layout_marginStart="-16dp"
                    android:layout_marginBottom="52dp"
                    android:background="@drawable/bg_badge_lavender"
                    android:elevation="10dp">
                    <ImageView
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:layout_centerInParent="true"
                        android:src="@drawable/ic_headset_purple" />
                </RelativeLayout>

            </RelativeLayout>

            <!-- Text Content Block -->
            <LinearLayout
                android:id="@+id/textBlock"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="24dp"
                android:paddingBottom="16dp">

                <TextView
                    android:id="@+id/tvHeading"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"
                    android:fontFamily="sans-serif"
                    android:gravity="center"
                    android:text="Connecting you to an agent..."
                    android:textColor="#0F172A"
                    android:textSize="26sp"
                    android:textStyle="bold" />

                <!-- Rich text using Android spans applied in code or static HTML in XML -->
                <!-- We will use a standard TextView and apply Html.fromHtml in code to keep exact styling -->
                <TextView
                    android:id="@+id/tvBodyText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif"
                    android:gravity="center"
                    android:lineSpacingMultiplier="1.3"
                    android:paddingHorizontal="8dp"
                    android:textColor="#6B7280"
                    android:textSize="16sp" />
            </LinearLayout>

            <!-- Secure Connection Card -->
            <LinearLayout
                android:id="@+id/secureCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="32dp"
                android:background="@drawable/bg_white_rounded_16"
                android:elevation="4dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="16dp">

                <RelativeLayout
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_shield_icon_bg">
                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:layout_centerInParent="true"
                        android:src="@drawable/ic_shield_blue" />
                </RelativeLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif"
                        android:letterSpacing="0.12"
                        android:text="SECURE CONNECTION"
                        android:textColor="#0F172A"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:fontFamily="sans-serif"
                        android:maxLines="1"
                        android:text="Your conversation is encrypted and"
                        android:textColor="#6B7280"
                        android:textSize="12sp" />
                </LinearLayout>

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- Fade mask to simulate cut off content -->
    <View
        android:id="@+id/fadeMask"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        app:layout_constraintBottom_toTopOf="@id/cancelWrapper"
        android:background="#00FFFFFF" /><!-- Gradient mask optionally applied in code or XML -->

    <!-- Cancel Request Button Wrapper (Fixed Bottom) -->
    <LinearLayout
        android:id="@+id/cancelWrapper"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#F0F2F7"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingTop="12dp"
        android:paddingEnd="16dp"
        android:paddingBottom="32dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:id="@+id/btnCancel"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:background="@drawable/bg_cancel_button"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_close"
                app:tint="#0F172A" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:fontFamily="sans-serif"
                android:text="Cancel Request"
                android:textColor="#0F172A"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
