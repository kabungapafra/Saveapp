<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="?attr/selectableItemBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:paddingVertical="12dp">

        <!-- Icon box: white rounded square, green when incoming -->
        <FrameLayout
            android:id="@+id/fvRowIconBg"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_tx_icon_box">
            <ImageView
                android:id="@+id/ivRowIcon"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_arrow_right"
                android:rotation="-45"
                app:tint="@color/dashboard_text_primary"
                tools:ignore="ContentDescription" />
        </FrameLayout>

        <!-- Title + subtitle -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="8dp">

            <TextView
                android:id="@+id/tvRowTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/dashboard_text_primary"
                android:textSize="13sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"
                tools:text="Contribution · Kampa..." />

            <TextView
                android:id="@+id/tvRowSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textColor="#9AA5B4"
                android:textSize="11sp"
                tools:text="Today, 09:12" />
        </LinearLayout>

        <!-- Amount -->
        <TextView
            android:id="@+id/tvRowAmount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@color/dashboard_text_primary"
            tools:text="– UGX 100,000" />

    </LinearLayout>

    <!-- Divider -->
    <View
        android:id="@+id/viewRowDivider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#F2F4F7" />

</LinearLayout>
