<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:clipChildren="false">

    <!-- CONFETTI -->
    <FrameLayout
        android:id="@+id/confettiContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipChildren="false">

        <View android:layout_width="18dp" android:layout_height="7dp" android:background="#F59E0B" android:rotation="35" android:layout_gravity="top|start" android:layout_marginStart="28dp" android:layout_marginTop="52dp"/>
        <View android:layout_width="10dp" android:layout_height="10dp" android:background="@drawable/shape_circle_blue" android:backgroundTint="#3B82F6" android:layout_gravity="top|start" android:layout_marginStart="95dp" android:layout_marginTop="22dp"/>
        <View android:layout_width="14dp" android:layout_height="6dp" android:background="#06B6D4" android:rotation="-18" android:layout_gravity="top|start" android:layout_marginStart="14dp" android:layout_marginTop="95dp"/>
        <View android:layout_width="12dp" android:layout_height="12dp" android:background="@drawable/shape_circle_blue" android:backgroundTint="#EC4899" android:layout_gravity="top|start" android:layout_marginStart="52dp" android:layout_marginTop="138dp"/>
        <View android:layout_width="16dp" android:layout_height="6dp" android:background="#F59E0B" android:rotation="22" android:layout_gravity="top|start" android:layout_marginStart="140dp" android:layout_marginTop="48dp"/>
        <View android:layout_width="8dp" android:layout_height="8dp" android:background="@drawable/shape_circle_blue" android:backgroundTint="#EF4444" android:layout_gravity="top|start" android:layout_marginStart="175dp" android:layout_marginTop="18dp"/>
        <View android:layout_width="10dp" android:layout_height="10dp" android:background="@drawable/shape_circle_blue" android:backgroundTint="#06B6D4" android:layout_gravity="top|start" android:layout_marginStart="22dp" android:layout_marginTop="190dp"/>
        <View android:layout_width="14dp" android:layout_height="5dp" android:background="#F97316" android:rotation="-40" android:layout_gravity="top|start" android:layout_marginStart="78dp" android:layout_marginTop="170dp"/>

        <View android:layout_width="18dp" android:layout_height="7dp" android:background="#3B82F6" android:rotation="-28" android:layout_gravity="top|end" android:layout_marginEnd="35dp" android:layout_marginTop="28dp"/>
        <View android:layout_width="14dp" android:layout_height="14dp" android:background="@drawable/shape_circle_blue" android:backgroundTint="#F59E0B" android:layout_gravity="top|end" android:layout_marginEnd="110dp" android:layout_marginTop="14dp"/>
        <View android:layout_width="10dp" android:layout_height="10dp" android:background="@drawable/shape_circle_blue" android:backgroundTint="#06B6D4" android:layout_gravity="top|end" android:layout_marginEnd="18dp" android:layout_marginTop="78dp"/>
        <View android:layout_width="16dp" android:layout_height="6dp" android:background="#EC4899" android:rotation="15" android:layout_gravity="top|end" android:layout_marginEnd="68dp" android:layout_marginTop="105dp"/>
        <View android:layout_width="12dp" android:layout_height="12dp" android:background="@drawable/shape_circle_blue" android:backgroundTint="#22C55E" android:layout_gravity="top|end" android:layout_marginEnd="145dp" android:layout_marginTop="72dp"/>
        <View android:layout_width="8dp" android:layout_height="8dp" android:background="@drawable/shape_circle_blue" android:backgroundTint="#F97316" android:layout_gravity="top|end" android:layout_marginEnd="28dp" android:layout_marginTop="145dp"/>
        <View android:layout_width="14dp" android:layout_height="5dp" android:background="#F59E0B" android:rotation="-12" android:layout_gravity="top|end" android:layout_marginEnd="95dp" android:layout_marginTop="160dp"/>
        <View android:layout_width="10dp" android:layout_height="10dp" android:background="@drawable/shape_circle_blue" android:backgroundTint="#3B82F6" android:layout_gravity="top|end" android:layout_marginEnd="52dp" android:layout_marginTop="195dp"/>

        <ImageView android:layout_width="16dp" android:layout_height="16dp" android:src="@drawable/ic_star" app:tint="#F59E0B" android:layout_gravity="top|start" android:layout_marginStart="42dp" android:layout_marginTop="30dp"/>
        <ImageView android:layout_width="14dp" android:layout_height="14dp" android:src="@drawable/ic_star" app:tint="#22C55E" android:layout_gravity="top|start" android:layout_marginStart="130dp" android:layout_marginTop="155dp"/>
        <ImageView android:layout_width="16dp" android:layout_height="16dp" android:src="@drawable/ic_star" app:tint="#3B82F6" android:layout_gravity="top|end" android:layout_marginEnd="55dp" android:layout_marginTop="55dp"/>
        <ImageView android:layout_width="14dp" android:layout_height="14dp" android:src="@drawable/ic_star" app:tint="#EC4899" android:layout_gravity="top|end" android:layout_marginEnd="130dp" android:layout_marginTop="135dp"/>

        <View android:layout_width="16dp" android:layout_height="6dp" android:background="#3B82F6" android:rotation="50" android:layout_gravity="top|start" android:layout_marginStart="18dp" android:layout_marginTop="260dp"/>
        <View android:layout_width="10dp" android:layout_height="10dp" android:background="@drawable/shape_circle_blue" android:backgroundTint="#F59E0B" android:layout_gravity="top|end" android:layout_marginEnd="20dp" android:layout_marginTop="255dp"/>

    </FrameLayout>

    <!-- CONTENT -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingHorizontal="28dp">

        <RelativeLayout android:layout_width="match_parent" android:layout_height="64dp">
            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="44dp" android:layout_height="44dp"
                android:layout_centerVertical="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="10dp"
                android:src="@drawable/ic_arrow_back"
                app:tint="@color/v_text_dark" />
            <View android:id="@+id/headerDivider" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
        </RelativeLayout>

        <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />

        <FrameLayout
            android:id="@+id/checkmarkCircle"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:background="@drawable/shape_circle_blue"
            android:backgroundTint="#F59E0B"
            android:elevation="4dp">
            <ImageView
                android:id="@+id/ivCheckmark"
                android:layout_width="50dp" android:layout_height="50dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_loan"
                app:tint="#FFFFFF" />
            <FrameLayout android:id="@+id/confettiContainerInner" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
        </FrameLayout>

        <TextView
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:fontFamily="@font/manrope_bold"
            android:gravity="center"
            android:text="Request&#10;Submitted!"
            android:textColor="@color/v_text_dark"
            android:textSize="26sp" />

        <TextView
            android:id="@+id/tvDescription"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:fontFamily="@font/manrope"
            android:gravity="center"
            android:lineSpacingExtra="4dp"
            android:text="The application is under review. The member will be notified of the decision."
            android:textColor="@color/v_text_mid"
            android:textSize="14sp" />

        <!-- Data stubs used by Java -->
        <TextView android:id="@+id/tvBorrowerName" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
        <TextView android:id="@+id/tvAmount" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
        <TextView android:id="@+id/tvTransactionId" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>

        <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />

    </LinearLayout>

    <!-- BUTTON -->
    <FrameLayout
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="#FFFFFF"
        android:elevation="8dp"
        android:padding="24dp">
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDone"
            android:layout_width="match_parent" android:layout_height="60dp"
            android:fontFamily="@font/manrope_bold"
            android:insetTop="0dp" android:insetBottom="0dp"
            android:text="Done"
            android:textAllCaps="false" android:textSize="16sp"
            app:backgroundTint="@color/brand_blue"
            app:cornerRadius="30dp" />
    </FrameLayout>

</FrameLayout>
