<?xml version="1.0" encoding="utf-8"?>
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/swipeRefresh"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/v_page_bg">

        <!-- TOP HEADER -->
        <RelativeLayout
            android:id="@+id/headerLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/card_surface"
            android:elevation="4dp"
            android:paddingHorizontal="16dp"
            android:paddingVertical="16dp"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/backButton"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:background="@drawable/bg_input_bg_circle"
                android:padding="10dp"
                android:src="@drawable/ic_arrow_back"
                app:tint="@color/v_text_dark" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:fontFamily="@font/poppins"
                android:text="Financial Analysis"
                android:textColor="@color/v_text_dark"
                android:textSize="@dimen/text_size_normal" />
        </RelativeLayout>

        <!-- SCROLLABLE CONTENT -->
        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:clipToPadding="false"
            android:paddingBottom="24dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toBottomOf="@id/headerLayout">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="32dp">

                <!-- ===== HERO CARD: TOTAL GROUP BALANCE ===== -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="16dp"
                    android:layout_marginTop="24dp"
                    android:layout_marginBottom="4dp"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="6dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_card_premium_blue"
                        android:orientation="vertical"
                        android:padding="24dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:alpha="0.8"
                            android:fontFamily="sans-serif-medium"
                            android:letterSpacing="0.08"
                            android:text="TOTAL GROUP BALANCE"
                            android:textColor="@color/permanent_white"
                            android:textSize="@dimen/text_size_xs" />

                        <TextView
                            android:id="@+id/tvTotalLiquidity"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:fontFamily="@font/poppins"
                            android:text="UGX 0"
                            android:textColor="@color/permanent_white"
                            android:textSize="@dimen/text_size_xxxl"
                            tools:text="UGX 45,200,000" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:alpha="0.75"
                            android:fontFamily="@font/montserrat"
                            android:text="Net pooled funds across the group"
                            android:textColor="@color/permanent_white"
                            android:textSize="@dimen/text_size_xs" />

                        <!-- Divider -->
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginVertical="20dp"
                            android:background="@color/divider_color" />

                        <!-- Export Buttons -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:orientation="horizontal">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnExportPdf"
                                android:layout_width="0dp"
                                android:layout_height="48dp"
                                android:layout_marginEnd="8dp"
                                android:layout_weight="1"
                                android:backgroundTint="@color/v_input_bg"
                                android:fontFamily="@font/poppins"
                                android:insetTop="0dp"
                                android:insetBottom="0dp"
                                android:text="Export PDF"
                                android:textAllCaps="false"
                                android:textColor="@color/v_blue"
                                android:textSize="@dimen/text_size_xs"
                                app:cornerRadius="24dp"
                                app:icon="@drawable/ic_pdf_export"
                                app:iconSize="18dp"
                                app:iconTint="@color/v_blue" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnExcelReport"
                                android:layout_width="0dp"
                                android:layout_height="48dp"
                                android:layout_marginStart="8dp"
                                android:layout_weight="1"
                                android:backgroundTint="@color/dashboard_accent_orange"
                                android:fontFamily="@font/poppins"
                                android:insetTop="0dp"
                                android:insetBottom="0dp"
                                android:text="Excel Report"
                                android:textAllCaps="false"
                                android:textColor="#FFFFFF"
                                android:textSize="@dimen/text_size_xs"
                                app:cornerRadius="24dp"
                                app:icon="@drawable/ic_excel_export"
                                app:iconSize="18dp"
                                app:iconTint="#FFFFFF" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- ===== CONTRIBUTIONS (MONTH + YEAR) ===== -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="16dp"
                    android:layout_marginTop="12dp"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="2dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@color/card_surface"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <FrameLayout
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:background="@drawable/bg_input_bg_circle"
                                android:backgroundTint="@color/v_input_bg">
                                <ImageView
                                    android:layout_width="16dp"
                                    android:layout_height="16dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_money_banknote"
                                    app:tint="@color/v_blue" />
                            </FrameLayout>

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginStart="12dp"
                                android:fontFamily="@font/poppins"
                                android:letterSpacing="0.05"
                                android:text="CONTRIBUTIONS THIS MONTH"
                                android:textColor="@color/v_text_muted"
                                android:textSize="@dimen/text_size_xs" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvMonthlyContributions"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:fontFamily="@font/poppins"
                            android:text="UGX 0"
                            android:textColor="@color/v_text_dark"
                            android:textSize="@dimen/text_size_xl"
                            tools:text="UGX 3.2M" />

                        <com.google.android.material.progressindicator.LinearProgressIndicator
                            android:id="@+id/progressMonthly"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="14dp"
                            android:progress="0"
                            app:indicatorColor="@color/v_blue"
                            app:trackColor="@color/v_input_bg"
                            app:trackCornerRadius="4dp"
                            app:trackThickness="8dp" />

                        <TextView
                            android:id="@+id/tvMonthlyTargetLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:fontFamily="@font/montserrat"
                            android:text="of monthly target"
                            android:textColor="@color/v_text_muted"
                            android:textSize="@dimen/text_size_xs" />

                        <!-- Divider -->
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginVertical="14dp"
                            android:background="@color/v_input_bg" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:fontFamily="@font/montserrat"
                                android:text="Year to date"
                                android:textColor="@color/v_text_mid"
                                android:textSize="@dimen/text_size_xs" />

                            <TextView
                                android:id="@+id/tvYearlyContributions"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/poppins"
                                android:text="UGX 0"
                                android:textColor="@color/v_text_dark"
                                android:textSize="@dimen/text_size_small"
                                tools:text="UGX 38.4M" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- ===== OUTSTANDING LOANS + INTEREST EARNED (2-COLUMN) ===== -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="16dp"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal">

                    <!-- Outstanding Loans -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="2dp"
                        app:strokeWidth="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@color/card_surface"
                            android:orientation="vertical"
                            android:padding="18dp">

                            <FrameLayout
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:background="@drawable/bg_input_bg_circle"
                                android:backgroundTint="@color/v_input_bg">
                                <ImageView
                                    android:layout_width="16dp"
                                    android:layout_height="16dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_loan"
                                    app:tint="@color/dashboard_accent_orange" />
                            </FrameLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="12dp"
                                android:fontFamily="@font/poppins"
                                android:letterSpacing="0.05"
                                android:text="OUTSTANDING LOANS"
                                android:textColor="@color/v_text_muted"
                                android:textSize="@dimen/text_size_xs" />

                            <TextView
                                android:id="@+id/tvOutstandingLoans"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:fontFamily="@font/poppins"
                                android:text="UGX 0"
                                android:textColor="@color/v_text_dark"
                                android:textSize="@dimen/text_size_large"
                                tools:text="UGX 8.1M" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:fontFamily="@font/montserrat"
                                android:text="Principal + interest due"
                                android:textColor="@color/v_text_muted"
                                android:textSize="@dimen/text_size_xs" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Interest Earned -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="2dp"
                        app:strokeWidth="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@color/card_surface"
                            android:orientation="vertical"
                            android:padding="18dp">

                            <FrameLayout
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:background="@drawable/bg_input_bg_circle"
                                android:backgroundTint="@color/v_input_bg">
                                <ImageView
                                    android:layout_width="16dp"
                                    android:layout_height="16dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_trending_up"
                                    app:tint="@color/h_green_600" />
                            </FrameLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="12dp"
                                android:fontFamily="@font/poppins"
                                android:letterSpacing="0.05"
                                android:text="INTEREST EARNED"
                                android:textColor="@color/v_text_muted"
                                android:textSize="@dimen/text_size_xs" />

                            <TextView
                                android:id="@+id/tvInterestEarned"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:fontFamily="@font/poppins"
                                android:text="UGX 0"
                                android:textColor="@color/v_text_dark"
                                android:textSize="@dimen/text_size_large"
                                tools:text="UGX 6.8M" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:fontFamily="@font/montserrat"
                                android:text="From group loans"
                                android:textColor="@color/v_text_muted"
                                android:textSize="@dimen/text_size_xs" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>

                <!-- ===== CURRENT LIQUIDITY ===== -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardLiquiditySummary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="16dp"
                    android:layout_marginTop="12dp"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="2dp"
                    app:strokeWidth="0dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@color/card_surface"
                        android:padding="20dp">

                        <!-- Orange accent pill -->
                        <View
                            android:id="@+id/orangeBoard"
                            android:layout_width="4dp"
                            android:layout_height="80dp"
                            android:layout_alignParentStart="true"
                            android:layout_centerVertical="true"
                            android:background="@drawable/bg_pill_orange"
                            android:backgroundTint="@color/dashboard_accent_orange" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:layout_toEndOf="@id/orangeBoard"
                            android:orientation="vertical">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <FrameLayout
                                    android:layout_width="32dp"
                                    android:layout_height="32dp"
                                    android:background="@drawable/bg_input_bg_circle"
                                    android:backgroundTint="@color/v_input_bg">
                                    <ImageView
                                        android:layout_width="16dp"
                                        android:layout_height="16dp"
                                        android:layout_gravity="center"
                                        android:src="@drawable/ic_wallet_safe_blue"
                                        app:tint="@color/dashboard_accent_orange" />
                                </FrameLayout>

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:layout_marginStart="12dp"
                                    android:fontFamily="@font/poppins"
                                    android:letterSpacing="0.05"
                                    android:text="AVAILABLE LIQUIDITY"
                                    android:textColor="@color/v_text_muted"
                                    android:textSize="@dimen/text_size_xs" />
                            </LinearLayout>

                            <TextView
                                android:id="@+id/tvCurrentLiquidity"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="12dp"
                                android:fontFamily="@font/poppins"
                                android:text="UGX 0"
                                android:textColor="@color/v_text_dark"
                                android:textSize="@dimen/text_size_xl"
                                tools:text="UGX 12.2M" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:fontFamily="@font/montserrat"
                                android:text="Balance available for disbursement"
                                android:textColor="@color/v_text_muted"
                                android:textSize="@dimen/text_size_xs" />
                        </LinearLayout>
                    </RelativeLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- ===== MEMBER PERFORMANCE SUMMARY ===== -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardMemberPerformance"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="16dp"
                    android:layout_marginTop="14dp"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="2dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@color/card_surface"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <!-- Header Row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:fontFamily="@font/poppins"
                                android:text="Top Contributors"
                                android:textColor="@color/v_text_dark"
                                android:textSize="@dimen/text_size_small" />

                            <TextView
                                android:id="@+id/btnViewAllMembers"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:background="?attr/selectableItemBackground"
                                android:fontFamily="@font/poppins"
                                android:padding="4dp"
                                android:text="View All"
                                android:textColor="@color/v_blue"
                                android:textSize="@dimen/text_size_xs" />
                        </LinearLayout>

                        <!-- Column Headers -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="14dp"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="2"
                                android:fontFamily="@font/montserrat"
                                android:letterSpacing="0.08"
                                android:text="MEMBER"
                                android:textColor="@color/v_text_muted"
                                android:textSize="@dimen/text_size_xs" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="2"
                                android:fontFamily="@font/montserrat"
                                android:gravity="center"
                                android:letterSpacing="0.06"
                                android:text="TARGET MET"
                                android:textColor="@color/v_text_muted"
                                android:textSize="@dimen/text_size_xs" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:fontFamily="@font/montserrat"
                                android:gravity="end"
                                android:text="AMT (M)"
                                android:textColor="@color/v_text_muted"
                                android:textSize="@dimen/text_size_xs" />
                        </LinearLayout>

                        <!-- Divider -->
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginVertical="10dp"
                            android:background="@color/v_input_bg" />

                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/rvMemberPerformance"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:nestedScrollingEnabled="false" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- ===== PAYOUT PERFORMANCE LINK ===== -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardPayoutPerformance"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="16dp"
                    android:layout_marginTop="14dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/divider_color"
                    app:strokeWidth="1.5dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@color/card_surface"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="20dp">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            app:cardBackgroundColor="@color/v_page_bg"
                            app:cardCornerRadius="18dp"
                            app:cardElevation="0dp"
                            app:strokeColor="@color/v_text_muted"
                            app:strokeWidth="1dp">
                            <ImageView
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_history"
                                app:tint="@color/v_blue" />
                        </com.google.android.material.card.MaterialCardView>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="18dp"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/poppins"
                                android:letterSpacing="-0.01"
                                android:text="Payout History"
                                android:textColor="@color/v_text_dark"
                                android:textSize="@dimen/text_size_normal" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="3dp"
                                android:fontFamily="@font/montserrat"
                                android:lineSpacingMultiplier="1.2"
                                android:text="Audit and track member disbursements"
                                android:textColor="@color/v_text_mid"
                                android:textSize="@dimen/text_size_xs" />
                        </LinearLayout>

                        <FrameLayout
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:layout_marginStart="12dp"
                            android:background="@drawable/bg_circle_white"
                            android:backgroundTint="@color/h_blue_50">
                            <ImageView
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_arrow_right"
                                app:tint="@color/v_blue" />
                        </FrameLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- ===== TRANSACTIONAL LEDGER ===== -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="16dp"
                    android:layout_marginTop="14dp"
                    android:layout_marginBottom="24dp"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="2dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@color/card_surface"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <!-- Header Row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="@font/poppins"
                                    android:text="Recent Transactions"
                                    android:textColor="@color/v_text_dark"
                                    android:textSize="@dimen/text_size_small" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="@font/montserrat"
                                    android:text="Latest group money movements"
                                    android:textColor="@color/v_text_muted"
                                    android:textSize="@dimen/text_size_xs" />
                            </LinearLayout>

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnFullLog"
                                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                android:layout_width="wrap_content"
                                android:layout_height="34dp"
                                android:fontFamily="@font/poppins"
                                android:insetTop="0dp"
                                android:insetBottom="0dp"
                                android:text="Full log"
                                android:textAllCaps="false"
                                android:textColor="@color/v_text_mid"
                                android:textSize="@dimen/text_size_xs"
                                app:cornerRadius="8dp"
                                app:icon="@drawable/ic_history"
                                app:iconSize="14dp"
                                app:iconTint="@color/v_text_mid"
                                app:strokeColor="#E2E8F0" />
                        </LinearLayout>

                        <!-- Column Headers -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="2"
                                android:fontFamily="@font/montserrat"
                                android:letterSpacing="0.06"
                                android:text="MEMBER / REF"
                                android:textColor="@color/v_text_muted"
                                android:textSize="@dimen/text_size_xs" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:fontFamily="@font/montserrat"
                                android:gravity="center"
                                android:letterSpacing="0.04"
                                android:text="TYPE"
                                android:textColor="@color/v_text_muted"
                                android:textSize="@dimen/text_size_xs" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:fontFamily="@font/montserrat"
                                android:gravity="end"
                                android:text="AMOUNT"
                                android:textColor="@color/v_text_muted"
                                android:textSize="@dimen/text_size_xs" />
                        </LinearLayout>

                        <!-- Divider -->
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginVertical="10dp"
                            android:background="@color/v_input_bg" />

                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/rvTransactionalLedger"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:nestedScrollingEnabled="false" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
