<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingVertical="16dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tvApplicantName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.6"
            android:fontFamily="@font/manrope_bold"
            android:text="Member Name"
            android:textColor="@color/v_text_dark"
            android:textSize="12sp"
            android:lineSpacingExtra="2dp" />

        <TextView
            android:id="@+id/tvAmount"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="@font/manrope_bold"
            android:text="$0.00"
            android:textColor="#215DA1"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tvMethod"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="@font/manrope"
            android:text="Vault\nSettlement"
            android:textColor="@color/v_text_mid"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/btnApprove"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="0.8"
            android:background="@drawable/bg_outlined_button_blue"
            android:clickable="true"
            android:focusable="true"
            android:fontFamily="@font/manrope_bold"
            android:gravity="center"
            android:letterSpacing="0.05"
            android:text="VERIFY"
            android:textColor="#215DA1"
            android:textSize="8sp" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/v_page_bg" />
</LinearLayout>
