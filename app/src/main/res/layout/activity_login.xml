<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_login_root">

    <!-- Premium Glass Container -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_margin="16dp"
        android:background="@drawable/bg_login_container"
        android:elevation="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Scrollable content -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:paddingStart="24dp"
                android:paddingTop="64dp"
                android:paddingEnd="24dp"
                android:paddingBottom="40dp">

                <!-- Circular Logo Container -->
                <FrameLayout
                    android:id="@+id/logoContainer"
                    android:layout_width="150dp"
                    android:layout_height="150dp"
                    android:layout_marginBottom="32dp"
                    android:background="@drawable/bg_logo_circle">

                    <ImageView
                        android:id="@+id/logoImage"
                        android:layout_width="100dp"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:adjustViewBounds="true"
                        android:contentDescription="@string/app_logo"
                        android:scaleType="fitCenter"
                        app:srcCompat="@drawable/save_logo" />
                </FrameLayout>

                <!-- Brand Typography -->
                <TextView
                    android:id="@+id/titleText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/manrope"
                    android:text="Welcome to Save"
                    android:textColor="@color/v_text_dark"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:id="@+id/taglineText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="48dp"
                    android:fontFamily="@font/manrope"
                    android:gravity="center"
                    android:lineSpacingMultiplier="1.2"
                    android:text="Join a community of savers and social\ncircles with Save's premium financial\ntools."
                    android:textColor="@color/v_text_mid"
                    android:textSize="15sp" />

                <!-- Features Quick Look -->
                <LinearLayout
                    android:id="@+id/featureCardsLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="48dp"
                    android:orientation="horizontal"
                    android:weightSum="2">

                    <!-- Social Circles Card -->
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="0dp"
                        android:layout_height="160dp"
                        android:layout_marginEnd="8dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_feature_card_white"
                        android:clipToOutline="true"
                        android:padding="20dp">

                        <!-- Decorative Overlay Circle -->
                        <View
                            android:layout_width="100dp"
                            android:layout_height="100dp"
                            android:layout_marginBottom="-40dp"
                            android:layout_marginEnd="-40dp"
                            android:alpha="0.3"
                            android:background="@drawable/bg_circle_white"
                            android:backgroundTint="#E2E8F0"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent" />

                        <FrameLayout
                            android:id="@+id/iconContainerSocial"
                            android:layout_width="52dp"
                            android:layout_height="52dp"
                            android:background="@drawable/bg_icon_circle_orange"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent">

                            <ImageView
                                android:layout_width="26dp"
                                android:layout_height="26dp"
                                android:layout_gravity="center"
                                app:srcCompat="@drawable/ic_people"
                                app:tint="#D84315" />
                        </FrameLayout>

                        <TextView
                            android:id="@+id/socialTitleText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="20dp"
                            android:fontFamily="@font/manrope"
                            android:text="Social\nCircles"
                            android:textColor="@color/v_text_dark"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/iconContainerSocial" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:fontFamily="@font/manrope"
                            android:text="Connect &amp; Earn"
                            android:textColor="@color/v_text_muted"
                            android:textSize="12dp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/socialTitleText" />
                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <!-- Easy Saving Card -->
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="0dp"
                        android:layout_height="160dp"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_feature_card_white"
                        android:clipToOutline="true"
                        android:padding="20dp">

                        <!-- Decorative Overlay Arrow -->
                        <ImageView
                            android:layout_width="60dp"
                            android:layout_height="60dp"
                            android:layout_marginBottom="0dp"
                            android:layout_marginEnd="0dp"
                            android:alpha="0.1"
                            android:rotation="-45"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:srcCompat="@drawable/ic_arrow_right"
                            app:tint="@color/v_text_mid" />

                        <FrameLayout
                            android:id="@+id/iconContainerSaving"
                            android:layout_width="52dp"
                            android:layout_height="52dp"
                            android:background="@drawable/bg_icon_circle_blue"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent">

                            <ImageView
                                android:layout_width="26dp"
                                android:layout_height="26dp"
                                android:layout_gravity="center"
                                app:srcCompat="@drawable/ic_account_balance_wallet"
                                app:tint="#1565C0" />
                        </FrameLayout>

                        <TextView
                            android:id="@+id/savingTitleText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="20dp"
                            android:fontFamily="@font/manrope"
                            android:text="Easy Saving"
                            android:textColor="@color/v_text_dark"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/iconContainerSaving" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:fontFamily="@font/manrope"
                            android:text="Smart Goals"
                            android:textColor="@color/v_text_muted"
                            android:textSize="12dp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/savingTitleText" />
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </LinearLayout>

                <!-- Action Buttons -->
                <LinearLayout
                    android:id="@+id/memberButton"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:layout_marginBottom="16dp"
                    android:background="@drawable/bg_btn_member_blue"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:onClick="onMemberClick"
                    android:orientation="horizontal"
                    android:paddingStart="24dp"
                    android:paddingEnd="24dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:fontFamily="@font/manrope"
                        android:gravity="center"
                        android:text="Continue as Member"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        app:srcCompat="@drawable/ic_arrow_right"
                        app:tint="#FFFFFF" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/adminButton"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:layout_marginBottom="48dp"
                    android:background="@drawable/bg_btn_admin_light"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:onClick="onAdminClick"
                    android:orientation="horizontal"
                    android:paddingStart="24dp"
                    android:paddingEnd="24dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:fontFamily="@font/manrope"
                        android:gravity="center"
                        android:text="Continue as Admin"
                        android:textColor="@color/v_text_mid"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        app:srcCompat="@drawable/ic_lock"
                        app:tint="@color/v_text_muted" />
                </LinearLayout>

                <!-- Pagination Dots -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <View
                        android:layout_width="24dp"
                        android:layout_height="6dp"
                        android:layout_marginEnd="6dp"
                        android:background="@drawable/bg_login_progress_active" />

                    <View
                        android:layout_width="6dp"
                        android:layout_height="6dp"
                        android:layout_marginEnd="6dp"
                        android:background="@drawable/bg_login_progress_inactive" />

                    <View
                        android:layout_width="6dp"
                        android:layout_height="6dp"
                        android:background="@drawable/bg_login_progress_inactive" />
                </LinearLayout>

            </LinearLayout>
        </ScrollView>
    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>