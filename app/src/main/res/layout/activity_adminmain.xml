<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dashboard_bg">

    <!-- Fragment Container (Overlays Main for Nav) -->
    <FrameLayout
        android:id="@+id/fragment_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Background Dim Layer (Fades in over everything except FAB/Nav) -->
    <View
        android:id="@+id/quickActionsDim"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#B364748B"
        android:visibility="gone" />

    <!-- Quick Actions Overlay -->
    <include
        android:id="@+id/quickActionsLayout"
        layout="@layout/dialog_quick_actions"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

    <!-- Redesigned Bottom Navigation Bar with Centered FAB -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/bottomNavWrapper"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:layout_gravity="bottom"
        android:layout_marginBottom="16dp"
        android:clipChildren="false"
        android:clipToPadding="false">

        <View
            android:id="@+id/navIconAnchor"
            android:layout_width="1dp"
            android:layout_height="1dp"
            android:visibility="invisible"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_bias="0.44" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/navContainer"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginHorizontal="20dp"
            app:cardCornerRadius="32dp"
            app:cardElevation="12dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:strokeWidth="0dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@color/white">

                <!-- Home -->
                <FrameLayout
                    android:id="@+id/bgHome"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toStartOf="@+id/bgLoans"
                    app:layout_constraintHorizontal_chainStyle="spread"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintVertical_bias="0.3">
                    <ImageView
                        android:id="@+id/imgHome"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_home"
                        app:tint="#94A3B8" />
                </FrameLayout>
                <TextView
                    android:id="@+id/txtHome"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="HOME"
                    android:textColor="#94A3B8"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:visibility="gone"
                    app:layout_constraintEnd_toEndOf="@+id/bgHome"
                    app:layout_constraintStart_toStartOf="@+id/bgHome"
                    app:layout_constraintTop_toBottomOf="@+id/bgHome" />

                <!-- Loans -->
                <FrameLayout
                    android:id="@+id/bgLoans"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    app:layout_constraintBottom_toBottomOf="@id/bgHome"
                    app:layout_constraintEnd_toStartOf="@+id/centerSpacer"
                    app:layout_constraintStart_toEndOf="@+id/bgHome"
                    app:layout_constraintTop_toTopOf="@id/bgHome">
                    <ImageView
                        android:id="@+id/imgLoans"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_account_balance_wallet"
                        app:tint="#94A3B8" />
                </FrameLayout>
                <TextView
                    android:id="@+id/txtLoans"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="LOANS"
                    android:textColor="#94A3B8"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:visibility="gone"
                    app:layout_constraintEnd_toEndOf="@+id/bgLoans"
                    app:layout_constraintStart_toStartOf="@+id/bgLoans"
                    app:layout_constraintTop_toBottomOf="@+id/bgLoans" />

                <View
                    android:id="@+id/centerSpacer"
                    android:layout_width="60dp"
                    android:layout_height="match_parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent" />

                <!-- Members -->
                <FrameLayout
                    android:id="@+id/bgMembers"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    app:layout_constraintBottom_toBottomOf="@id/bgHome"
                    app:layout_constraintEnd_toStartOf="@+id/bgSettings"
                    app:layout_constraintStart_toEndOf="@+id/centerSpacer"
                    app:layout_constraintTop_toTopOf="@id/bgHome">
                    <ImageView
                        android:id="@+id/imgMembers"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_people"
                        app:tint="#94A3B8" />
                </FrameLayout>
                <TextView
                    android:id="@+id/txtMembers"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MEMBERS"
                    android:textColor="#94A3B8"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:visibility="gone"
                    app:layout_constraintEnd_toEndOf="@+id/bgMembers"
                    app:layout_constraintStart_toStartOf="@+id/bgMembers"
                    app:layout_constraintTop_toBottomOf="@+id/bgMembers" />

                <!-- Settings -->
                <FrameLayout
                    android:id="@+id/bgSettings"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    app:layout_constraintBottom_toBottomOf="@id/bgHome"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@+id/bgMembers"
                    app:layout_constraintTop_toTopOf="@id/bgHome">
                    <ImageView
                        android:id="@+id/imgSettings"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_settings"
                        app:tint="#94A3B8" />
                </FrameLayout>
                <TextView
                    android:id="@+id/txtSettings"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ACCOUNT"
                    android:textColor="#94A3B8"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:visibility="gone"
                    app:layout_constraintEnd_toEndOf="@+id/bgSettings"
                    app:layout_constraintStart_toStartOf="@+id/bgSettings"
                    app:layout_constraintTop_toBottomOf="@+id/bgSettings" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/fabAction"
            android:layout_width="56dp"
            android:layout_height="56dp"
            app:cardBackgroundColor="@color/dashboard_accent_blue"
            app:cardCornerRadius="28dp"
            app:cardElevation="14dp"
            app:layout_constraintBottom_toBottomOf="@+id/navIconAnchor"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@+id/navIconAnchor"
            app:strokeWidth="0dp">
            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_add_thin"
                app:tint="@color/white" />
        </com.google.android.material.card.MaterialCardView>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>