<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dashboard_bg">

    <!-- Content area — constrained above the nav bar -->
    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipeRefreshLayout"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/navContainer">

        <FrameLayout
            android:id="@+id/fragment_container"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    <!-- Bottom nav — full width, flush to screen bottom -->
    <LinearLayout
        android:id="@+id/navContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/card_surface"
        android:elevation="10dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Hairline separator -->
        <View
            android:layout_width="match_parent"
            android:layout_height="0.8dp"
            android:background="@color/divider_color" />

        <!-- Nav items -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="6dp"
            android:paddingTop="8dp"
            android:paddingBottom="16dp">

            <!-- HOME -->
            <LinearLayout
                android:id="@+id/nav_dashboard"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <LinearLayout
                    android:id="@+id/pill_dashboard"
                    android:layout_width="52dp"
                    android:layout_height="32dp"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:background="@drawable/bg_nav_pill_active">

                    <ImageView
                        android:id="@+id/img_dashboard"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_home"
                        app:tint="#FFFFFF" />
                </LinearLayout>

                <TextView
                    android:id="@+id/txt_dashboard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:gravity="center"
                    android:text="Home"
                    android:textColor="@color/brand_blue"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:singleLine="true"
                    android:ellipsize="none"
                    android:visibility="visible" />
            </LinearLayout>

            <!-- SAVINGS -->
            <LinearLayout
                android:id="@+id/nav_savings"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <LinearLayout
                    android:id="@+id/pill_savings"
                    android:layout_width="52dp"
                    android:layout_height="32dp"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <ImageView
                        android:id="@+id/img_savings"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_wallet_safe_blue"
                        app:tint="#9CA3AF" />
                </LinearLayout>

                <TextView
                    android:id="@+id/txt_savings"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:gravity="center"
                    android:text="Savings"
                    android:textColor="#9CA3AF"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:singleLine="true"
                    android:ellipsize="none"
                    android:visibility="visible" />
            </LinearLayout>

            <!-- LOANS -->
            <LinearLayout
                android:id="@+id/nav_loans"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <LinearLayout
                    android:id="@+id/pill_loans"
                    android:layout_width="52dp"
                    android:layout_height="32dp"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <ImageView
                        android:id="@+id/img_loans"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_bank_filled"
                        app:tint="#9CA3AF" />
                </LinearLayout>

                <TextView
                    android:id="@+id/txt_loans"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:gravity="center"
                    android:text="Loans"
                    android:textColor="#9CA3AF"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:singleLine="true"
                    android:ellipsize="none"
                    android:visibility="visible" />
            </LinearLayout>

            <!-- ACTIVITY -->
            <LinearLayout
                android:id="@+id/nav_payouts"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <LinearLayout
                    android:id="@+id/pill_payouts"
                    android:layout_width="52dp"
                    android:layout_height="32dp"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <ImageView
                        android:id="@+id/img_payouts"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_history"
                        app:tint="#9CA3AF" />
                </LinearLayout>

                <TextView
                    android:id="@+id/txt_payouts"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:gravity="center"
                    android:text="Activity"
                    android:textColor="#9CA3AF"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:singleLine="true"
                    android:ellipsize="none"
                    android:visibility="visible" />
            </LinearLayout>

            <!-- PROFILE -->
            <LinearLayout
                android:id="@+id/nav_settings"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <LinearLayout
                    android:id="@+id/pill_settings"
                    android:layout_width="52dp"
                    android:layout_height="32dp"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <ImageView
                        android:id="@+id/img_settings"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_person"
                        app:tint="#9CA3AF" />
                </LinearLayout>

                <TextView
                    android:id="@+id/txt_settings"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:gravity="center"
                    android:text="Profile"
                    android:textColor="#9CA3AF"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:singleLine="true"
                    android:ellipsize="none"
                    android:visibility="visible" />
            </LinearLayout>

        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
