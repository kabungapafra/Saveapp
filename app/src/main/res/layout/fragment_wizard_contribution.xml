<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/v_page_bg"
    android:clipToPadding="false"
    android:paddingBottom="24dp"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Blue header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/brand_blue"
            android:orientation="vertical"
            android:paddingTop="52dp"
            android:paddingBottom="28dp"
            android:paddingHorizontal="24dp">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/bg_avatar_circle"
                android:backgroundTint="#2EFFFFFF"
                android:padding="8dp"
                android:src="@drawable/ic_arrow_back"
                app:tint="#FFFFFF" />

            <!-- Step dots -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:orientation="horizontal">

                <View android:layout_width="8dp" android:layout_height="6dp"
                    android:background="#4DFFFFFF" android:layout_marginEnd="5dp" />
                <View android:layout_width="20dp" android:layout_height="6dp"
                    android:background="#FFFFFF" android:layout_marginEnd="5dp" />
                <View android:layout_width="8dp" android:layout_height="6dp"
                    android:background="#4DFFFFFF" android:layout_marginEnd="5dp" />
                <View android:layout_width="8dp" android:layout_height="6dp"
                    android:background="#4DFFFFFF" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:fontFamily="@font/manrope_bold"
                android:text="Group Rules"
                android:textColor="#FFFFFF"
                android:textSize="28sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="@font/manrope_medium"
                android:text="Set contributions, penalties, and loan policies."
                android:textColor="#B3C8E8"
                android:textSize="13sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="@font/manrope_medium"
                android:text="Step 2 of 5"
                android:textColor="#80FFFFFF"
                android:textSize="12sp" />

        </LinearLayout>

        <!-- ── CONTRIBUTION section ── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="10dp"
            android:fontFamily="@font/manrope_bold"
            android:letterSpacing="0.08"
            android:text="CONTRIBUTIONS"
            android:textColor="@color/brand_blue"
            android:textSize="11sp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            app:cardBackgroundColor="@color/card_surface"
            app:cardCornerRadius="20dp"
            app:cardElevation="2dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Contribution Amount -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:fontFamily="@font/manrope_bold"
                    android:text="Contribution Amount"
                    android:textColor="@color/v_text_dark"
                    android:textSize="13sp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginBottom="20dp"
                    app:hintEnabled="false"
                    app:prefixText="UGX "
                    app:prefixTextColor="@color/v_text_muted">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etContributionAmount"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_wizard_input_solid"
                        android:fontFamily="@font/manrope_medium"
                        android:hint="0.00"
                        android:inputType="numberDecimal"
                        android:paddingHorizontal="16dp"
                        android:textColor="@color/v_text_dark"
                        android:textColorHint="@color/v_text_muted"
                        android:textSize="15sp" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Frequency -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:fontFamily="@font/manrope_bold"
                    android:text="Frequency"
                    android:textColor="@color/v_text_dark"
                    android:textSize="13sp" />

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginBottom="20dp"
                    android:background="@drawable/bg_wizard_input_solid">

                    <Spinner
                        android:id="@+id/spinnerFrequency"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@android:color/transparent"
                        android:fontFamily="@font/manrope_medium"
                        android:paddingHorizontal="16dp"
                        android:spinnerMode="dropdown" />

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:layout_gravity="end|center_vertical"
                        android:layout_marginEnd="16dp"
                        android:src="@drawable/ic_chevron_down"
                        app:tint="@color/v_text_muted" />
                </FrameLayout>

                <!-- Late Penalty -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:fontFamily="@font/manrope_bold"
                    android:text="Late Penalty (%)"
                    android:textColor="@color/v_text_dark"
                    android:textSize="13sp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginBottom="20dp"
                    app:hintEnabled="false"
                    app:suffixText="%"
                    app:suffixTextColor="@color/v_text_muted">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etLatePenalty"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_wizard_input_solid"
                        android:fontFamily="@font/manrope_medium"
                        android:hint="5"
                        android:inputType="numberDecimal"
                        android:paddingHorizontal="16dp"
                        android:text="5"
                        android:textColor="@color/v_text_dark"
                        android:textColorHint="@color/v_text_muted"
                        android:textSize="15sp" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Retention -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:fontFamily="@font/manrope_bold"
                    android:text="Payout Retention (%)"
                    android:textColor="@color/v_text_dark"
                    android:textSize="13sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:fontFamily="@font/manrope_medium"
                    android:text="Portion held back from each payout"
                    android:textColor="@color/v_text_muted"
                    android:textSize="12sp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    app:hintEnabled="false"
                    app:suffixText="%"
                    app:suffixTextColor="@color/v_text_muted">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etRetention"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_wizard_input_solid"
                        android:fontFamily="@font/manrope_medium"
                        android:hint="5"
                        android:inputType="numberDecimal"
                        android:paddingHorizontal="16dp"
                        android:textColor="@color/v_text_dark"
                        android:textColorHint="@color/v_text_muted"
                        android:textSize="15sp" />
                </com.google.android.material.textfield.TextInputLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── LOAN RULES section ── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="10dp"
            android:fontFamily="@font/manrope_bold"
            android:letterSpacing="0.08"
            android:text="LOAN RULES"
            android:textColor="@color/brand_blue"
            android:textSize="11sp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            app:cardBackgroundColor="@color/card_surface"
            app:cardCornerRadius="20dp"
            app:cardElevation="2dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Max Loan Amount -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:fontFamily="@font/manrope_bold"
                    android:text="Max Loan Amount per Member"
                    android:textColor="@color/v_text_dark"
                    android:textSize="13sp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginBottom="20dp"
                    app:hintEnabled="false"
                    app:prefixText="UGX "
                    app:prefixTextColor="@color/v_text_muted">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etMaxLoanAmount"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_wizard_input_solid"
                        android:fontFamily="@font/manrope_medium"
                        android:hint="0.00"
                        android:inputType="numberDecimal"
                        android:paddingHorizontal="16dp"
                        android:textColor="@color/v_text_dark"
                        android:textColorHint="@color/v_text_muted"
                        android:textSize="15sp" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Interest Rate -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:fontFamily="@font/manrope_bold"
                    android:text="Interest Rate (%)"
                    android:textColor="@color/v_text_dark"
                    android:textSize="13sp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginBottom="20dp"
                    app:hintEnabled="false"
                    app:suffixText="%"
                    app:suffixTextColor="@color/v_text_muted">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etInterestRate"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_wizard_input_solid"
                        android:fontFamily="@font/manrope_medium"
                        android:hint="10"
                        android:inputType="numberDecimal"
                        android:paddingHorizontal="16dp"
                        android:text="10"
                        android:textColor="@color/v_text_dark"
                        android:textColorHint="@color/v_text_muted"
                        android:textSize="15sp" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Repayment Period -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:fontFamily="@font/manrope_bold"
                    android:text="Repayment Period (Months)"
                    android:textColor="@color/v_text_dark"
                    android:textSize="13sp" />

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etRepaymentPeriod"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginBottom="20dp"
                    android:background="@drawable/bg_wizard_input_solid"
                    android:fontFamily="@font/manrope_medium"
                    android:hint="12"
                    android:inputType="number"
                    android:paddingHorizontal="16dp"
                    android:text="12"
                    android:textColor="@color/v_text_dark"
                    android:textColorHint="@color/v_text_muted"
                    android:textSize="15sp" />

                <!-- Require Guarantor toggle row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_wizard_input_solid"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="14dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/manrope_bold"
                            android:text="Require Guarantor"
                            android:textColor="@color/v_text_dark"
                            android:textSize="13sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:fontFamily="@font/manrope_medium"
                            android:text="Members need a guarantor for loans"
                            android:textColor="@color/v_text_muted"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switchRequireGuarantor"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true"
                        app:thumbTint="@color/switch_thumb_tint"
                        app:trackTint="@color/switch_track_blue"
                        app:thumbElevation="4dp" />
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
